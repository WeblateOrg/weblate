msgid "Verify the code from the app"
msgstr "Verifiera koden från appen"

#: weblate/accounts/forms.py:1211
msgid "Discard previously configured authentication apps"
msgstr "Förkasta tidigare konfigurerade autentiseringsappar"

#: weblate/accounts/forms.py:1215
msgid ""
"All previously configured authentication apps will be discarded upon "
"verification of the new app."
msgstr ""
"Alla tidigare konfigurerade autentiseringsappar kommer att förkastas när den "
"nya appen har verifierats."

#: weblate/accounts/forms.py:1218
msgid ""
"Other two-factor methods (such as WebAuthn and security keys) won't be "
"affected."
msgstr ""
"Andra tvåfaktorsmetoder (som WebAuthn och säkerhetsnycklar) påverkas inte."

#: weblate/accounts/forms.py:1225
msgid "The entered token is not valid."
msgstr "Det angivna token är ogiltigt."

#: weblate/accounts/forms.py:1295
msgid "Recovery token"
msgstr "Återställningstoken"

#: weblate/accounts/forms.py:1297
msgid ""
"Recovery codes can only be used once. Remember to mark used ones as expired."
msgstr ""
"Återställningskoder kan endast användas en gång. Kom ihåg att markera "
"använda koder som utgångna."

