msgstr "Matchar filer som nyheter_sv.md."

#: weblate/addons/forms.py:1051
msgid "Repeated language code"
msgstr "Upprepad språkkod"

#: weblate/addons/forms.py:1052
msgid "Matches files like locale/cs/application/cs.po."
msgstr "Matchar filer som locale/sv/program/sv.po."

#: weblate/addons/forms.py:1056
msgid "Split Android strings"
msgstr "Dela Android-strängar"

#: weblate/addons/forms.py:1057
msgid "Matches files like res/values-cs/strings-about.xml."
msgstr "Matchar filer som res/values-sv/strings-about.xml."

#: weblate/addons/forms.py:1061
msgid "Matching multiple paths"
msgstr "Matchning av flera sökvägar"

#: weblate/addons/forms.py:1063
msgid ""
"Matches nested Java properties layouts and also fills the component name "
"template."
msgstr ""
"Matchar nästade Java-egenskapsstrukturer och fyller även i mallen för "
"komponentnamn."

#: weblate/addons/forms.py:1091
#, python-format
msgid "Detected: %(pattern)s [%(details)s]"
msgstr "Upptäckt: %(pattern)s [%(details)s]"

#: weblate/addons/forms.py:1165
msgid "Detected from repository"
msgstr "Upptäckt från förråd"

#: weblate/addons/forms.py:1175
msgid "Generic presets"
msgstr "Allmänna förinställningar"

#: weblate/addons/forms.py:1206 weblate/trans/models/component.py:4952
msgid "You can not use a monolingual translation without a base file."
msgstr "Du kan inte använda enspråkig översättning utan en basfil."

#: weblate/addons/forms.py:1214 weblate/trans/models/component.py:4874
msgid "You can not use a base file for bilingual translation."
msgstr "Du kan inte använda en basfil för tvåspråkig översättning."

#: weblate/addons/forms.py:1228
msgid "Please review and confirm the matched components."
msgstr "Granska och bekräfta de matchade komponenterna."

#: weblate/addons/forms.py:1280
msgid "This template must include {{ component }}."
msgstr "Denna mall måste innehålla {{ component }}."

#: weblate/addons/forms.py:1281
msgid "This template must include component markup."
msgstr "Denna mall måste innehålla markering för komponenter."

#: weblate/addons/forms.py:1353
msgid "Translation threshold"
msgstr "Översättningströskel"

#: weblate/addons/forms.py:1359
msgid ""
"The percentage of translated strings that must be present for translation to "
"be included."
msgstr ""
"Den procentandel av översatta strängar som måste finnas för att "
"översättningen ska inkluderas."

#: weblate/addons/forms.py:1363
msgid "CSS selector"
msgstr "CSS-väljare"

#: weblate/addons/forms.py:1366
msgid "CSS selector to detect localizable elements."
msgstr "CSS-väljare för att upptäcka lokaliserbara element."

#: weblate/addons/forms.py:1369
msgid "Language cookie name"
msgstr "Namn på språkcookie"

#: weblate/addons/forms.py:1372
msgid "Name of cookie which stores language preference."
msgstr "Namn på cookie som lagrar språkinställningar."

#: weblate/addons/forms.py:1377
msgid "Extract strings from HTML files"
msgstr "Extrahera strängar från HTML-filer"

#: weblate/addons/forms.py:1380
msgid ""
"List of filenames in current repository or remote URLs to parse for "
"translatable strings."
msgstr ""
"Lista över filnamn i aktuella databas- eller fjärradresser som ska tolkas "
"för översättningsbara strängar."

#: weblate/addons/forms.py:1408
#, python-format
msgid "Could not parse CSS selector: %s"
msgstr "Kunde inte tolka CSS-selector: %s"

