msgstr "Källsträngar"

#: weblate/addons/forms.py:1461
msgid "Target translation"
msgstr "Målöversättning"

#: weblate/addons/forms.py:1463
msgid "All strings in this translation will be overwritten"
msgstr "Alla strängar i denna översättning kommer att skrivas över"

#: weblate/addons/forms.py:1468 weblate/templates/addons/pseudolocale.html:9
msgid "Prepended static text"
msgstr "Statisk text i början"

#: weblate/addons/forms.py:1473 weblate/templates/addons/pseudolocale.html:10
msgid "Prepended variable text"
msgstr "Variabel text i början"

#: weblate/addons/forms.py:1478 weblate/templates/addons/pseudolocale.html:13
msgid "Appended static text"
msgstr "Statisk text i slutet"

#: weblate/addons/forms.py:1483 weblate/templates/addons/pseudolocale.html:12
msgid "Appended variable text"
msgstr "Variabel text i slutet"

#: weblate/addons/forms.py:1488
msgid "Variable text multiplier"
msgstr "Variabel textmultiplikator"

#: weblate/addons/forms.py:1492
msgid ""
"How many times to repeat the variable text depending on the length of the "
"source string."
msgstr ""
"Hur många gånger variabeltexten ska upprepas beroende på längden på "
"källsträngen."

#: weblate/addons/forms.py:1497
msgid "Include read-only strings"
msgstr "Inkludera skrivskyddade strängar"

#: weblate/addons/forms.py:1527
msgid "The source and target have to be different languages."
msgstr "Källan och målet måste vara olika språk."

#: weblate/addons/forms.py:1545
msgid "Enable case-sensitive key sorting"
msgstr "Aktivera sortering av tangenter med skiftlägeskänslighet"

#: weblate/addons/forms.py:1558
msgid "Change events to trigger"
msgstr "Ändringshändelser som skall utösas"

#: weblate/addons/forms.py:1564
msgid "Translation content events"
msgstr "Översättningsinnehållshändelser"

#: weblate/addons/forms.py:1568
msgid "All change events"
msgstr "Alla ändringshändelser"

