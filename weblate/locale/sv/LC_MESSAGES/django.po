msgstr "Mejl med en bekräftelselänk kommer att skickas hit."

#: weblate/accounts/forms.py:750
msgid "New password"
msgstr "Nytt lösenord"

#: weblate/accounts/forms.py:755
msgid "New password confirmation"
msgstr "Bekräfta nytt lösenord"

#: weblate/accounts/forms.py:759 weblate/templates/accounts/profile.html:570
msgid "Regenerate API key"
msgstr "Generera om API-nyckel"

#: weblate/accounts/forms.py:761
msgid ""
"Leave enabled to revoke the current API key and generate a new one. This is "
"recommended if you suspect your password was compromised. Disable it to keep "
"your current API key active after changing your password."
msgstr ""
"Låt detta vara aktiverat för att återkalla den nuvarande API-nyckeln och "
"generera en ny. Detta rekommenderas om du misstänker att ditt lösenord har "
"blivit avslöjat. Avaktivera det för att behålla din nuvarande API-nyckel "
"aktiv efter att lösenordet bytts."

#: weblate/accounts/forms.py:797
msgid "Your password has been changed."
msgstr "Ditt lösenord har ändrats."

#: weblate/accounts/forms.py:811
msgid "Current password"
msgstr "Nuvarande lösenord"

#: weblate/accounts/forms.py:812
