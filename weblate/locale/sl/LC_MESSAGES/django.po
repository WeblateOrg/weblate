#: weblate/accounts/forms.py:1026
msgid ""
"You will receive a notification for every such event in non-watched projects."
msgstr ""
"Prejeli boste obvestilo ob vsakem takšnem dogodku v ne spremljanih projektih."

#: weblate/accounts/forms.py:1031
msgid ""
"You will receive a notification for every such event in your watched "
"projects."
msgstr ""
"Prejeli boste obvestilo ob vsakem takšnem dogodku v vaših spremljanih "
"projektih."

#: weblate/accounts/forms.py:1036
msgid ""
"You will receive a notification for every such event in projects where you "
"have admin permissions."
msgstr ""
"Prejeli boste obvestilo ob vsakem takšnem dogodku v projektih kjer imate "
"skrbniške pravice."

#: weblate/accounts/forms.py:1041
#, python-format
msgid "You will receive a notification for every such event in %(project)s."
msgstr ""
"Prejeli boste obvestilo ob vsakem takšnem dogodku v projektu %(project)s."

#: weblate/accounts/forms.py:1044
#, python-format
msgid "You will receive a notification for every such event in %(component)s."
msgstr ""
"Prejeli boste obvestilo ob vsakem takšnem dogodku v komponenti %(component)s."

#: weblate/accounts/forms.py:1051
msgid ""
"You will only receive these notifications for your translated languages in "
"non-watched projects."
msgstr ""
"Ta obvestila boste prejemali samo za svoje prevodne jezike v ne spremljanih "
"projektih."

#: weblate/accounts/forms.py:1056
msgid ""
"You will only receive these notifications for your translated languages in "
"your watched projects."
msgstr ""
"Ta obvestila boste prejemali samo za vaše prevedene jezike v vaših "
"spremljanih projektih."

#: weblate/accounts/forms.py:1061
msgid ""
"You will only receive these notifications for your translated languages in "
"projects where you have admin permissions."
msgstr ""
"Ta obvestila boste prejemali samo za vaše prevedene jezike v projektih, kjer "
"imate administratorske pravice."

#: weblate/accounts/forms.py:1066
#, python-format
msgid ""
"You will only receive these notifications for your translated languages in "
"%(project)s."
msgstr ""
"Ta obvestila boste prejemali samo za vaše prevedene jezike v projektu "
"%(project)s."

#: weblate/accounts/forms.py:1070
#, python-format
msgid ""
"You will only receive these notifications for your translated languages in "
"%(component)s."
msgstr ""
"Ta obvestila boste prejemali samo za vaše prevedene jezike v komponentah "
"%(component)s."

