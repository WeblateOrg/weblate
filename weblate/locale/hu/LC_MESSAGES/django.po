#: weblate/checks/fluent/inner_html.py:172
#, python-brace-format
msgid ""
"The sequence {sequence} begins with a HTML closing tag, but the name or "
"syntax is not valid. If you do not want a closing tag, use {suggestion}."
msgstr ""
"A(z) {sequence} sorozat HTML záró címkével kezdődik, de a név vagy a "
"szintaxis nem érvényes. Ha nem szeretne záró címkét, akkor használja a(z) "
"{suggestion} javaslatot."

#: weblate/checks/fluent/inner_html.py:185
#, python-brace-format
msgid ""
"The sequence {sequence} begins with a HTML tag, but the name is not valid. "
"If you do not want to begin a HTML tag, use {suggestion}."
msgstr ""
"A(z) {sequence} sorozat HTML címkével kezdődik, de a név nem érvényes. Ha "
"nem szeretne HTML címkével kezdeni, akkor használja a(z) {suggestion} "
"javaslatot."

#: weblate/checks/fluent/inner_html.py:198
#, python-brace-format
msgid ""
"The sequence {sequence} begins with a HTML tag, but the tag is never closed "
