#: weblate/checks/fluent/inner_html.py:129
#, python-brace-format
msgid ""
"The Fluent reference in {sequence} may expand into a HTML tag. Maybe use "
"{suggestion}."
msgstr ""
"A(z) {sequence} sorozatban lévő Fluent-hivatkozás HTML címkévé bontható ki. "
"Esetleg használja a(z) {suggestion} javaslatot."

