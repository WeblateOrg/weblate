msgid ""
"Other two-factor methods (such as WebAuthn and security keys) won't be "
"affected."
msgstr ""
"Más kétfaktoros módszerek (mint például a WebAuthn és biztonsági kulcsok) "
"nem lesznek érintettek."

#: weblate/accounts/forms.py:1187
msgid "The entered token is not valid."
msgstr "A megadott token nem érvényes."

#: weblate/accounts/forms.py:1257
msgid "Recovery token"
msgstr "Visszaszerzési token"

#: weblate/accounts/forms.py:1259
msgid ""
"Recovery codes can only be used once. Remember to mark used ones as expired."
msgstr ""
"A visszaszerzési kódok csak egyszer használhatók. Ne felejtse el a "
"felhasználtakat lejártként megjelölni."

#: weblate/accounts/forms.py:1316
