#, python-brace-format
msgid ""
"Fluent inner HTML should not include {sequence}. Maybe use {suggestion}."
msgstr ""
"A Fluent belső HTML-e nem tartalmazhat {sequence} sorozatot. Esetleg "
"használja a(z) {suggestion} javaslatot."

#: weblate/checks/fluent/inner_html.py:228
#, python-brace-format
msgid ""
"The sequence {sequence} begins with a HTML tag, but the sequence {attribute} "
"is not a valid attribute with a value. If you do not want to begin a HTML "
