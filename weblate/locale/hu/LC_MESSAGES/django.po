msgid "Managed projects"
msgstr "Menedzselt projektek"

#: weblate/accounts/forms.py:996
msgid "Project: {}"
msgstr "Projekt: {}"

#: weblate/accounts/forms.py:997
msgid "Component: {}"
msgstr "Összetevő: {}"

#: weblate/accounts/forms.py:1003
msgid ""
"You will receive a notification for every such event in non-watched projects."
msgstr ""
"Minden ilyen eseményről értesítést fog kapni a nem megfigyelt projektekben."

#: weblate/accounts/forms.py:1008
msgid ""
"You will receive a notification for every such event in your watched "
"projects."
msgstr ""
"Minden ilyen eseményről értesítést fog kapni a megfigyelt projektekben."

#: weblate/accounts/forms.py:1013
msgid ""
"You will receive a notification for every such event in projects where you "
"have admin permissions."
msgstr ""
"Minden ilyen eseményről értesítést fog kapni azokban a projektekben, ahol "
"adminisztrátori jogosultságokkal rendelkezik."

#: weblate/accounts/forms.py:1018
#, python-format
msgid "You will receive a notification for every such event in %(project)s."
msgstr ""
"Minden ilyen eseményről értesítést fog kapni a(z) %(project)s projektekben."

#: weblate/accounts/forms.py:1021
#, python-format
msgid "You will receive a notification for every such event in %(component)s."
msgstr ""
"Minden ilyen eseményről értesítést fog kapni a(z) %(component)s összetevőben."

#: weblate/accounts/forms.py:1028
msgid ""
"You will only receive these notifications for your translated languages in "
"non-watched projects."
msgstr ""
"Ezeket az értesítéseket csak a nem megfigyelt projektjeiben lefordított "
"nyelvekre fogja megkapni."

#: weblate/accounts/forms.py:1033
msgid ""
"You will only receive these notifications for your translated languages in "
"your watched projects."
msgstr ""
"Ezeket az értesítéseket csak a megfigyelt projektjeiben lefordított "
"nyelvekre fogja megkapni."

#: weblate/accounts/forms.py:1038
msgid ""
"You will only receive these notifications for your translated languages in "
"projects where you have admin permissions."
msgstr ""
"Ezeket az értesítéseket csak azokban a projektekben lévő lefordított "
"nyelvekre fogja megkapni, ahol adminisztrátori jogosultságokkal rendelkezik."

#: weblate/accounts/forms.py:1043
#, python-format
msgid ""
"You will only receive these notifications for your translated languages in "
"%(project)s."
msgstr ""
"Ezeket az értesítéseket csak a(z) %(project)s projektben lévő lefordított "
"nyelvekre fogja megkapni."

#: weblate/accounts/forms.py:1047
#, python-format
msgid ""
"You will only receive these notifications for your translated languages in "
"%(component)s."
msgstr ""
"Ezeket az értesítéseket csak a(z) %(component)s összetevőben lévő "
"lefordított nyelvekre fogja megkapni."

