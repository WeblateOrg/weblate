#. Translators: Audit log entry
#: weblate/accounts/models.py:292
#, python-brace-format
msgid "Removed sign in using {method} ({name})."
msgstr "Влизането чрез ({method}) ({name}) е премахнато."

#. Translators: Audit log entry
#: weblate/accounts/models.py:294
#, python-brace-format
msgid "Signed in using {method} ({name})."
msgstr "Влезли сте чрез ({method}) ({name})."

#. Translators: Audit log entry
#: weblate/accounts/models.py:296
#, python-brace-format
msgid "Signed in using {method} ({name}) from a new device."
msgstr "Влезли сте чрез ({method}) ({name}) от ново устройство."

#. Translators: Audit log entry
#: weblate/accounts/models.py:298
msgid "Somebody attempted to register with your e-mail."
msgstr "Някой опита да се регистрира с Вашата е-поща."

#: weblate/accounts/models.py:301
msgid "Somebody attempted to register using your e-mail address."
msgstr "Някой сопита да се регистрира чрез Вашата е-поща."

#. Translators: Audit log entry
#: weblate/accounts/models.py:304
#, python-brace-format
msgid "Could not sign in using {method} ({name})."
msgstr "Влизането чрез ({method}) ({name}) не е успешно."

#. Translators: Audit log entry
#: weblate/accounts/models.py:306
msgid "Account locked due to many failed sign in attempts."
msgstr "Акаунтът е заключен поради твърде много неуспешни опити за вход."

#. Translators: Audit log entry
#: weblate/accounts/models.py:308
msgid "Account locked by the site administrator."
msgstr "Акаунтът е заключен от администратора на уеб сайта."

#. Translators: Audit log entry
#: weblate/accounts/models.py:310
msgid "Account and all private data removed."
msgstr "Акаунтът и всички лични данни са премахнати."

#. Translators: Audit log entry
#: weblate/accounts/models.py:312
#, python-brace-format
msgid "Account removal confirmation sent to {email}."
msgstr ""
"Изпратено е е-писмо до {email} за потвърждение на изтриването на акаунта."

#. Translators: Audit log entry
#: weblate/accounts/models.py:314
#, python-brace-format
msgid "Agreement with General Terms and Conditions {date}."
msgstr "Съгласие с документа за „Общи условия за ползване“ — {date}."

#. Translators: Audit log entry
#: weblate/accounts/models.py:316
#, python-brace-format
msgid "Invited to {site_title} by {username}."
msgstr "Поканен в {site_title} от {username}."

#. Translators: Audit log entry
#: weblate/accounts/models.py:318
#, python-brace-format
msgid "Accepted invitation from {username}."
msgstr "Приета покана от {username}."

#. Translators: Audit log entry
#: weblate/accounts/models.py:320
msgid "Started trial period."
msgstr "Пробният период е започнат."

#. Translators: Audit log entry
#: weblate/accounts/models.py:322
#, python-brace-format
msgid "Sent confirmation mail to {email}."
msgstr "Изпратено е е-писмо за потвърждение на {email}."

#: weblate/accounts/models.py:325
msgid ""
"The system created a user to track authorship of translations uploaded by "
"other user."
msgstr ""
"Системата създаде потребител, чрез който да следи авторството на преводите, "
"качени от друг потребител."

#: weblate/accounts/models.py:330
msgid ""
"Account created externally from weblate.org for access to purchased services."
msgstr "Акаунтът е създаден извън weblate.org за достъп до платени услуги."

#. Translators: Audit log entry
#: weblate/accounts/models.py:333
#, python-brace-format
msgid "Access to project {project} was blocked."
msgstr "Достъпът до проекта {project} е спрян."

#. Translators: Audit log entry
#: weblate/accounts/models.py:335
msgid "User was enabled by administrator."
msgstr "Потребителят е включен от администратор."

#. Translators: Audit log entry
#: weblate/accounts/models.py:337
msgid "User was disabled by administrator."
msgstr "Потребителят е изключен от администратор."

#: weblate/accounts/models.py:340
msgid "User was disabled because the access has expired."
msgstr "Потребителят е изключен, тъй като достъпът му е изтекъл."

#: weblate/accounts/models.py:344
#, python-brace-format
msgid "User was added to the site-wide {team} team by {username}."
msgstr ""
"Потребител е добавен в екип {team}, който е за целия уеб сайт, от {username}."

#: weblate/accounts/models.py:348
#, python-brace-format
msgid "User access to the site-wide {team} team was changed by {username}."
msgstr ""
"Достъпът на потребител до екип {team}, който е за целия уеб сайт, беше "
"променен от {username}."

#: weblate/accounts/models.py:352
#, python-brace-format
msgid "User was removed from the site-wide {team} team by {username}."
msgstr ""
"Потребител е премахнат от екип {team}, който е за целия уеб сайт, от "
"{username}."

#. Translators: Audit log entry
#: weblate/accounts/models.py:355
msgid "Superuser privileges granted."
msgstr "Дадени са права на супер потребител."

