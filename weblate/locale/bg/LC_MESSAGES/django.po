msgstr "Представка – променлив текст"

#: weblate/addons/forms.py:1441 weblate/templates/addons/pseudolocale.html:13
msgid "Appended static text"
msgstr "Наставка – статичен текст"

#: weblate/addons/forms.py:1446 weblate/templates/addons/pseudolocale.html:12
msgid "Appended variable text"
msgstr "Наставка – променлив текст"

#: weblate/addons/forms.py:1451
msgid "Variable text multiplier"
msgstr "Множител за променливия текст"

#: weblate/addons/forms.py:1455
msgid ""
"How many times to repeat the variable text depending on the length of the "
"source string."
msgstr ""
"Колко пъти да се повтаря променливия текст, в зависимост от дължината на "
"изходния низ."

#: weblate/addons/forms.py:1460
msgid "Include read-only strings"
msgstr "Да се включат и низовете, които са само за четене"

