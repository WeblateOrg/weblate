#: weblate/accounts/forms.py:99
msgid ""
"This e-mail address is already in use. Please supply a different e-mail "
"address."
msgstr ""
"Тази е-поща вече се използва в системата. Моля, въведете друга ел. поща."

#: weblate/accounts/forms.py:131
msgid "This username is already taken. Please pick something else."
msgstr "Това потребителско име е заето. Моля, изберете друго."

#: weblate/accounts/forms.py:144 weblate/accounts/forms.py:1106
#: weblate/auth/models.py:805 weblate/auth/models.py:1928
#: weblate/templates/auth/team.html:126 weblate/templates/manage/users.html:60
#: weblate/templates/trans/project-access.html:59
msgid "Full name"
msgstr "Пълно име"

#: weblate/accounts/forms.py:146
msgid "Name is also used in version control commits."
msgstr ""
"Името се използва и в подаванията към системата за контрол на версиите."

#: weblate/accounts/forms.py:211 weblate/accounts/models.py:974
msgid "Commit e-mail"
msgstr "Е-поща за подаванията"

#: weblate/accounts/forms.py:212
msgid "Use account e-mail address"
msgstr "Да се използва адресът на е-пощата на акаунта"

#: weblate/accounts/forms.py:214
msgid ""
"Used in version-control commits. The address stays in the repository forever "
"once changes are committed by Weblate."
msgstr ""
"Използва се при подавания към системата за контрол на версиите. Адресът "
"остава завинаги в хранилището, след като промените бъдат подадени от Weblate."

#: weblate/accounts/forms.py:221 weblate/accounts/models.py:985
msgid "Commit name"
msgstr "Име за подаванията"

#: weblate/accounts/forms.py:224
msgid ""
"Used in version control commits. The name stays in the repository forever, "
"once changes are committed by Weblate."
msgstr ""
"Използва се при подавания към системата за контрол на версиите. Името остава "
"завинаги в хранилището, след като промените бъдат подадени от Weblate."

#: weblate/accounts/forms.py:252
msgid "Use anonymous account name"
msgstr "Използване на анонимно име на акаунт"

#: weblate/accounts/forms.py:254
msgid "Use account name"
msgstr "Да се използва името на акаунта"

#: weblate/accounts/forms.py:275 weblate/accounts/models.py:968
msgid "Public e-mail"
msgstr "Публична е-поща"

#: weblate/accounts/forms.py:276
msgid "Hide e-mail address from public view"
msgstr "Скриване на адреса на е-пощата от публичния изглед"

#: weblate/accounts/forms.py:394
#, python-format
msgid "Component list: %s"
msgstr "Списък на компонентите: %s"

#: weblate/accounts/forms.py:421
msgid "Account e-mail"
msgstr "Е-поща на акаунта"

#: weblate/accounts/forms.py:423
msgid ""
"Used for e-mail notifications and as a commit e-mail if it is not configured "
"below."
msgstr ""
"Използва се за известия по е-поща и като е-поща при подавания, ако нещо "
"друго не бъде настроено по-долу."

#: weblate/accounts/forms.py:493
msgid "Human verification"
msgstr "Потвърждение на това, че сте човек"

#: weblate/accounts/forms.py:564
#, python-format
msgctxt ""
"Question for a mathematics-based CAPTCHA, the %s is an arithmetic problem"
msgid "What is %s?"
msgstr "Колко е %s?"

#. Translators: Shown on wrong answer to the mathematics-based CAPTCHA
#: weblate/accounts/forms.py:583
msgid "That was not correct, please try again."
msgstr "Отговорът е грешен, моля, опитайте отново."

#: weblate/accounts/forms.py:597 weblate/accounts/forms.py:604
#: weblate/accounts/forms.py:612 weblate/accounts/forms.py:623
msgid "Validation failed, please try again."
msgstr "Потвърждението беше неуспешно. Опитайте отново."

#: weblate/accounts/forms.py:642
msgid "Subject"
msgstr "Тема"

#: weblate/accounts/forms.py:645
msgid "Your name"
msgstr "Име"

#: weblate/accounts/forms.py:647
msgid "Your e-mail"
msgstr "Адрес на ел. поща"

#: weblate/accounts/forms.py:649 weblate/templates/manage/performance.html:28
#: weblate/templates/manage/performance.html:81
#: weblate/trans/models/announcement.py:164
msgid "Message"
msgstr "Съобщение"

#: weblate/accounts/forms.py:652
msgid ""
"Please contact us in English. Otherwise, we might not process your request."
msgstr ""
"Пишете на английски. В противен случай може да не обработим Вашата заявка."

#: weblate/accounts/forms.py:677 weblate/accounts/templatetags/authnames.py:34
#: weblate/auth/models.py:811 weblate/auth/models.py:1945
#: weblate/templates/accounts/user.html:253
#: weblate/templates/manage/users.html:61
#: weblate/templates/trans/project-access.html:61 weblate/utils/fields.py:40
#: weblate/wladmin/forms.py:58
msgid "E-mail"
msgstr "Е-поща"

#: weblate/accounts/forms.py:678
msgid "An e-mail with a confirmation link will be sent here."
msgstr "Тук ще бъде изпратено е-писмо с връзка за потвърждение."

#: weblate/accounts/forms.py:741
msgid "New password"
msgstr "Нова парола"

#: weblate/accounts/forms.py:746
msgid "New password confirmation"
msgstr "Потвърждение на новата парола"

#: weblate/accounts/forms.py:750 weblate/templates/accounts/profile.html:574
msgid "Regenerate API key"
msgstr "Регенериране на ключ за ППИ"

#: weblate/accounts/forms.py:752
msgid ""
"Leave enabled to revoke the current API key and generate a new one. This is "
"recommended if you suspect your password was compromised. Disable it to keep "
"your current API key active after changing your password."
msgstr ""
"Оставете това включено, за да премахнете текущия ключ за ППИ и да създадете "
"нов. Това е препоръчително, ако имате съмнения, че някой може да знае "
"паролата Ви. Изключете го, за да запазите текущия си ключ за ППИ след "
"промяната на паролата си."

#: weblate/accounts/forms.py:788
msgid "Your password has been changed."
msgstr "Паролата е променена."

#: weblate/accounts/forms.py:802
msgid "Current password"
msgstr "Текуща парола"

#: weblate/accounts/forms.py:803
msgid "Leave empty if you have not set a password yet."
msgstr "Оставете полето празно, ако все още не сте задали парола."

#: weblate/accounts/forms.py:817
msgid "You have entered an invalid password."
msgstr "Въведохте грешна парола."

#: weblate/accounts/forms.py:830
msgid "Username or e-mail"
msgstr "Потребителско име или е-поща"

#: weblate/accounts/forms.py:831 weblate/accounts/templatetags/authnames.py:33
msgid "Password"
msgstr "Парола"

#: weblate/accounts/forms.py:836
msgid "Please enter the correct username and password."
msgstr "Моля, въведете правилно Вашето потребителско име и парола."

#: weblate/accounts/forms.py:838
msgid "This account is inactive."
msgstr "Акаунтът е неактивен."

#: weblate/accounts/forms.py:957
msgid "Component wide notifications"
msgstr "Общи известия"

#: weblate/accounts/forms.py:962
msgid "Translation notifications"
msgstr "Известия за превод"

#: weblate/accounts/forms.py:981
msgid "Use default setting"
msgstr "Използване на настройките по подразбиране"

#: weblate/accounts/forms.py:1013
msgid "Other projects"
msgstr "Други проекти"

#: weblate/accounts/forms.py:1015 weblate/accounts/models.py:890
#: weblate/templates/accounts/profile.html:106
#: weblate/templates/accounts/user.html:174
msgid "Watched projects"
msgstr "Наблюдавани проекти"

#: weblate/accounts/forms.py:1017 weblate/accounts/models.py:863
#: weblate/templates/accounts/user.html:171
#: weblate/templates/dashboard/user.html:43
msgid "Managed projects"
msgstr "Управлявани проекти"

#: weblate/accounts/forms.py:1019
msgid "Project: {}"
msgstr "Проект: {}"

#: weblate/accounts/forms.py:1020
msgid "Component: {}"
msgstr "Компонент: {}"

#: weblate/accounts/forms.py:1026
msgid ""
"You will receive a notification for every such event in non-watched projects."
msgstr ""
"Ще получавате известия за всяко подобно събитие в проектите, които не "
"следите."

#: weblate/accounts/forms.py:1031
msgid ""
"You will receive a notification for every such event in your watched "
"projects."
msgstr ""
"Ще получавате известия за всяко подобно събитие в наблюдаваните проекти."

#: weblate/accounts/forms.py:1036
msgid ""
"You will receive a notification for every such event in projects where you "
"have admin permissions."
msgstr ""
"Ще получавате известия за всяко подобно събитие в проектите, в които имате "
"администраторски права."

#: weblate/accounts/forms.py:1041
#, python-format
msgid "You will receive a notification for every such event in %(project)s."
msgstr "Ще получавате известия за всяко подобно събитие в %(project)s."

#: weblate/accounts/forms.py:1044
#, python-format
msgid "You will receive a notification for every such event in %(component)s."
msgstr "Ще получавате известия за всяко подобно събитие в %(component)s."

#: weblate/accounts/forms.py:1051
msgid ""
"You will only receive these notifications for your translated languages in "
"non-watched projects."
msgstr ""
"Ще получавате тези известия за езиците, на които превеждате, в проектите, "
"които не следите."

#: weblate/accounts/forms.py:1056
msgid ""
"You will only receive these notifications for your translated languages in "
"your watched projects."
msgstr ""
"Ще получавате тези известия само за езиците, на които превеждате "
"наблюдаваните проекти."

#: weblate/accounts/forms.py:1061
msgid ""
"You will only receive these notifications for your translated languages in "
"projects where you have admin permissions."
msgstr ""
"Ще получавате тези известия само за езиците, на които превеждате, в "
"проектите, в които имате администраторски права."

#: weblate/accounts/forms.py:1066
#, python-format
msgid ""
"You will only receive these notifications for your translated languages in "
"%(project)s."
msgstr ""
"Ще получавате тези известия само за езиците, на които превеждате, в "
"%(project)s."

#: weblate/accounts/forms.py:1070
#, python-format
msgid ""
"You will only receive these notifications for your translated languages in "
"%(component)s."
msgstr ""
"Ще получавате тези известия само за езиците, на които превеждате, в "
"%(component)s."

#: weblate/accounts/forms.py:1105 weblate/auth/models.py:792
#: weblate/auth/models.py:1919 weblate/templates/auth/team.html:125
#: weblate/templates/manage/users.html:59
#: weblate/templates/trans/project-access.html:58 weblate/utils/forms.py:93
msgid "Username"
msgstr "Потребителско име"

#: weblate/accounts/forms.py:1107 weblate/auth/models.py:840
#: weblate/trans/forms.py:1686
msgid "Date joined"
msgstr "Дата на присъединяване"

#: weblate/accounts/forms.py:1108
msgid "Translations made"
msgstr "Направени преводи"

#: weblate/accounts/forms.py:1109
msgid "Suggestions made"
msgstr "Направени предложения"

#: weblate/accounts/forms.py:1110
msgid "Comments made"
msgstr "Написани коментари"

#: weblate/accounts/forms.py:1111
msgid "Screenshots uploaded"
msgstr "Качени снимки"

#: weblate/accounts/forms.py:1135 weblate/screenshots/forms.py:233
msgid "The chosen sorting is not supported."
msgstr "Избраната подредба не се поддържа."

#: weblate/accounts/forms.py:1152 weblate/auth/forms.py:321
#: weblate/auth/models.py:1938 weblate/templates/accounts/profile.html:452
#: weblate/templates/accounts/user.html:334
#: weblate/templates/trans/project-access-team-form.html:13
msgid "Team"
msgstr "Екип"

#: weblate/accounts/forms.py:1169
msgid "Add to a team"
msgstr "Добавяне към екип"

#: weblate/accounts/forms.py:1183
msgid "Name your authentication app"
msgstr "Дайте име на удостоверителното си приложение"

#: weblate/accounts/forms.py:1186
msgid "Verify the code from the app"
msgstr "Потвърдете кода от приложението"

#: weblate/accounts/forms.py:1202
msgid "Discard previously configured authentication apps"
msgstr "Премахване на настроените удостоверителни приложения"

#: weblate/accounts/forms.py:1206
msgid ""
"All previously configured authentication apps will be discarded upon "
"verification of the new app."
msgstr ""
"Всички настроени досега удостоверителни приложения ще бъдат премахнати при "
"потвърждаването на новото приложение."

#: weblate/accounts/forms.py:1209
msgid ""
"Other two-factor methods (such as WebAuthn and security keys) won't be "
"affected."
msgstr ""
"Ако имате други двустъпкови методи (като WebAuthn или секретни ключове), те "
"няма да бъдат засегнати."

#: weblate/accounts/forms.py:1216
msgid "The entered token is not valid."
msgstr "Въведеният идентификатор не е правилен."

#: weblate/accounts/forms.py:1286
msgid "Recovery token"
msgstr "Идентификатор за възстановяване"

#: weblate/accounts/forms.py:1288
msgid ""
"Recovery codes can only be used once. Remember to mark used ones as expired."
msgstr ""
"Кодовете за възстановяване може да бъдат използвани само по веднъж. Не "
"забравяйте да отбележите използваните след употреба."

#: weblate/accounts/forms.py:1346
msgid "Enter the code from the app"
msgstr "Въведете кода от приложението"

#. Translators: Audit log entry
