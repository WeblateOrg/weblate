msgstr "Потребителското име е променено от {old} на {new}."

#. Translators: Audit log entry
#: weblate/accounts/models.py:282
#, python-brace-format
msgid "E-mail changed from {old} to {new}."
msgstr "Е-пощата е променена от {old} на {new}."

#. Translators: Audit log entry
#: weblate/accounts/models.py:284
#, python-brace-format
msgid "Full name changed from {old} to {new}."
msgstr "Пълното име е променено от {old} на {new}."

#. Translators: Audit log entry
#: weblate/accounts/models.py:286
msgid "Password reset requested."
msgstr "Заявено е подновяване на паролата."

#. Translators: Audit log entry
#: weblate/accounts/models.py:288
