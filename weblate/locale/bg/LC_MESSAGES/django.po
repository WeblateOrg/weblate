msgstr[1] "%(count)s липсващи подавания"

#: weblate/templates/js/git-status.html:109
msgid "This will update the Weblate repository with the upstream changes."
msgstr ""
"Това ще обнови хранилището на Weblate като изтегли отдалечените промени."

#: weblate/templates/js/git-status.html:118
msgid "Allow changes to the Weblate repository"
