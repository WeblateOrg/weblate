#: weblate/templates/vcs/github_app_register.html:59
msgid "Webhook URL"
msgstr "Адрес на уеб-куката"

#: weblate/addons/forms.py:1630 weblate/vcs/github.py:455
msgid "Webhook secret"
msgstr "Тайна за уеб-куката"

#: weblate/addons/forms.py:1636
msgid "The Standard Webhooks secret is a base64 encoded string."
msgstr ""
"Стандартната тайна за уеб-куките е във вида на низ кодиран чрез base64."

#: weblate/addons/forms.py:1650
msgid "AMQP broker URL"
msgstr "Адрес на брокера на AMPQ"

#: weblate/addons/forms.py:1651
msgid "The AMQP broker URL to connect to."
msgstr "Адресът на брокера на AMPQ, с който да се направи връзка."

#: weblate/addons/forms.py:1655
msgid "Topic prefix"
msgstr "Представка на темата"

#: weblate/addons/forms.py:1657
msgid "Optional prefix to prepend to generated message topics."
msgstr ""
"Незадължителна представка, която да се добавя към темите за генерираните "
"съобщения."

#: weblate/addons/forms.py:1663
msgid "CA certificate bundle (PEM)"
msgstr "Пакет CA сертификати (PEM)"

#: weblate/addons/forms.py:1665
msgid ""
"Paste only PEM certificate blocks, each starting with \"-----BEGIN "
"CERTIFICATE-----\" and ending with \"-----END CERTIFICATE-----\"."
msgstr ""
"Поставете само блоковете от сертификати PEM, като всеки започва с „-----"
"BEGIN CERTIFICATE-----“ и завършва с „-----END CERTIFICATE-----“."

#: weblate/addons/forms.py:1671
msgid "Client private key (PEM)"
msgstr "Клиентски частен ключ (PEM)"

#: weblate/addons/forms.py:1673
msgid ""
"Paste a single unencrypted PEM private key block. Encrypted private keys are "
"not supported."
msgstr ""
"Поставете един блок от нешифрован частен ключ PEM. Шифровани частни ключове "
"не се поддържат."

#: weblate/addons/forms.py:1680
msgid "Client certificate (PEM)"
msgstr "Клиентски сертификат (PEM)"

#: weblate/addons/forms.py:1682
msgid ""
"Paste only the PEM certificate block starting with \"-----BEGIN "
"CERTIFICATE-----\"; do not paste the output from \"openssl x509 -text\"."
msgstr ""
"Поставете само блока от сертификата PEM, който започва с „-----BEGIN "
"CERTIFICATE-----“. Не поставяйте резултата от „openssl x509 -text“."

#: weblate/addons/forms.py:1687
msgid "Publish timeout"
msgstr "Време за изчакване на публикуването"

#: weblate/addons/forms.py:1689
msgid "How many seconds to wait for the broker delivery acknowledgement."
msgstr "Колко секунди да се чака брокерът за потвърждение на доставката."

#: weblate/addons/forms.py:1697
msgid "Connection attempts"
msgstr "Опити за свързване"

#: weblate/addons/forms.py:1698
msgid "How many times to try connecting to the broker."
msgstr "Колко пъти да се прави опит за свързване с брокера."

#: weblate/addons/forms.py:1705
msgid "Retry delay"
msgstr "Изчакване преди повторен опит"

#: weblate/addons/forms.py:1706
msgid "How many seconds to wait between connection attempts."
msgstr "Колко секунди да се изчаква преди всеки нов опит за свързване."

#: weblate/addons/forms.py:1755
msgid "Topic prefix can contain only ASCII characters."
msgstr "Представката за темата може да съдържа само знаци от ASCII."

#: weblate/addons/forms.py:1760
#, python-format
msgid "Topic prefix must not exceed %(limit)d characters."
msgstr "Представката на темата може да бъде не по-дълга от %(limit)d знака."

#: weblate/addons/forms.py:1794
msgid "The SSL certificates have to be provided for SSL connection."
msgstr "За връзка чрез SSL трябва да бъдат предоставени SSL сертификатите."

#: weblate/addons/forms.py:1807
msgid "The SSL certificates are not used without a SSL connection."
msgstr "SSL сертификатите не се използват без връзка чрез SSL."

#: weblate/addons/generate.py:47
msgid "Statistics generator"
msgstr "Събирач на статистики"

#: weblate/addons/generate.py:49
msgid "Generates a file containing detailed info about the translation status."
msgstr ""
"Създава файл, съдържащ подробна информация относно състоянието на превода."

#: weblate/addons/generate.py:185
msgid "Pseudolocale generation"
msgstr "Създаване на псевдо-език"

#: weblate/addons/generate.py:187
msgid ""
"Generates a translation by adding prefix and suffix to source strings "
"automatically."
msgstr ""
"Създава нов превод, като автоматично добавя представка и наставка към всеки "
"изходен низ."

#: weblate/addons/generate.py:274
msgid "Prefill translation with source"
msgstr "Предварително попълване на превода с изходния низ"

#: weblate/addons/generate.py:275
msgid "Fills in translation strings with source string."
msgstr "Попълва преводите като се използват изходните низове."

#: weblate/addons/generate.py:313
msgid "Fill read-only strings with source"
msgstr "Попълване на низовете само за четене с изходния низ"

#: weblate/addons/generate.py:315
msgid "Fills in translation of read-only strings with source string."
msgstr ""
"Попълва преводите на низовете само за четене използвайки изходните низове."

#: weblate/addons/gettext.py:94
msgid "Generate MO files"
msgstr "Създаване на файлове MO"

#: weblate/addons/gettext.py:96
msgid "Automatically generates a MO file for every changed PO file."
msgstr "Автоматично създава файл MO от всеки променен файл PO."

#: weblate/addons/gettext.py:136
msgid "Update LINGUAS file"
msgstr "Обновяване на файла LINGUAS"

#: weblate/addons/gettext.py:138
msgid "Updates the LINGUAS file when a translation is added or removed."
msgstr "Обновява файла LINGUAS при добавяне или премахване на превод."

#: weblate/addons/gettext.py:278
msgid "Update ALL_LINGUAS variable in the \"configure\" file"
msgstr "Обновяване на променливата ALL_LINGUAS във файла „configure“"

#: weblate/addons/gettext.py:280
msgid ""
"Updates the ALL_LINGUAS variable in \"configure\", \"configure.in\" or "
"\"configure.ac\" files, when a translation is added or removed."
msgstr ""
"Обновява променливата ALL_LINGUAS във файловете „configure“, „configure.in“ "
"и „configure.ac“ при добавяне или премахване на превод."

#: weblate/addons/gettext.py:374
msgid "Update PO files to match POT (msgmerge)"
msgstr ""
"Обновяване на файловете PO, така че да отговарят на файла POT (чрез msgmerge)"

#: weblate/addons/gettext.py:376
msgid ""
"Updates all PO files (as configured by \"File mask\") to match the POT file "
"(as configured by \"Template for new translations\") using msgmerge."
msgstr ""
"Обновява всички файлове PO (според зададената „Файлова маска“), така че да "
"съответстват на файла POT (според настройката „Шаблон за новите преводи“), "
"използвайки msgmerge."

#: weblate/addons/gettext.py:999
msgid "Update POT file (xgettext)"
msgstr "Обновяване на файла POT (чрез xgettext)"

#: weblate/addons/gettext.py:1001
msgid "Updates the gettext template using xgettext on selected source files."
msgstr ""
"Обновява шаблона на gettext чрез изпълнение на xgettext върху избраните "
"изходни файлове."

#: weblate/addons/gettext.py:1412
msgid "Update POT file (Meson)"
msgstr "Обновяване на файла POT (чрез Meson)"

#: weblate/addons/gettext.py:1414
msgid "Updates the gettext template using Meson gettext conventions."
msgstr ""
"Обновява шаблона на gettext ползвайки начина на работа на gettext в Meson."

#: weblate/addons/gettext.py:1562
msgid "Update gettext template (Django)"
msgstr "Обновяване на шаблона на gettext (чрез Django)"

#: weblate/addons/gettext.py:1564
msgid ""
"Updates the gettext template using Django's built-in makemessages command."
msgstr ""
"Обновява шаблона на gettext чрез вградената в Django команда „makemessages“."

#: weblate/addons/gettext.py:1756
msgid "Update POT file (Sphinx)"
msgstr "Обновяване на файла POT (чрез Sphinx)"

#: weblate/addons/gettext.py:1758
msgid ""
"Updates the gettext template using Sphinx's gettext builder without loading "
"project configuration."
msgstr ""
"Обновява шаблона на gettext чрез системата за работа с gettext на Sphinx, "
"без да зарежда конфигурацията на проекта."

#: weblate/addons/gettext.py:2008
msgid "Contributors in comment"
msgstr "Участници в коментар"

#: weblate/addons/gettext.py:2010
msgid ""
"Updates the comment part of the PO file header to include contributor names "
"and years of contributions."
msgstr ""
"Обновява частта с коментара в заглавната част на файла PO, така че да "
"включва имената на участниците и годините, в които са участвали."

#: weblate/addons/git.py:41
msgid "Squash Git commits"
msgstr "Смачкване на подаванията на Git"

#: weblate/addons/git.py:42
msgid "Squash Git commits prior to pushing changes."
msgstr "Смачкване на подаванията на Git преди изпращането на промените."

