msgstr ", "

#: weblate/templates/js/git-status.html:136
#, python-format
msgid "%(count)s component is unlocked"
msgid_plural "%(count)s components are unlocked"
msgstr[0] "%(count)s компонент е отключен"
msgstr[1] "%(count)s компонента са отключени"

#: weblate/templates/js/git-status.html:139
#: weblate/templates/js/git-status.html:144
msgid "Weblate translations are unlocked"
msgstr "Преводите в Weblate са отключени"

#: weblate/templates/js/git-status.html:142
msgid "Weblate translations are locked"
msgstr "Преводите в Weblate са заключени"

#: weblate/templates/js/git-status.html:147
msgid "Locking prevents translators from doing changes."
msgstr "Заключването не позволява на преводачите да правят промени."

#: weblate/templates/js/git-status.html:158
msgid "Danger zone"
msgstr "Опасна зона"

#: weblate/templates/js/git-status.html:165
msgid "Reset and discard"
msgstr "Нулиране и отхвърляне"

#: weblate/templates/js/git-status.html:168
msgid ""
"Resets Weblate’s repository to match upstream and discards any pending "
"changes in Weblate."
msgstr ""
"Нулира хранилището на Weblate, така че да съвпада с отдалечения сървър, и "
"отхвърля всички чакащи промени в Weblate."

#: weblate/templates/js/git-status.html:169
msgid "Use when you want the upstream to be the authority for translations."
msgstr ""
"Използвайте това, когато искате отдалеченият сървър да бъде приет като "
"източник на правилни преводи."

#: weblate/templates/js/git-status.html:170
msgid ""
"It will discard changes in Weblate repo and bring it in sync with the "
"upstream repository."
msgstr ""
"По този начин ще анулирате всички промени в хранилището на Weblate и ще го "
"синхронизирате с отдалечения сървър."

#: weblate/templates/js/git-status.html:177
msgid "Reset and reapply"
msgstr "Нулиране и повторно прилагане"

#: weblate/templates/js/git-status.html:180
msgid ""
"Resets Weblate’s repository to match upstream and reapplies pending "
"translations onto the reset repository state."
msgstr ""
"Нулира хранилището на Weblate, така че да съвпада с отдалечения сървър, и "
"прилага отново чакащите преводи върху нулираното състояние на хранилището."

#: weblate/templates/js/git-status.html:181
msgid "Use when you want Weblate to be the authority for translations."
msgstr ""
"Използвайте това, когато искате Weblate да бъде приет като източник на "
"правилни преводи."

#: weblate/templates/js/git-status.html:182
msgid ""
"Missing language files must already exist upstream or Weblate must be able "
"to create them for the component."
msgstr ""
"Липсващите езикови файлове трябва вече да са налични в отдалеченото "
"хранилище, или Weblate трябва да може да ги създаде за компонента."

#: weblate/templates/js/git-status.html:188
msgid "Cleanup"
msgstr "Почистване"

#: weblate/templates/js/git-status.html:191
msgid ""
"Cleanup removes all files which are not tracked by the version control from "
"the repository."
msgstr ""
"Почистването премахва всички файлове в хранилището, които не се следят от "
"системата за контрол на версиите."

#: weblate/templates/js/git-status.html:192
msgid "It also removes stale branches which are not used by Weblate."
msgstr ""
"То също премахва и остарелите клони, които вече не се ползват от Weblate."

#: weblate/templates/js/git-status.html:193
msgid "Use when there is some garbage left in the Weblate repository."
msgstr ""
"Използвайте това, когато в хранилището на Weblate има останали ненужни "
"файлове."

#: weblate/templates/js/git-status.html:199
msgid "Synchronize"
msgstr "Синхронизиране"

#: weblate/templates/js/git-status.html:202
msgid "Forces writing all strings to the translation files."
msgstr "Записва принудително всички низове във файловете за превод."

#: weblate/templates/js/git-status.html:203
msgid ""
"Use this when repository files became out of sync with Weblate for some "
"reason."
msgstr ""
"Използвайте това, когато файловете в хранилището по някаква причина не "
"съвпадат с това, което виждате в Weblate."

#: weblate/templates/js/git-status.html:209
msgid "Rescan"
msgstr "Повторно сканиране"

#: weblate/templates/js/git-status.html:212
msgid "Loads translations from the files into Weblate."
msgstr "Зарежда преводите от файловете в Weblate."

#: weblate/templates/js/git-status.html:213
msgid ""
"Use when Weblate missed some of the strings after updating the repository."
msgstr ""
"Използвайте това, когато Weblate е пропуснал някои от низовете при "
"обновяването на хранилището."

#: weblate/templates/js/git-status.html:214
msgid ""
"This might discard edits that cannot be committed because of the configured "
"commit policy."
msgstr ""
"Това може да отхвърли редакциите, които не могат да бъдат подадени, поради "
"настроената политика за подаване."

#: weblate/templates/js/git-status.html:219
msgid "Use these operations with caution, they can lead to data loss."
msgstr ""
"Използвайте тези операции внимателно, тъй като те могат да доведат до загуба "
"на данни."

#: weblate/templates/js/git-status.html:229
msgid "File management"
msgstr "Управление на файловете"

#: weblate/templates/js/git-status.html:237
msgid "Remove duplicates"
msgstr "Премахване на дубликатите"

#: weblate/templates/js/git-status.html:238
msgid "Remove duplicated strings from the translation file"
msgstr "Премахване на дублираните низове от файла за превод."

#: weblate/templates/js/git-status.html:240
msgid ""
"Removes repeated strings with the same identifier from the translation file."
msgstr ""
"Премахване на повтарящите се низове с еднакъв идентификатор от файла за "
"превод."

#: weblate/templates/js/git-status.html:241
msgid ""
"Use when the translation file contains duplicate strings that are not "
"present in Weblate."
msgstr ""
"Използвайте това, когато файла за превод съдържа дублирани низове, които не "
"са налични в Weblate."

#: weblate/templates/js/git-status.html:249
msgid "Cleanup unused"
msgstr "Почистване на неизползваните"

#: weblate/templates/js/git-status.html:250
msgid "Remove unused strings from the translation file"
msgstr "Премахване на неизползваните низове от файла за превод"

#: weblate/templates/js/git-status.html:252
msgid "Removes strings that are no longer present in the base file."
msgstr "Премахва низовете, които вече не присъстват в основния файл."

#: weblate/templates/js/git-status.html:253
msgid "The cleanup translation files add-on can perform this automatically."
msgstr ""
"Добавката за почистване на файловете за превод може да прави това "
"автоматично."

#: weblate/templates/js/git-status.html:261
#, fuzzy
#| msgid "Remove blank strings"
msgid "Remove obsolete"
msgstr "Премахване на празни низове"

#: weblate/templates/js/git-status.html:262
#, fuzzy
#| msgid "Remove unused strings from the translation file"
msgid "Remove obsolete strings from the translation file"
msgstr "Премахване на неизползваните низове от файла за превод"

#: weblate/templates/js/git-status.html:264
#, fuzzy
#| msgid "Remove blank strings"
msgid "Removes obsolete strings from PO files."
msgstr "Премахване на празни низове"

#: weblate/templates/js/git-status.html:265
msgid ""
"Use when obsolete entries should be pruned without enabling automatic "
"removal on save."
msgstr ""

#: weblate/templates/js/git-status.html:271
msgid "Use these operations with caution, they rewrite the translation file."
