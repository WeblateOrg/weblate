msgstr "Горната категория трябва да бъде в същия проект!"

#: weblate/trans/models/category.py:429
msgid "Parent category has to be different!"
msgstr "Горната категория трябва да бъде различна!"

#: weblate/trans/models/category.py:447
msgid "Repository path for this category already exists and is not empty."
msgstr "Пътят в хранилището за тази категория вече съществува и не е празен."

#: weblate/trans/models/change.py:75
msgid "Component created from scratch"
msgstr "Компонентът е създаден от нулата"

#: weblate/trans/models/change.py:76
msgid "Component created as a branch"
msgstr "Компонентът е създаден като клон"

#: weblate/trans/models/change.py:77
msgid "Component created via API"
msgstr "Компонентът е създаден чрез ППИ"

#: weblate/trans/models/change.py:78
msgid "Component created from version control"
msgstr "Компонентът е създаден от системата за контрол на версиите"

#: weblate/trans/models/change.py:79
msgid "Component created via ZIP upload"
msgstr "Компонентът е създаден чрез качване на ZIP"

#: weblate/trans/models/change.py:80
