#: weblate/static/js/vcs-push-help.js:38 weblate/static/js/vcs-push-help.js:48
msgid ""
"A pull or merge request will be created from a branch in the repository."
msgstr ""
"Z vetvy v repozitári bude vytvorená požiadavka na stiahnutie alebo zlúčenie."

#: weblate/static/js/vcs-push-help.js:41
msgid ""
"A push URL is set but no push branch is given. Set a push branch that "
"differs from the translated branch."
msgstr ""
"Je nastavená URL adresa pre odosielanie, ale nie je zadaná vetva pre "
"odosielanie. Nastavte vetvu pre odosielanie, ktorá sa líši od prekladanej "
"vetvy."

#: weblate/static/js/vcs-push-help.js:51
msgid ""
"The push branch must differ from the translated branch when creating a pull "
"or merge request."
msgstr ""
"Vetva pre odosielanie sa musí líšiť od prekladanej vetvy pri vytváraní "
"požiadavky na stiahnutie alebo zlúčenie."

#: weblate/static/js/vcs-push-help.js:58
msgid "A pull or merge request will be created from a fork of the repository."
msgstr ""
"Z forku repozitára bude vytvorená požiadavka na stiahnutie alebo zlúčenie."

#: weblate/static/js/vcs-push-help.js:65
#, javascript-format
msgid ""
"A pull or merge request will be created from the “%s” branch in the "
"repository."
msgstr ""
"Z vetvy „%s“ v repozitári bude vytvorená požiadavka na stiahnutie alebo "
"zlúčenie."

#: weblate/static/js/vcs-push-help.js:77
#, javascript-format
msgid ""
"Changes will be sent as a Gerrit review request targeting the “%s” branch."
msgstr ""
"Zmeny budú odoslané ako požiadavka na prehliadku v Gerrite cielená na vetvu "
"„%s“."

#: weblate/static/js/vcs-push-help.js:84
msgid "Changes will be sent as a Gerrit review request."
msgstr "Zmeny budú odoslané ako požiadavka na prehliadku v Gerrite."

#: weblate/static/js/vcs-push-help.js:92
msgid ""
"Changes will not be pushed automatically. You can still push them manually "
"from the repository maintenance."
msgstr ""
"Zmeny nebudú odoslané automaticky. Stále ich môžete odoslať manuálne z "
"údržby repozitára."

#: weblate/static/js/vcs-push-help.js:100
#: weblate/static/js/vcs-push-help.js:110
#, javascript-format
msgid ""
"Changes will be pushed directly to the “%s” branch in the push repository."
msgstr "Zmeny budú odoslané priamo do vetvy „%s“ v úložisku pre odosielanie."

#: weblate/static/js/vcs-push-help.js:118
msgid ""
"Changes will be pushed directly to the default branch of the push repository."
msgstr ""

