msgstr "Aktualizuje hlavičky gettext a nahrádza zástupné komentáre POT."

#: weblate/addons/forms.py:158
msgid "Update PO files using msgmerge"
msgstr "Aktualizovať PO súbory pomocou msgmerge"

#: weblate/addons/forms.py:163
msgid ""
