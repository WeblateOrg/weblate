msgstr ""
"Ďalšie kontrolné overenie xgettext na povolenie pre extrahované správy."

#: weblate/addons/forms.py:226
msgid "Additional keyword"
msgstr "Ďalšie kľúčové slovo"

#: weblate/addons/forms.py:229
msgid "Optional extra keyword passed to xgettext using --keyword."
