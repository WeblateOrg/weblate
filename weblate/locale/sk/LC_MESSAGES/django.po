msgstr "Sem bude odoslaný e-mail s odkazom na potvrdenie."

#: weblate/accounts/forms.py:719
msgid "New password"
msgstr "Nové heslo"

#: weblate/accounts/forms.py:724
msgid "New password confirmation"
msgstr "Potvrdenie nového hesla"

