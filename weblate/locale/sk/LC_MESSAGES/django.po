msgid "Discard previously configured authentication apps"
msgstr "Zahodiť predtým nakonfigurované aplikačné autentifikácie"

#: weblate/accounts/forms.py:1178
msgid ""
"All previously configured authentication apps will be discarded upon "
"verification of the new app."
msgstr ""
"Všetky predtým nakonfigurované aplikačné autentifikácie budú zahodené po "
"overení novej aplikácie."

#: weblate/accounts/forms.py:1181
msgid ""
"Other two-factor methods (such as WebAuthn and security keys) won't be "
"affected."
msgstr ""
"Iné metódy dvojfázového overenia (ako WebAuthn a bezpečnostné kľúče) nebudú "
"ovplyvnené."

