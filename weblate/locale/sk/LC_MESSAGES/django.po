msgstr ""
"Štýl POSIX používajúci podčiarkovník ako oddeľovač, vrátane kódu krajiny, "
"malé písmená"

#: weblate/trans/models/component.py:204
msgid "BCP style using hyphen as a separator, including country code"
msgstr "Štýl BCP používajúci pomlčku ako oddeľovač, vrátane kódu krajiny"

#: weblate/trans/models/component.py:208
msgid "BCP style using hyphen as a separator, legacy language codes"
msgstr "Štýl BCP používajúci pomlčku ako oddeľovač, staré jazykové kódy"

#: weblate/trans/models/component.py:210
msgid "BCP style using hyphen as a separator, lower cased"
msgstr "Štýl BCP používajúci pomlčku ako oddeľovač, malé písmená"

#: weblate/trans/models/component.py:211
msgid "Android style"
msgstr "Štýl Android"

#: weblate/trans/models/component.py:212
msgid "Apple App Store metadata style"
msgstr "Štýl metadát Apple App Store"

#: weblate/trans/models/component.py:213
msgid "Google Play metadata style"
msgstr "Štýl metadát Google Play"

#: weblate/trans/models/component.py:214
msgid "Linux style"
msgstr "Štýl Linux"

#: weblate/trans/models/component.py:215
msgid "Linux style, lower cased"
msgstr "Štýl Linux, malé písmená"

#: weblate/trans/models/component.py:219
msgid "Merge"
msgstr "Zlúčiť"

#: weblate/trans/models/component.py:220
msgid "Rebase"
msgstr "Prepísať"

#: weblate/trans/models/component.py:221
msgid "Merge without fast-forward"
msgstr "Zlúčiť bez fast-forward"

#: weblate/trans/models/component.py:462
msgid ""
"Option is not available for linked repositories. Setting from linked "
"component will be used."
msgstr ""
"Možnosť nie je dostupná pre prepojené repozitáre. Použije sa nastavenie z "
"prepojeného komponentu."

#: weblate/trans/models/component.py:493
msgid ""
"Version control system to use to access your repository containing "
"translations. You can also choose additional integration with third party "
"providers to submit pull/merge requests."
msgstr ""
"Systém riadenia verzií na použitie na prístup k vášmu repozitáru "
"obsahujúcemu preklady. Môžete tiež vybrať dodatočnú integráciu s "
"poskytovateľmi tretích strán na odoslanie pull/merge požiadaviek."

#: weblate/trans/models/component.py:505
msgid ""
"URL of a repository, use weblate://project/component to share it with other "
"component."
msgstr ""
"URL repozitára, použite weblate://project/component na zdieľanie s iným "
"komponentom."

#: weblate/trans/models/component.py:518
msgid "Repository push URL"
msgstr "URL odoslania repozitára"

#: weblate/trans/models/component.py:521
msgid ""
"URL of a push repository, pushing is turned off if empty. When using pull/"
"merge requests, keep empty to fork the repository."
msgstr ""
"URL odoslania repozitára, odoslanie je vypnuté, ak je prázdne. Pri používaní "
"pull/merge požiadaviek ponechajte prázdne na fork repozitára."

#: weblate/trans/models/component.py:527
msgid "Repository browser"
msgstr "Prehliadač repozitára"

#: weblate/trans/models/component.py:530
msgid ""
"Link to repository browser, use {{branch}} for branch, {{filename}} and "
"{{line}} as filename and line placeholders. You might want to strip leading "
"directory by using {{filename|parentdir}}."
msgstr ""
"Odkaz na prehliadač repozitára, použite {{branch}} pre vetvu, {{filename}} a "
"{{line}} ako zástupné názvy súboru a riadku. Možno budete chcieť odstrániť "
"vedúci adresár použitím {{filename|parentdir}}."

#: weblate/trans/models/component.py:538
msgid "Exported repository URL"
msgstr "URL exportovaného repozitára"

#: weblate/trans/models/component.py:541
msgid "URL of repository where users can fetch changes from Weblate"
msgstr "URL repozitára, kde si môžu používatelia stiahnuť zmeny z Weblate"

#: weblate/trans/models/component.py:546
msgid "Source string bug reporting address"
msgstr "Adresa na hlásenie chýb zdrojového reťazca"

#: weblate/trans/models/component.py:548
msgid ""
"E-mail address for reports on errors in source strings. Leave empty for no e-"
"mails."
msgstr ""
"E-mailová adresa na správy o chybách v zdrojových reťazcoch. Ponechajte "
"prázdne pre žiadne e-maily."

#: weblate/trans/models/component.py:556
msgid "Repository branch to translate"
msgstr "Vetva repozitára na preklad"

#: weblate/trans/models/component.py:561
msgid "Push branch"
msgstr "Vetva odoslania"

#: weblate/trans/models/component.py:564
msgid ""
"Branch for pushing changes. Leave empty to use repository branch when "
"pushing directly to the repository. When using pull/merge requests, specify "
"a branch name different from the repository branch."
msgstr ""
"Vetva na odosielanie zmien. Ponechajte prázdne na použitie vetvy repozitára "
"pri oodosielaní priamo do repozitára. Pri používaní pull/merge požiadaviek "
"špecifikujte názov vetvy odlišný od vetvy repozitára."

#: weblate/trans/models/component.py:576
msgid ""
"Path of files to translate relative to repository root, use * instead of "
"language code, for example: po/*.po or locale/*/LC_MESSAGES/django.po."
msgstr ""
"Cesta súborov na preklad relatívne k koreňu repozitára, použite * namiesto "
"kódu jazyka, napríklad: po/*.po alebo locale/*/LC_MESSAGES/django.po."

#: weblate/trans/models/component.py:582
msgid "Screenshot file mask"
msgstr "Maska súboru snímky obrazovky"

#: weblate/trans/models/component.py:587
msgid ""
"Path of screenshots relative to repository root, for example: docs/"
"screenshots/*.png."
msgstr ""
"Cesta snímok obrazovky relatívne k koreňu repozitára, napríklad: docs/"
"screenshots/*.png."

#: weblate/trans/models/component.py:596
msgid ""
"Filename of translation base file, containing all strings and their source "
"for monolingual translations."
msgstr ""
"Názov súboru základného prekladového súboru, obsahujúci všetky reťazce a ich "
"zdroj pre jednojazyčné preklady."

#: weblate/trans/models/component.py:603
msgid "Edit base file"
msgstr "Editovať základný súbor"

#: weblate/trans/models/component.py:606
msgid ""
"Whether users will be able to edit the base file for monolingual "
"translations."
msgstr ""
"Či budú používatelia môcť upravovať základný súbor pre jednojazyčné preklady."

#: weblate/trans/models/component.py:615
msgid ""
"Filename of intermediate translation file. In most cases this is a "
"translation file provided by developers and is used when creating actual "
"source strings."
msgstr ""
"Názov súboru medziprekladového súboru. V väčšine prípadov je to súbor "
"poskytnutý vývojármi a používa sa pri vytváraní skutočných zdrojových "
"reťazcov."

#: weblate/trans/models/component.py:627
msgid ""
"Filename of file used for creating new translations. For gettext choose .pot "
"file."
msgstr ""
"Názov súboru použitého na vytváranie nových prekladov. Pre gettext "
"vyberte .pot súbor."

#: weblate/trans/models/component.py:640
msgid "File format parameters"
msgstr "Parametre formátu súboru"

#: weblate/trans/models/component.py:650
msgid "Locked component will not get any translation updates."
msgstr "Zamknutý komponent nedostane žiadne aktualizácie prekladu."

#: weblate/trans/models/component.py:654
msgid "Do not show glossary matches"
msgstr "Nezobrazovať zhody slovníka"

#: weblate/trans/models/component.py:656
msgid "Hides the glossary panel in the translation editor."
msgstr "Skryje panel slovníka v editore prekladu."

#: weblate/trans/models/component.py:659
msgid "Allow translation propagation"
msgstr "Povoliť propagáciu prekladu"

#: weblate/trans/models/component.py:662
msgid ""
"Whether translation updates in other components will cause automatic "
"translation in this one"
msgstr ""
"Či aktualizácie prekladu v iných komponentoch spôsobia automatický preklad v "
"tomto"

#: weblate/trans/models/component.py:667
msgid "Contribute to project translation memory"
msgstr "Prispieť do prekladovej pamäte projektu"

#: weblate/trans/models/component.py:670
msgid ""
"Allow this component's translations to be added to the project-level "
"translation memory."
msgstr ""
"Povoliť preklady tohto komponentu pridať do prekladovej pamäte na úrovni "
"projektu."

#: weblate/trans/models/component.py:676 weblate/trans/models/workflow.py:30
msgid "Turn on suggestions"
msgstr "Zapnúť návrhy"

#: weblate/trans/models/component.py:678 weblate/trans/models/workflow.py:32
msgid "Whether to allow translation suggestions at all."
msgstr "Či vôbec povoliť návrhy prekladu."

#: weblate/trans/models/component.py:682 weblate/trans/models/workflow.py:36
msgid "Suggestion voting"
msgstr "Hlasovanie o návrhoch"

#: weblate/trans/models/component.py:685 weblate/trans/models/workflow.py:39
msgid "Users can only vote for suggestions and can’t make direct translations."
msgstr ""
"Používatelia môžu iba hlasovať o návrhoch a nemôžu robiť priame preklady."

#: weblate/trans/models/component.py:690 weblate/trans/models/workflow.py:44
msgid "Automatically accept suggestions"
msgstr "Automaticky prijať návrhy"

#: weblate/trans/models/component.py:693 weblate/trans/models/workflow.py:47
msgid ""
"Automatically accept suggestions with this number of votes, use 0 to turn it "
"off."
msgstr ""
"Automaticky prijať návrhy s týmto počtom hlasov, použite 0 na vypnutie."

#: weblate/trans/models/component.py:699 weblate/trans/models/project.py:306
#: weblate/trans/models/unit.py:455
msgid "Translation flags"
msgstr "Príznaky prekladu"

#: weblate/trans/models/component.py:702 weblate/trans/models/project.py:309
#: weblate/trans/models/unit.py:458
msgid "Additional comma-separated flags to influence Weblate behavior."
msgstr "Dodatočné čiarkou oddelené príznaky ovplyvňujúce správanie Weblate."

#: weblate/trans/models/component.py:708
msgid "Enforced checks"
msgstr "Vynútené kontroly"

#: weblate/trans/models/component.py:709
msgid "List of checks which can not be dismissed."
msgstr "Zoznam kontrol, ktoré nie je možné zamietnuť."

#: weblate/trans/models/component.py:727
msgid ""
"Contributor license agreement which needs to be approved before a user can "
"translate this component."
msgstr ""
"Licenčná zmluva s prispievateľom, ktorá musí byť schválená predtým, než môže "
"používateľ prekladať tento komponent."

#: weblate/trans/models/component.py:734
msgid "Adding new translation"
msgstr "Pridávanie nového prekladu"

#: weblate/trans/models/component.py:738
msgid "How to handle requests for creating new translations."
msgstr "Ako zaobchádzať s požiadavkami na vytváranie nových prekladov."

#: weblate/trans/models/component.py:741
msgid "Language code style"
msgstr "Štýl jazykového kódu"

#: weblate/trans/models/component.py:747
msgid ""
"Customize language code used to generate the filename for translations "
"created by Weblate."
msgstr ""
"Prispôsobte jazykový kód používaný na generovanie názvu súboru pre preklady "
"vytvorené systémom Weblate."

#: weblate/trans/models/component.py:752
msgid "Manage strings"
msgstr "Spravovať reťazce"

#: weblate/trans/models/component.py:755
msgid ""
"Enables adding and removing strings straight from Weblate. If your strings "
"are extracted from the source code or managed externally you probably want "
"to keep it disabled."
msgstr ""
"Povoľuje pridávanie a odstraňovanie reťazcov priamo z Weblate. Ak sú vaše "
"reťazce extrahované zo zdrojového kódu alebo spravované externé, "
"pravdepodobne budete chcieť ponechať to vypnuté."

#: weblate/trans/models/component.py:763
msgid "Merge style"
msgstr "Štýl zlúčenia"

#: weblate/trans/models/component.py:768
msgid ""
"Define whether Weblate should merge the upstream repository or rebase "
"changes onto it."
msgstr ""
"Definovať, či by Weblate mal zlúčiť upstream repozitár alebo prepísať zmeny "
"naň."

#: weblate/trans/models/component.py:773
msgid "Commit message when translating"
msgstr "Správa zápisu pri preklade"

#: weblate/trans/models/component.py:775 weblate/trans/models/component.py:784
#: weblate/trans/models/component.py:793 weblate/trans/models/component.py:803
#: weblate/trans/models/component.py:812 weblate/trans/models/component.py:821
msgid ""
"You can use template language for various info, please consult the "
"documentation for more details."
msgstr ""
"Môžete použiť jazyk šablóny pre rôzne informácie, prosím, konzultujte "
"dokumentáciu pre viac podrobností."

#: weblate/trans/models/component.py:782
msgid "Commit message when adding translation"
msgstr "Správa zápisu pri pridávaní prekladu"

#: weblate/trans/models/component.py:791
msgid "Commit message when removing translation"
msgstr "Správa zápisu pri odstraňovaní prekladu"

#. Translators: The commit message, for when merging the translation
#: weblate/trans/models/component.py:801
msgid "Commit message when merging translation"
msgstr "Správa zápisu pri zlúčení prekladu"

#: weblate/trans/models/component.py:810
msgid "Commit message when add-on makes a change"
msgstr "Správa zápisu, keď doplnok robí zmenu"

#: weblate/trans/models/component.py:819
msgid "Merge request message"
msgstr "Správa zlúčenia požiadavky"

#: weblate/trans/models/component.py:828
msgid "Push on commit"
msgstr "Odoslať pri zápise"

#: weblate/trans/models/component.py:831
msgid "Whether the repository should be pushed upstream on every commit."
msgstr "Či by mal byť repozitár odoslaný do upstreamu pri každom zápise."

#: weblate/trans/models/component.py:835
msgid "Age of changes to commit"
msgstr "Vek zmien na zápis"

#: weblate/trans/models/component.py:839
msgid ""
"Time in hours after which any pending changes will be committed to the VCS."
msgstr "Čas v hodinách, po ktorom budú všetky čakajúce zmeny zapísané do VCS."

#: weblate/trans/models/component.py:844
msgid "Lock on error"
msgstr "Zamknúť pri chybe"

#: weblate/trans/models/component.py:847
msgid "Whether the component should be locked on repository errors."
msgstr "Či by mal byť komponent zamknutý pri chybách repozitára."

#: weblate/trans/models/component.py:854
msgid "Language used for source strings in all components"
msgstr "Jazyk použitý pre zdrojové reťazce vo všetkých komponentoch"

#: weblate/trans/models/component.py:864
msgid ""
"Regular expression used to filter translation files when scanning for file "
"mask."
msgstr ""
"Regulárny výraz použitý na filtrovanie prekladových súborov pri skenovaní "
"masky súboru."

#: weblate/trans/models/component.py:869
msgid "Variants regular expression"
msgstr "Regulárny výraz variantov"

#: weblate/trans/models/component.py:875
msgid "Regular expression used to determine variants of a string."
msgstr "Regulárny výraz použitý na určenie variantov reťazca."

#: weblate/trans/models/component.py:884
msgid "Components with higher priority are offered first to translators."
msgstr "Komponenty s vyššou prioritou sú ponúkané prekladateľom ako prvé."

#: weblate/trans/models/component.py:888
msgid "Restricted component"
msgstr "Obmedzený komponent"

#: weblate/trans/models/component.py:892
msgid ""
"Restrict access to the component to only those explicitly given permission."
msgstr ""
"Obmedziť prístup ku komponentu iba na tých, ktorí majú explicitne udelené "
"oprávnenie."

#: weblate/trans/models/component.py:904
msgid "Choose additional projects where this component will be listed."
msgstr "Vyberte dodatočné projekty, kde bude tento komponent uvedený."

#: weblate/trans/models/component.py:910
msgid "Use as a glossary"
msgstr "Použiť ako slovník"

#: weblate/trans/models/component.py:914
msgid ""
"Glossaries are different from regular translations but help keep track of "
"and share consistent terminology."
msgstr ""
"Slovníky sa líšia od bežných prekladov, ale pomáhajú sledovať a zdieľať "
"konzistentnú terminológiu."

#: weblate/trans/models/component.py:918
msgid "Glossary color"
msgstr "Farba slovníka"

#: weblate/trans/models/component.py:929
msgid "Key filter"
msgstr "Filter kľúčov"

#: weblate/trans/models/component.py:933
msgid ""
"Regular expression used to filter keys. This is only available for "
"monolingual formats."
msgstr ""
"Regulárny výraz použitý na filtrovanie kľúčov. Toto je dostupné iba pre "
"jednojazyčné formáty."

#: weblate/trans/models/component.py:940 weblate/trans/models/project.py:295
msgid "Secondary language"
msgstr "Sekundárny jazyk"

#: weblate/trans/models/component.py:944 weblate/trans/models/project.py:297
msgid ""
"Additional language to show together with the source language while "
"translating."
msgstr ""
"Dodatočný jazyk na zobrazenie spolu so zdrojovým jazykom počas prekladania."

#: weblate/trans/models/component.py:946
msgid "This setting is inherited from the project if left empty."
msgstr "Toto nastavenie je zdedené z projektu, ak je ponechané prázdne."

#: weblate/trans/models/component.py:1949
msgid ""
"Could not verify the SSH host key. Please add it on the SSH page in the "
"admin interface."
msgstr ""
"Nepodarilo sa overiť SSH kľúč hostiteľa. Prosím, pridajte ho na stránke SSH "
"v rozhraní administrátora."

#: weblate/trans/models/component.py:1955
msgid ""
"The SSH host key for the repository has changed. Verify the new fingerprint, "
"remove the stored host key, and add the new one on the SSH page in the admin "
"interface."
msgstr ""
"SSH kľúč hostiteľa pre repozitár sa zmenil. Overte nový odtlačok, odstráňte "
"uložený kľúč hostiteľa a pridajte nový na stránke SSH v rozhraní "
"administrátora."

#: weblate/trans/models/component.py:1992
msgid ""
"The repository requires authentication, please specify credentials in the "
"URL or use SSH access instead."
msgstr ""
"Repozitár vyžaduje overenie, prosím, špecifikujte poverenia v URL alebo "
"použite prístup SSH."

#: weblate/trans/models/component.py:1998
#, python-format
msgid "Could not fetch the repository: %s"
msgstr "Nepodarilo sa získať repozitár: %s"

#: weblate/trans/models/component.py:2076
#: weblate/trans/models/component.py:3848
#: weblate/trans/models/component.py:3925
msgid "File does not exist."
msgstr "Súbor neexistuje."

#: weblate/trans/models/component.py:2267
#, python-format
msgid "Could not push %(component)s: %(error_text)s"
msgstr "Nepodarilo sa odoslať %(component)s: %(error_text)s"

#: weblate/trans/models/component.py:2301
#, python-format
msgid "Push is turned off for %s."
msgstr "Odosielania je vypnuté pre %s."

