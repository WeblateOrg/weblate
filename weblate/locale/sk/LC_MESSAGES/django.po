msgstr "Často by mal doplnok aktualizovať POT súbor, keď sa komponent obnoví."

#: weblate/addons/forms.py:150
msgid "Normalize POT header"
msgstr "Normalizovať hlavičku POT"

#: weblate/addons/forms.py:154
