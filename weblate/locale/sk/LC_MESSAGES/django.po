msgstr "Neextrahovať komentáre"

#: weblate/addons/forms.py:189
msgid "Extract all comments"
msgstr "Extrahovať všetky komentáre"

#: weblate/addons/forms.py:190
msgid "Extract comments with tag"
msgstr "Extrahovať komentáre s tagom"

#: weblate/addons/forms.py:199
msgid "Code comments"
msgstr "Komentáre kódu"

#: weblate/addons/forms.py:204
msgid ""
"Choose whether xgettext should extract no comments, all comments, or only "
"comments marked with a specific tag."
msgstr ""
"Vyberte, či by xgettext nemal extrahovať žiadne komentáre, všetky komentáre, "
"alebo iba komentáre označené konkrétnym tagom."

#: weblate/addons/forms.py:209
msgid "Comment tag"
msgstr "Tag komentára"

#: weblate/addons/forms.py:212
msgid ""
"Tag passed to xgettext for comment extraction when using tagged comment mode."
msgstr ""
"Tag odovzdaný xgettext pre extrakciu komentárov pri použití režimu s tagmi."

#: weblate/addons/forms.py:217
msgid "xgettext checks"
msgstr "Kontroly xgettext"

#: weblate/addons/forms.py:222
