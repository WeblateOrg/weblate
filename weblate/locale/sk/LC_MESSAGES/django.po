msgid_plural "Backups are removed after %(keep_days)s days."
msgstr[0] "Zálohy sú odstránené po %(keep_days)s dni."
msgstr[1] "Zálohy sú odstránené po %(keep_days)s dňoch."
msgstr[2] "Zálohy sú odstránené po %(keep_days)s dňoch."

