#: weblate/templates/translation.html:85
msgid "Automatic translation"
msgstr "Automatický preklad"

#: weblate/addons/autotranslate.py:72
msgid ""
"Automatically translates strings using machine translation or other "
"components."
msgstr ""
"Automaticky prekladá reťazce pomocou strojového prekladu alebo iných "
"komponentov."

#: weblate/addons/base.py:207
msgid "enabled"
msgstr "povolené"

#: weblate/addons/base.py:760 weblate/trans/views/create.py:272
msgid ""
"The repository is outdated, you might not get expected results until you "
"update it."
msgstr ""
"Repozitár je zastaraný, nemusíte dostávať očakávané výsledky, kým ho "
"neaktualizujete."

#: weblate/addons/cdn.py:38
msgid "JavaScript localization CDN"
msgstr "CDN pre lokalizáciu JavaScriptu"

#: weblate/addons/cdn.py:40
msgid ""
"Publishes translations into content delivery network for use in JavaScript "
"or HTML localization."
msgstr ""
"Zverejňuje preklady do siete na doručovanie obsahu na použitie v lokalizácii "
"JavaScriptu alebo HTML."

#: weblate/addons/cleanup.py:44
msgid "Cleanup translation files"
msgstr "Vyčistiť súbory prekladov"

#: weblate/addons/cleanup.py:46
msgid ""
"Update all translation files to match the monolingual base file. For most "
"file formats, this means removing stale translation keys no longer present "
"in the base file."
msgstr ""
"Aktualizovať všetky súbory prekladov tak, aby zodpovedali jednojazyčnému "
"základnému súboru. Pre väčšinu formátov súborov to znamená odstránenie "
"zastaraných kľúčov prekladu, ktoré už nie sú v základnom súbore."

#: weblate/addons/cleanup.py:93
msgid "Remove blank strings"
msgstr "Odstrániť prázdne reťazce"

#: weblate/addons/cleanup.py:95
msgid "Removes strings without a translation from translation files."
msgstr "Odstraňuje reťazce bez prekladu zo súborov prekladov."

#: weblate/addons/cleanup.py:130
msgid "Reset repository to upstream"
msgstr "Obnoviť repozitár na upstream"

#: weblate/addons/cleanup.py:132
msgid "Discards all changes in the Weblate repository each night."
msgstr "Zahodí všetky zmeny v repozitári Weblate každú noc."

#: weblate/addons/consistency.py:91
msgid "Add missing languages"
msgstr "Pridať chýbajúce jazyky"

#: weblate/addons/consistency.py:93
msgid ""
"Ensures a consistent set of languages is used for all components within a "
"project."
msgstr ""
"Zaisťuje, že konzistentná sada jazykov sa používa pre všetky komponenty v "
"projekte."

#: weblate/addons/consistency.py:129
msgid ""
"This add-on affects the whole project and may create translation files "
"across many components or repositories."
msgstr ""
"Tento doplnok ovplyvňuje celý projekt a môže vytvárať súbory prekladov "
"naprieč mnohými komponentmi alebo repozitármi."

#: weblate/addons/consistency.py:134
msgid ""
"This add-on affects the whole category and may create translation files "
"across many components or repositories."
msgstr ""
"Tento doplnok ovplyvňuje celú kategóriu a môže vytvárať súbory prekladov "
"naprieč mnohými komponentmi alebo repozitármi."

#: weblate/addons/consistency.py:138
msgid ""
"This add-on affects all projects and may create translation files across "
"many components or repositories."
msgstr ""
"Tento doplnok ovplyvňuje všetky projekty a môže vytvárať súbory prekladov "
"naprieč mnohými komponentmi alebo repozitármi."

#: weblate/addons/consistency.py:244 weblate/trans/models/component.py:4721
msgid ""
"The given language maps to a different language. Check language aliases "
"settings."
msgstr ""
"Zadaný jazyk sa mapuje na iný jazyk. Skontrolujte nastavenia aliasov jazykov."

#: weblate/addons/consistency.py:248 weblate/trans/models/component.py:4727
msgid "The given language is used as a source language."
msgstr "Zadaný jazyk sa používa ako zdrojový jazyk."

#: weblate/addons/consistency.py:253 weblate/trans/models/component.py:4739
msgid "The language filter timed out."
msgstr "Filter jazykov vypršal časovo."

#: weblate/addons/consistency.py:256 weblate/trans/models/component.py:4743
msgid "The given language is filtered by the language filter."
msgstr "Zadaný jazyk je filtrovaný jazykovým filtrom."

#: weblate/addons/discovery.py:27
msgid "Component discovery"
msgstr "Objavovanie komponentov"

#: weblate/addons/discovery.py:29
msgid ""
"Automatically adds or removes project components based on file changes in "
"the version control system."
msgstr ""
"Automaticky pridáva alebo odstraňuje komponenty projektu na základe zmien "
"súborov vo verziovom systéme."

#: weblate/addons/example.py:31
msgid "Example add-on"
msgstr "Príklad doplnku"

#: weblate/addons/example.py:33
msgid "This add-on does nothing it is just an example."
msgstr "Tento doplnok nerobí nič, je to len príklad."

#: weblate/addons/example_pre.py:25
msgid "Execute script before commit"
msgstr "Spustiť skript pred zápisom"

#: weblate/addons/example_pre.py:26
msgid "This add-on executes a script."
msgstr "Tento doplnok spúšťa skript."

#: weblate/addons/fedora_messaging.py:32
msgid "Fedora Messaging"
msgstr "Fedora Messaging"

#: weblate/addons/fedora_messaging.py:34
msgid "Sends notifications to a Fedora Messaging compatible AMQP exchange."
msgstr "Odosiela notifikácie do AMQP výmeny kompatibilnej s Fedorou Messaging."

#: weblate/addons/flags.py:51
msgid "Flag new source strings as \"Needs checking\""
msgstr "Označiť nové zdrojové reťazce ako \"Vyžaduje kontrolu\""

#: weblate/addons/flags.py:53
msgid ""
"Whenever a new source string is imported from the VCS, it is flagged as "
"needing checking in Weblate. This way you can easily filter and edit source "
"strings written by the developers."
msgstr ""
"Vždy, keď je nový zdrojový reťazec importovaný z VCS, je označený ako "
"vyžadujúci kontrolu v Weblate. Týmto spôsobom môžete ľahko filtrovať a "
"upravovať zdrojové reťazce napísané vývojármi."

#: weblate/addons/flags.py:72
msgid "Flag new translations as \"Needs rewriting\""
msgstr "Označiť nové preklady ako \"Vyžaduje prepísanie\""

#: weblate/addons/flags.py:74
msgid ""
"Whenever a new translatable string is imported from the VCS, it is flagged "
"as needing rewriting in Weblate. This way you can easily filter and edit "
"translations created by the developers."
msgstr ""
"Vždy, keď je nový prekladateľný reťazec importovaný z VCS, je označený ako "
"vyžadujúci prepísanie v Weblate. Týmto spôsobom môžete ľahko filtrovať a "
"upravovať preklady vytvorené vývojármi."

#: weblate/addons/flags.py:90
msgid "Flag unchanged translations as \"Needs rewriting\""
msgstr "Označiť nezmenené preklady ako \"Vyžaduje prepísanie\""

#: weblate/addons/flags.py:92
msgid ""
"Whenever a new translatable string is imported from the VCS and it matches a "
"source string, it is flagged as needing rewriting in Weblate. Especially "
"useful for file formats that include source strings for untranslated strings."
msgstr ""
"Vždy, keď je nový prekladateľný reťazec importovaný z VCS a zhoduje sa so "
"zdrojovým reťazcom, je označený ako vyžadujúci prepísanie v Weblate. "
"Obzvlášť užitočné pre formáty súborov, ktoré obsahujú zdrojové reťazce pre "
"nepreložené reťazce."

#: weblate/addons/flags.py:113 weblate/templates/category-language.html:53
#: weblate/templates/category-language.html:136
#: weblate/templates/category.html:84 weblate/templates/category.html:231
#: weblate/templates/component.html:96 weblate/templates/component.html:285
#: weblate/templates/language-project.html:84
#: weblate/templates/language-project.html:210
#: weblate/templates/project.html:99 weblate/templates/project.html:311
#: weblate/templates/translation.html:80 weblate/templates/translation.html:213
msgid "Bulk edit"
msgstr "Hromadná úprava"

#: weblate/addons/flags.py:114
msgid "Bulk edit flags, labels, or states of strings."
msgstr "Hromadná úprava príznakov, štítkov alebo stavov reťazcov."

#: weblate/addons/flags.py:145
msgid "Flag updated translations from repository as \"Needs rewriting\""
msgstr ""
"Označiť aktualizované preklady z repozitára ako \"Vyžaduje prepísanie\""

#: weblate/addons/flags.py:148
msgid ""
"Whenever a string translation is changed from the VCS, it is flagged as "
"needing rewriting in Weblate. Especially useful if translation files are "
"often updated manually or by an external service."
msgstr ""
"Vždy, keď je preklad reťazca zmenený z VCS, je označený ako vyžadujúci "
"prepísanie v Weblate. Obzvlášť užitočné, ak sa súbory prekladov často "
"aktualizujú manuálne alebo externou službou."

#: weblate/addons/forms.py:100
msgid "Path of generated MO file"
msgstr "Cesta vygenerovaného MO súboru"

#: weblate/addons/forms.py:104
msgid "If not specified, the location of the PO file will be used."
msgstr "Ak nie je špecifikované, použije sa umiestnenie PO súboru."

#: weblate/addons/forms.py:108
msgid "Include strings needing editing"
msgstr "Zahrnúť reťazce vyžadujúce úpravu"

#: weblate/addons/forms.py:111
msgid ""
"Strings needing editing (fuzzy) are typically not ready for use as "
"translations."
msgstr ""
"Reťazce vyžadujúce úpravu (fuzzy) zvyčajne nie sú pripravené na použitie ako "
"preklady."

#: weblate/addons/forms.py:137
