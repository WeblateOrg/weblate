msgstr "Projekt: {}"

#: weblate/accounts/forms.py:997
msgid "Component: {}"
msgstr "Komponent: {}"

#: weblate/accounts/forms.py:1003
msgid ""
"You will receive a notification for every such event in non-watched projects."
msgstr ""
"Dostanete notifikáciu o každej takejto udalosti v nesledovaných projektoch."

#: weblate/accounts/forms.py:1008
msgid ""
"You will receive a notification for every such event in your watched "
"projects."
msgstr ""
"Dostanete notifikáciu o každej takejto udalosti vo vašich sledovaných "
"projektoch."

#: weblate/accounts/forms.py:1013
msgid ""
"You will receive a notification for every such event in projects where you "
"have admin permissions."
msgstr ""
"Dostanete notifikáciu o každej takejto udalosti v projektoch, kde máte "
"správcovské oprávnenia."

#: weblate/accounts/forms.py:1018
#, python-format
msgid "You will receive a notification for every such event in %(project)s."
msgstr "Dostanete notifikáciu o každej takejto udalosti v %(project)s."

#: weblate/accounts/forms.py:1021
#, python-format
msgid "You will receive a notification for every such event in %(component)s."
msgstr "Dostanete notifikáciu o každej takejto udalosti v %(component)s."

#: weblate/accounts/forms.py:1028
msgid ""
"You will only receive these notifications for your translated languages in "
"non-watched projects."
msgstr ""
"Tieto notifikácie dostanete iba pre vaše prekladané jazyky v nesledovaných "
"projektoch."

#: weblate/accounts/forms.py:1033
msgid ""
"You will only receive these notifications for your translated languages in "
"your watched projects."
msgstr ""
"Tieto notifikácie dostanete iba pre vaše prekladané jazyky vo vašich "
"sledovaných projektoch."

#: weblate/accounts/forms.py:1038
msgid ""
"You will only receive these notifications for your translated languages in "
"projects where you have admin permissions."
msgstr ""
"Tieto notifikácie dostanete iba pre vaše prekladané jazyky v projektoch, kde "
"máte správcovské oprávnenia."

#: weblate/accounts/forms.py:1043
#, python-format
msgid ""
"You will only receive these notifications for your translated languages in "
"%(project)s."
msgstr ""
"Tieto notifikácie dostanete iba pre vaše prekladané jazyky v %(project)s."

#: weblate/accounts/forms.py:1047
#, python-format
msgid ""
"You will only receive these notifications for your translated languages in "
"%(component)s."
msgstr ""
"Tieto notifikácie dostanete iba pre vaše prekladané jazyky v %(component)s."

