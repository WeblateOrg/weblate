msgstr "Vytvoriť komponent"

#: weblate/templates/trans/component_create.html:56
#: weblate/templates/trans/component_form.html:13
msgid "You do not have permission to create components in any projects."
msgstr "Nemáte oprávnenie na vytváranie komponentov v žiadnych projektoch."

#: weblate/templates/trans/component_create.html:75
msgid ""
"Create a new translation component from remote version control system "
"repository."
msgstr ""
