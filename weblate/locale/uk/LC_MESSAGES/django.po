msgstr "Увійдено за допомогою {method} ({name}) з нового пристрою."

#. Translators: Audit log entry
#: app/src/weblate/accounts/models.py:294
msgid "Somebody attempted to register with your e-mail."
msgstr "Хтось спробував зареєструватися за допомогою вашої адреси е-пошти."

#: app/src/weblate/accounts/models.py:297
msgid "Somebody attempted to register using your e-mail address."
msgstr "Хтось спробував зареєструватися за допомогою вашої адреси е-пошти."

