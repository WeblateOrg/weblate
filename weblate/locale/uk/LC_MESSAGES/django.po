#: app/src/weblate/accounts/forms.py:145
msgid "Name is also used in version control commits."
msgstr ""
"Ім'я буде також використано у записах внески системи керування версіями."

#: app/src/weblate/accounts/forms.py:209 app/src/weblate/accounts/models.py:967
msgid "Commit e-mail"
msgstr "е-пошта для внеску"

#: app/src/weblate/accounts/forms.py:210
msgid "Use account e-mail address"
msgstr "Адреса е-пошти облікового запису"

#: app/src/weblate/accounts/forms.py:212
msgid ""
"Used in version-control commits. The address stays in the repository forever "
"once changes are committed by Weblate."
msgstr ""
"Використовується в комітах контролю версій. Адреса залишається в репозиторії "
"назавжди, коли Weblate вносить зміни."

#: app/src/weblate/accounts/forms.py:219 app/src/weblate/accounts/models.py:978
msgid "Commit name"
msgstr "Ім'я коміту"

#: app/src/weblate/accounts/forms.py:222
msgid ""
"Used in version control commits. The name stays in the repository forever, "
"once changes are committed by Weblate."
msgstr ""
"Використовується в комітах контролю версій. Ім'я залишається в репозиторії "
"назавжди, після того як зміни були зафіксовані Weblate."

#: app/src/weblate/accounts/forms.py:250
msgid "Use anonymous account name"
msgstr "Використовувати анонімне ім'я облікового запису"

#: app/src/weblate/accounts/forms.py:252
msgid "Use account name"
msgstr "Використовувати ім'я облікового запису"

#: app/src/weblate/accounts/forms.py:273 app/src/weblate/accounts/models.py:961
msgid "Public e-mail"
msgstr "Загальнодоступна ел. пошта"

#: app/src/weblate/accounts/forms.py:274
msgid "Hide e-mail address from public view"
msgstr "Приховати адресу електронної пошти від загального перегляду"

#: app/src/weblate/accounts/forms.py:390
#, python-format
msgid "Component list: %s"
msgstr "Списки складників: %s"

#: app/src/weblate/accounts/forms.py:417
msgid "Account e-mail"
msgstr "Електронна адреса облікового запису"

#: app/src/weblate/accounts/forms.py:419
msgid ""
"Used for e-mail notifications and as a commit e-mail if it is not configured "
"below."
msgstr ""
"Використовується для сповіщень електронною поштою та як електронна пошта для "
"внесків, якщо вона не налаштована нижче."

#: app/src/weblate/accounts/forms.py:488
msgid "Human verification"
msgstr "Людська перевірка"

#: app/src/weblate/accounts/forms.py:559
#, python-format
msgctxt ""
"Question for a mathematics-based CAPTCHA, the %s is an arithmetic problem"
msgid "What is %s?"
msgstr "Скільки буде %s?"

#. Translators: Shown on wrong answer to the mathematics-based CAPTCHA
#: app/src/weblate/accounts/forms.py:578
msgid "That was not correct, please try again."
msgstr "Відповідь неправильна. Будь ласка, спробуйте знову."

#: app/src/weblate/accounts/forms.py:592 app/src/weblate/accounts/forms.py:599
#: app/src/weblate/accounts/forms.py:607 app/src/weblate/accounts/forms.py:618
msgid "Validation failed, please try again."
msgstr "Помилка перевірки, повторіть спробу."

#: app/src/weblate/accounts/forms.py:637
msgid "Subject"
msgstr "Тема"

#: app/src/weblate/accounts/forms.py:640
msgid "Your name"
msgstr "Ваше ім’я"

#: app/src/weblate/accounts/forms.py:642
msgid "Your e-mail"
msgstr "Ваша електронна пошта"

#: app/src/weblate/accounts/forms.py:644
#: app/src/weblate/api/serializers.py:2379
#: app/src/weblate/templates/manage/performance.html:28
#: app/src/weblate/templates/manage/performance.html:81
#: app/src/weblate/trans/change_messages.py:28
#: app/src/weblate/trans/models/announcement.py:138
msgid "Message"
msgstr "Повідомлення"

#: app/src/weblate/accounts/forms.py:647
msgid ""
"Please contact us in English. Otherwise, we might not process your request."
msgstr ""
"Будь ласка, зв'яжіться з нами англійською мовою. Інакше ми можемо не "
"обробити ваш запит."

#: app/src/weblate/accounts/forms.py:671
#: app/src/weblate/accounts/templatetags/authnames.py:34
#: app/src/weblate/auth/models.py:671 app/src/weblate/auth/models.py:1705
#: app/src/weblate/templates/accounts/user.html:251
#: app/src/weblate/templates/manage/users.html:61
#: app/src/weblate/templates/trans/project-access.html:61
#: app/src/weblate/utils/fields.py:39 app/src/weblate/wladmin/forms.py:58
msgid "E-mail"
msgstr "Електронна пошта"

#: app/src/weblate/accounts/forms.py:672
msgid "An e-mail with a confirmation link will be sent here."
msgstr "Сюди буде надіслано електронний лист із посиланням для підтвердження."

#: app/src/weblate/accounts/forms.py:734
msgid "New password"
msgstr "Новий пароль"

#: app/src/weblate/accounts/forms.py:739
msgid "New password confirmation"
msgstr "Підтвердження нового пароля"

#: app/src/weblate/accounts/forms.py:743
#: app/src/weblate/templates/accounts/profile.html:562
msgid "Regenerate API key"
msgstr "Повторно створити ключ API"

#: app/src/weblate/accounts/forms.py:745
msgid ""
"Leave enabled to revoke the current API key and generate a new one. This is "
"recommended if you suspect your password was compromised. Disable it to keep "
"your current API key active after changing your password."
msgstr ""
"Увімкніть цю опцію, щоб скасувати чинний ключ API та згенерувати новий. Це "
"рекомендується зробити, якщо ви підозрюєте, що ваш пароль потрапив до чужих "
"рук. Вимкніть цю опцію, щоб чинний ключ API залишився активним після зміни "
"пароля."

#: app/src/weblate/accounts/forms.py:781
msgid "Your password has been changed."
msgstr "Ваш пароль змінено."

#: app/src/weblate/accounts/forms.py:795
msgid "Current password"
msgstr "Поточний пароль"

#: app/src/weblate/accounts/forms.py:796
msgid "Leave empty if you have not set a password yet."
msgstr "Залиште порожнім, якщо ви ще не встановили пароль."

#: app/src/weblate/accounts/forms.py:810
msgid "You have entered an invalid password."
msgstr "Ви ввели неправильний пароль."

#: app/src/weblate/accounts/forms.py:823
msgid "Username or e-mail"
msgstr "Імʼя користувача або електронна пошта"

#: app/src/weblate/accounts/forms.py:824
#: app/src/weblate/accounts/templatetags/authnames.py:33
msgid "Password"
msgstr "Пароль"

#: app/src/weblate/accounts/forms.py:828
msgid "Please enter the correct username and password."
msgstr "Введіть правильне ім’я користувача та пароль."

#: app/src/weblate/accounts/forms.py:830
msgid "This account is inactive."
msgstr "Цей обліковий запис не активний."

#: app/src/weblate/accounts/forms.py:949
msgid "Component wide notifications"
msgstr "Сповіщення про перекладацькі складники"

#: app/src/weblate/accounts/forms.py:954
msgid "Translation notifications"
msgstr "Сповіщення з перекладу"

#: app/src/weblate/accounts/forms.py:973
msgid "Use default setting"
msgstr "Використовувати типове значення"

#: app/src/weblate/accounts/forms.py:1005
msgid "Other projects"
msgstr "Інші проєкти"

#: app/src/weblate/accounts/forms.py:1007
#: app/src/weblate/accounts/models.py:883
#: app/src/weblate/templates/accounts/profile.html:106
#: app/src/weblate/templates/accounts/user.html:174
msgid "Watched projects"
msgstr "Відстежувані проєкти"

#: app/src/weblate/accounts/forms.py:1009
#: app/src/weblate/accounts/models.py:856
#: app/src/weblate/templates/accounts/user.html:171
#: app/src/weblate/templates/dashboard/user.html:43
msgid "Managed projects"
msgstr "Керовані проєкти"

#: app/src/weblate/accounts/forms.py:1011
msgid "Project: {}"
msgstr "Проєкт: {}"

#: app/src/weblate/accounts/forms.py:1012
msgid "Component: {}"
msgstr "Складник: {}"

#: app/src/weblate/accounts/forms.py:1018
msgid ""
"You will receive a notification for every such event in non-watched projects."
msgstr ""
"Ви отримуватимете сповіщення про кожну з цих подій у проєктах, за якими ви "
"не стежите."

#: app/src/weblate/accounts/forms.py:1023
msgid ""
"You will receive a notification for every such event in your watched "
"projects."
msgstr ""
"Ви отримуватимете сповіщення про кожну з цих подій у відстежуваних проєктах."

#: app/src/weblate/accounts/forms.py:1028
msgid ""
"You will receive a notification for every such event in projects where you "
"have admin permissions."
msgstr ""
"Ви отримуватимете сповіщення про кожну подію у проєктах, де у вас є права "
"доступу адміністратора."

#: app/src/weblate/accounts/forms.py:1033
#, python-format
msgid "You will receive a notification for every such event in %(project)s."
msgstr "Ви будете отримувати повідомлення про кожну таку подію у %(project)s."

#: app/src/weblate/accounts/forms.py:1036
#, python-format
msgid "You will receive a notification for every such event in %(component)s."
msgstr ""
"Ви будете отримувати повідомлення про кожну таку подію у %(component)s."

#: app/src/weblate/accounts/forms.py:1043
msgid ""
"You will only receive these notifications for your translated languages in "
"non-watched projects."
msgstr ""
"Ви отримуватимете ці сповіщення лише для мов, якими ви перекладаєте, у "
"проєктах, за якими ви не стежите."

#: app/src/weblate/accounts/forms.py:1048
msgid ""
"You will only receive these notifications for your translated languages in "
"your watched projects."
msgstr ""
"Ви отримуватимете ці сповіщення лише для мов, на які ви перекладаєте у "
"відстежуваних вами проєктах."

#: app/src/weblate/accounts/forms.py:1053
msgid ""
"You will only receive these notifications for your translated languages in "
"projects where you have admin permissions."
msgstr ""
"Ви отримуватимете ці сповіщення лише для ваших мов перекладу у проєктах, де "
"ви маєте права адміністратора."

#: app/src/weblate/accounts/forms.py:1058
#, python-format
msgid ""
"You will only receive these notifications for your translated languages in "
"%(project)s."
msgstr ""
"Ви отримуватимете ці сповіщення лише для ваших мов перекладу в %(project)s."

#: app/src/weblate/accounts/forms.py:1062
#, python-format
msgid ""
"You will only receive these notifications for your translated languages in "
"%(component)s."
msgstr ""
"Ви отримуватимете ці сповіщення лише для ваших мов перекладу в %(component)s."

