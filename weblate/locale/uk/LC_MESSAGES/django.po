#: app/src/weblate/templates/accounts/profile.html:440
#: app/src/weblate/templates/accounts/user.html:332
#: app/src/weblate/templates/trans/project-access-team-form.html:13
msgid "Team"
msgstr "Команда"

#: app/src/weblate/accounts/forms.py:1161
msgid "Add to a team"
msgstr "Додати до команди"

#: app/src/weblate/accounts/forms.py:1175
msgid "Name your authentication app"
msgstr "Назва вашої програми для розпізнавання"

#: app/src/weblate/accounts/forms.py:1178
msgid "Verify the code from the app"
msgstr "Перевірити код з програми"

#: app/src/weblate/accounts/forms.py:1194
msgid "Discard previously configured authentication apps"
msgstr "Відхилити раніше налаштовані програми автентифікації"

#: app/src/weblate/accounts/forms.py:1198
msgid ""
"All previously configured authentication apps will be discarded upon "
"verification of the new app."
msgstr ""
"Усі раніше налаштовані програми автентифікації будуть відхилені після "
"перевірки нової програми."

#: app/src/weblate/accounts/forms.py:1201
msgid ""
"Other two-factor methods (such as WebAuthn and security keys) won't be "
"affected."
msgstr ""
"Інші двофакторні методи (такі як WebAuthn та ключі безпеки) залишаться в "
"силі."

#: app/src/weblate/accounts/forms.py:1207
msgid "The entered token is not valid."
msgstr "Введений маркер недійсний."

#: app/src/weblate/accounts/forms.py:1277
msgid "Recovery token"
msgstr "Жетон відновлення"

#: app/src/weblate/accounts/forms.py:1279
msgid ""
"Recovery codes can only be used once. Remember to mark used ones as expired."
msgstr ""
"Коди відновлення можна використати лише один раз. Не забудьте позначити "
"використані як прострочені."

#: app/src/weblate/accounts/forms.py:1336
msgid "Enter the code from the app"
msgstr "Введіть код з програми"

