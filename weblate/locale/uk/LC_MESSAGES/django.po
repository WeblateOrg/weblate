#: app/src/weblate/accounts/forms.py:1100
msgid "Translations made"
msgstr "Зроблені переклади"

#: app/src/weblate/accounts/forms.py:1101
msgid "Suggestions made"
msgstr "Зроблені пропозиції"

#: app/src/weblate/accounts/forms.py:1102
msgid "Comments made"
msgstr "Додано коментарі"

#: app/src/weblate/accounts/forms.py:1103
msgid "Screenshots uploaded"
msgstr "Знімки вивантажено"

#: app/src/weblate/accounts/forms.py:1127
#: app/src/weblate/screenshots/forms.py:227
msgid "The chosen sorting is not supported."
msgstr "Вибране сортування не підтримується."

#: app/src/weblate/accounts/forms.py:1144 app/src/weblate/auth/forms.py:319
