#: app/src/weblate/addons/autotranslate.py:70
#: app/src/weblate/templates/snippets/autoform.html:13
#: app/src/weblate/templates/translation.html:85
msgid "Automatic translation"
msgstr "Dịch tự động"

#: app/src/weblate/addons/autotranslate.py:72
msgid ""
"Automatically translates strings using machine translation or other "
"components."
msgstr "Tự động dịch các xâu bằng dịch bằng máy hoặc các thành phần khác."

#: app/src/weblate/addons/base.py:208
#: app/src/weblate/trans/change_display.py:274
msgid "enabled"
msgstr "đã bật"

#: app/src/weblate/addons/base.py:825 app/src/weblate/trans/views/create.py:315
msgid ""
"The repository is outdated, you might not get expected results until you "
"update it."
msgstr ""
"Kho lưu trữ đã bị chậm cập nhật, bạn có thể sẽ không nhận được kết quả mong "
"muốn trừ khi bạn cập nhật nó."

#: app/src/weblate/addons/cdn.py:155
msgid "JavaScript localization CDN"
msgstr "JavaScript cục bộ hóa CDN"

#: app/src/weblate/addons/cdn.py:157
msgid ""
"Publishes translations into content delivery network for use in JavaScript "
"or HTML localization."
msgstr ""
"Đăng tải các bản dịch lên mạng phân phối nội dung để sử dụng trong quá trình "
"bản địa hóa JavaScript hoặc HTML."

#: app/src/weblate/addons/cdn.py:269
msgid "Translation files CDN"
msgstr "CDN tập tin dịch thuật"

#: app/src/weblate/addons/cdn.py:271
msgid "Publishes translation files into a content delivery network."
msgstr "Đăng tải các tệp dịch thuật lên mạng phân phối nội dung."

#: app/src/weblate/addons/cdn.py:308
msgid "The translation files CDN add-on cannot publish weblate.js."
msgstr ""
"Tiện ích bổ sung CDN cho các tệp dịch thuật không thể xuất bản weblate.js."

#: app/src/weblate/addons/cleanup.py:44
msgid "Cleanup translation files"
msgstr "Dọn dẹp các tệp bản dịch"

#: app/src/weblate/addons/cleanup.py:46
msgid ""
"Update all translation files to match the monolingual base file. For most "
"file formats, this means removing stale translation keys no longer present "
"in the base file."
msgstr ""
"Cập nhật tất cả tệp dịch thuật để hợp với tệp cơ sở đơn ngữ. Cho hầu hết các "
"định dạng tệp, điều này có nghĩa là khi loại bỏ các từ khóa dịch thuật cũ sẽ "
"không còn hiện trên các tệp cơ sở nữa."

#: app/src/weblate/addons/cleanup.py:93
msgid "Remove blank strings"
msgstr "Xoá các chuỗi trống"

#: app/src/weblate/addons/cleanup.py:95
msgid "Removes strings without a translation from translation files."
msgstr "Xóa các chuỗi không có bản dịch khỏi các tệp dịch."

#: app/src/weblate/addons/cleanup.py:130
msgid "Reset repository to upstream"
msgstr "Đặt lại repository về thượng nguồn"

#: app/src/weblate/addons/cleanup.py:132
msgid "Discards all changes in the Weblate repository each night."
msgstr "Bỏ tất cả thay đổi trong Weblate repository vào mỗi đêm."

#: app/src/weblate/addons/consistency.py:91
msgid "Add missing languages"
msgstr "Thêm ngôn ngữ thiếu"

#: app/src/weblate/addons/consistency.py:93
msgid ""
"Ensures a consistent set of languages is used for all components within a "
"project."
msgstr ""
"Đảm bảo một bộ ngôn ngữ nhất quán dùng cho tất cả thành phần trong dự án."

#: app/src/weblate/addons/consistency.py:129
msgid ""
"This add-on affects the whole project and may create translation files "
"across many components or repositories."
msgstr ""
"Tiện ích bổ sung này ảnh hưởng đến toàn bộ dự án và có thể tạo ra các tệp "
"dịch thuật trên nhiều thành phần hoặc kho lưu trữ khác nhau."

#: app/src/weblate/addons/consistency.py:134
msgid ""
"This add-on affects the whole category and may create translation files "
"across many components or repositories."
msgstr ""
"Tiện ích bổ sung này ảnh hưởng đến toàn bộ danh mục và có thể tạo ra các tệp "
"dịch thuật trên nhiều thành phần hoặc kho lưu trữ."

#: app/src/weblate/addons/consistency.py:138
msgid ""
"This add-on affects all projects and may create translation files across "
"many components or repositories."
msgstr ""
"Tiện ích bổ sung này ảnh hưởng đến tất cả các dự án và có thể tạo ra các tệp "
"dịch thuật trên nhiều thành phần hoặc kho lưu trữ."

#: app/src/weblate/addons/consistency.py:244
#: app/src/weblate/trans/models/component.py:5261
msgid ""
"The given language maps to a different language. Check language aliases "
"settings."
msgstr ""
"Ngôn ngữ được cung cấp tương ứng với một ngôn ngữ khác. Vui lòng kiểm tra "
"cài đặt bí danh ngôn ngữ."

#: app/src/weblate/addons/consistency.py:248
#: app/src/weblate/trans/models/component.py:5267
msgid "The given language is used as a source language."
msgstr "Ngôn ngữ được cung cấp được sử dụng làm ngôn ngữ nguồn."

#: app/src/weblate/addons/consistency.py:253
#: app/src/weblate/trans/models/component.py:5279
msgid "The language filter timed out."
msgstr "Bộ lọc ngôn ngữ đã hết thời gian chờ."

#: app/src/weblate/addons/consistency.py:256
#: app/src/weblate/trans/models/component.py:5283
msgid "The given language is filtered by the language filter."
msgstr "Ngôn ngữ được cung cấp sẽ được lọc bởi bộ lọc ngôn ngữ."

#: app/src/weblate/addons/discovery.py:27
msgid "Component discovery"
msgstr "Khám phá thành phần"

#: app/src/weblate/addons/discovery.py:29
msgid ""
"Automatically adds or removes project components based on file changes in "
"the version control system."
msgstr ""
"Tự động thêm hoặc bỏ đi các thành phần dự án dựa trên các sự điểu chỉnh của "
"tệp trong một phiên bản hệ thống điều khiển."

#: app/src/weblate/addons/example.py:31
msgid "Example add-on"
msgstr "Ví dụ add-on"

#: app/src/weblate/addons/example.py:33
msgid "This add-on does nothing it is just an example."
msgstr "Add-on này không có tác dụng gì cả, nó chỉ là một ví dụ."

#: app/src/weblate/addons/example_pre.py:25
msgid "Execute script before commit"
msgstr "Thực thi tập lệnh trước khi commit"

#: app/src/weblate/addons/example_pre.py:26
msgid "This add-on executes a script."
msgstr "Add-on này sẽ thực thi một tập lệnh."

#: app/src/weblate/addons/fedora_messaging.py:32
msgid "Fedora Messaging"
msgstr "Thông Báo Fedora"

#: app/src/weblate/addons/fedora_messaging.py:34
msgid "Sends notifications to a Fedora Messaging compatible AMQP exchange."
msgstr ""
"Gửi thông báo đến một cơ chế trao đổi AMQP tương thích với Thông Báo Fedora."

#: app/src/weblate/addons/flags.py:51
msgid "Flag new source strings as \"Needs checking\""
msgstr "Đánh dấu các chuỗi nguồn mới là \"Cần kiểm tra\""

#: app/src/weblate/addons/flags.py:53
msgid ""
"Whenever a new source string is imported from the VCS, it is flagged as "
"needing checking in Weblate. This way you can easily filter and edit source "
"strings written by the developers."
msgstr ""
"Bất cứ khi nào một chuỗi nguồn mới được nhập từ VCS, nó sẽ được đánh dấu là "
"cần chỉnh sửa trong Weblate. Bằng cách này, bạn có thể dễ dàng lọc và chỉnh "
"sửa các chuỗi nguồn do nhà phát triển viết."

#: app/src/weblate/addons/flags.py:72
msgid "Flag new translations as \"Needs rewriting\""
msgstr "Đánh dấu các bản dịch mới là \"Cần viết lại\""

#: app/src/weblate/addons/flags.py:74
msgid ""
"Whenever a new translatable string is imported from the VCS, it is flagged "
"as needing rewriting in Weblate. This way you can easily filter and edit "
"translations created by the developers."
msgstr ""
"Bất cứ khi nào một chuỗi dịch mới được nhập từ VCS, nó sẽ được đánh dấu là "
"cần viết lại trong Weblate. Bằng cách này, bạn có thể dễ dàng lọc và chỉnh "
"sửa các bản dịch do nhà phát triển tạo ra."

#: app/src/weblate/addons/flags.py:90
msgid "Flag unchanged translations as \"Needs rewriting\""
msgstr "Đánh dấu các bản dịch chưa thay đổi là \"Cần viết lại\""

#: app/src/weblate/addons/flags.py:92
msgid ""
"Whenever a new translatable string is imported from the VCS and it matches a "
"source string, it is flagged as needing rewriting in Weblate. Especially "
"useful for file formats that include source strings for untranslated strings."
msgstr ""
"Bất cứ khi nào một chuỗi dịch mới được nhập từ VCS và khớp với chuỗi nguồn, "
"chuỗi đó sẽ được đánh dấu là cần viết lại trong Weblate. Điều này đặc biệt "
"hữu ích cho các định dạng tệp bao gồm chuỗi nguồn cho các chuỗi chưa dịch."

#: app/src/weblate/addons/flags.py:113
#: app/src/weblate/templates/category-language.html:53
#: app/src/weblate/templates/category-language.html:136
#: app/src/weblate/templates/category.html:84
#: app/src/weblate/templates/category.html:234
#: app/src/weblate/templates/component.html:98
#: app/src/weblate/templates/component.html:288
#: app/src/weblate/templates/language-project.html:84
#: app/src/weblate/templates/language-project.html:210
#: app/src/weblate/templates/project.html:99
#: app/src/weblate/templates/project.html:311
#: app/src/weblate/templates/translation.html:80
#: app/src/weblate/templates/translation.html:213
#: app/src/weblate/templates/workspace.html:51
#: app/src/weblate/templates/workspace.html:113
msgid "Bulk edit"
msgstr "Chỉnh sửa hàng loạt"

#: app/src/weblate/addons/flags.py:114
msgid "Bulk edit flags, labels, or states of strings."
msgstr "Chỉnh sửa hàng loạt cờ, nhãn hoặc trạng thái của chuỗi."

#: app/src/weblate/addons/flags.py:145
msgid "Flag updated translations from repository as \"Needs rewriting\""
msgstr "Đánh dấu bản dịch đã cập nhật từ repository là \"Cần sửa\""

#: app/src/weblate/addons/flags.py:148
msgid ""
"Whenever a string translation is changed from the VCS, it is flagged as "
"needing rewriting in Weblate. Especially useful if translation files are "
"often updated manually or by an external service."
msgstr ""
"Bất cứ khi nào một chuỗi dịch được thay đổi từ VCS, nó sẽ được đánh dấu là "
"cần viết lại trong Weblate. Điều này đặc biệt hữu ích nếu các tệp dịch "
"thường được cập nhật thủ công hoặc bởi một dịch vụ bên ngoài."

#: app/src/weblate/addons/forms.py:101
msgid "Path of generated MO file"
msgstr "Đường dẫn của tệp MO được tạo"

#: app/src/weblate/addons/forms.py:105
msgid "If not specified, the location of the PO file will be used."
msgstr "Nếu không chỉ định, vị trí của tệp PO sẽ được sử dụng."

#: app/src/weblate/addons/forms.py:109
msgid "Include strings needing editing"
msgstr "Bao gồm các chuỗi cần chỉnh sửa"

#: app/src/weblate/addons/forms.py:112
msgid ""
"Strings needing editing (fuzzy) are typically not ready for use as "
"translations."
msgstr ""
"Các chuỗi cần chỉnh sửa (mờ) thường chưa sẵn sàng để sử dụng làm bản dịch."

#: app/src/weblate/addons/forms.py:138
msgid "Update frequency"
msgstr "Tần suất cập nhật"

#: app/src/weblate/addons/forms.py:140
msgid "Daily"
msgstr "Hằng ngày"

#: app/src/weblate/addons/forms.py:141
msgid "Weekly"
msgstr "Hàng tuần"

#: app/src/weblate/addons/forms.py:142
msgid "Monthly"
msgstr "Hàng tháng"

#: app/src/weblate/addons/forms.py:147
msgid ""
"How often the add-on should update the POT file when the component is "
"refreshed."
msgstr ""
"Tần suất cập nhật tệp POT của tiện ích bổ sung khi thành phần được làm mới "
"là bao nhiêu."

#: app/src/weblate/addons/forms.py:151
msgid "Normalize POT header"
msgstr "Tiêu đề POT bình thường"

#: app/src/weblate/addons/forms.py:155
msgid "Updates gettext headers and replaces placeholder POT comments."
msgstr "Cập nhật tiêu đề gettext và thay thế các bình luận POT giữ chỗ."

#: app/src/weblate/addons/forms.py:159
msgid "Update PO files using msgmerge"
msgstr "Cập nhật các tệp PO bằng msgmerge"

#: app/src/weblate/addons/forms.py:164
msgid ""
"Ensures the msgmerge add-on is installed and triggers it after the POT file "
"is updated."
msgstr ""
"Đảm bảo tiện ích bổ sung msgmerge được cài đặt và kích hoạt nó sau khi tệp "
"POT được cập nhật."

#: app/src/weblate/addons/forms.py:189
msgid "Do not extract comments"
msgstr "Không trích xuất bình luận"

#: app/src/weblate/addons/forms.py:190
msgid "Extract all comments"
msgstr "Trích xuất tất cả bình luận"

#: app/src/weblate/addons/forms.py:191
msgid "Extract comments with tag"
msgstr "Trích xuất bình luận có gắn thẻ"

#: app/src/weblate/addons/forms.py:200
msgid "Code comments"
msgstr "Chú thích mã"

#: app/src/weblate/addons/forms.py:205
msgid ""
"Choose whether xgettext should extract no comments, all comments, or only "
"comments marked with a specific tag."
msgstr ""
"Chọn xem xgettext có nên trích xuất không có bình luận nào, tất cả bình "
"luận, hoặc chỉ những bình luận được đánh dấu bằng một thẻ cụ thể hay không."

#: app/src/weblate/addons/forms.py:210
msgid "Comment tag"
msgstr "Thẻ bình luận"

#: app/src/weblate/addons/forms.py:213
msgid ""
"Tag passed to xgettext for comment extraction when using tagged comment mode."
msgstr ""
"Thẻ được truyền đến xgettext để trích xuất bình luận khi sử dụng chế độ bình "
"luận có gắn thẻ."

#: app/src/weblate/addons/forms.py:218
msgid "xgettext checks"
msgstr "xgettext kiểm tra"

#: app/src/weblate/addons/forms.py:223
msgid "Additional xgettext validation checks to enable for extracted messages."
msgstr ""
"Thêm các bước kiểm tra xác thực xgettext bổ sung để kích hoạt cho các tin "
"nhắn đã trích xuất."

#: app/src/weblate/addons/forms.py:227
msgid "Additional keyword"
msgstr "Từ khóa bổ sung"

#: app/src/weblate/addons/forms.py:230
msgid "Optional extra keyword passed to xgettext using --keyword."
msgstr ""
"Từ khóa bổ sung tùy chọn được truyền cho xgettext bằng cách sử dụng --"
"keyword."

#: app/src/weblate/addons/forms.py:259 app/src/weblate/addons/forms.py:350
#: app/src/weblate/addons/forms.py:357
msgid "This field is required."
msgstr "Trường này là bắt buộc."

#: app/src/weblate/addons/forms.py:269
msgid "Input source"
msgstr "Nguồn đầu vào"

#: app/src/weblate/addons/forms.py:271 app/src/weblate/addons/forms.py:290
msgid "Source file patterns"
msgstr "Các mẫu tệp nguồn"

#: app/src/weblate/addons/forms.py:272
msgid "POTFILES manifest"
msgstr "Tệp kê khai POTFILES"

#: app/src/weblate/addons/forms.py:277
msgid ""
"Choose whether xgettext should read source files from glob patterns or from "
"a POTFILES/POTFILES.in manifest."
msgstr ""
"Chọn xem xgettext nên đọc các tệp nguồn từ các mẫu glob hay từ tệp kê khai "
"POTFILES/POTFILES.in."

#: app/src/weblate/addons/forms.py:282
msgid "xgettext language"
msgstr "ngôn ngữ xgettext"

#: app/src/weblate/addons/forms.py:286
msgid "Programming language passed to xgettext, for example Python or C."
msgstr ""
"Ngôn ngữ lập trình được truyền cho hàm xgettext, ví dụ như Python hoặc C."

#: app/src/weblate/addons/forms.py:294
msgid ""
"Newline-separated repository-relative glob patterns for files to extract "
"with xgettext."
msgstr ""
"Các mẫu glob tương đối với kho lưu trữ được phân tách bằng dấu xuống dòng "
"dùng để trích xuất tệp bằng xgettext."

#: app/src/weblate/addons/forms.py:299
msgid "POTFILES path"
msgstr "Đường dẫn POTFILES"

#: app/src/weblate/addons/forms.py:303
msgid ""
"Repository-relative path to POTFILES or POTFILES.in. Entries are resolved "
"relative to the repository root. If present next to the manifest, "
"POTFILES.skip excludes listed files from extraction."
msgstr ""
"Đường dẫn tương đối so với kho lưu trữ đến POTFILES hoặc POTFILES.in. Các "
"mục được giải quyết tương đối so với thư mục gốc của kho lưu trữ. Nếu có mặt "
"bên cạnh tệp kê khai, POTFILES.skip sẽ loại trừ các tệp được liệt kê khỏi "
"quá trình giải nén."

#: app/src/weblate/addons/forms.py:367
#: app/src/weblate/trans/models/component.py:5747
msgid "Invalid symbolic link in a repository."
msgstr "Liên kết tượng trưng không hợp lệ trong kho lưu trữ."

#: app/src/weblate/addons/forms.py:378
msgid "POTFILES path has to point to a file."
msgstr "Đường dẫn POTFILES phải trỏ đến một tệp."

#: app/src/weblate/addons/forms.py:387
msgid "Meson preset"
msgstr "Cài đặt sẵn Meson"

#: app/src/weblate/addons/forms.py:388
msgid "GLib"
msgstr "GLib"

#: app/src/weblate/addons/forms.py:392
