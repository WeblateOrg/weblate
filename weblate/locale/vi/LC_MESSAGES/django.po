#: weblate/addons/flags.py:51
msgid "Flag new source strings as \"Needs checking\""
msgstr "Đánh dấu các chuỗi nguồn mới là \"Cần kiểm tra\""

#: weblate/addons/flags.py:53
msgid ""
"Whenever a new source string is imported from the VCS, it is flagged as "
"needing checking in Weblate. This way you can easily filter and edit source "
"strings written by the developers."
msgstr ""
"Bất cứ khi nào một chuỗi nguồn mới được nhập từ VCS, nó sẽ được đánh dấu là "
"cần chỉnh sửa trong Weblate. Bằng cách này, bạn có thể dễ dàng lọc và chỉnh "
"sửa các chuỗi nguồn do nhà phát triển viết."

#: weblate/addons/flags.py:72
msgid "Flag new translations as \"Needs rewriting\""
msgstr "Đánh dấu các bản dịch mới là \"Cần viết lại\""

#: weblate/addons/flags.py:74
msgid ""
"Whenever a new translatable string is imported from the VCS, it is flagged "
"as needing rewriting in Weblate. This way you can easily filter and edit "
"translations created by the developers."
msgstr ""
"Bất cứ khi nào một chuỗi dịch mới được nhập từ VCS, nó sẽ được đánh dấu là "
"cần viết lại trong Weblate. Bằng cách này, bạn có thể dễ dàng lọc và chỉnh "
"sửa các bản dịch do nhà phát triển tạo ra."

#: weblate/addons/flags.py:90
msgid "Flag unchanged translations as \"Needs rewriting\""
msgstr "Đánh dấu các bản dịch chưa thay đổi là \"Cần viết lại\""

#: weblate/addons/flags.py:92
msgid ""
"Whenever a new translatable string is imported from the VCS and it matches a "
"source string, it is flagged as needing rewriting in Weblate. Especially "
"useful for file formats that include source strings for untranslated strings."
msgstr ""
"Bất cứ khi nào một chuỗi dịch mới được nhập từ VCS và khớp với chuỗi nguồn, "
"chuỗi đó sẽ được đánh dấu là cần viết lại trong Weblate. Điều này đặc biệt "
"hữu ích cho các định dạng tệp bao gồm chuỗi nguồn cho các chuỗi chưa dịch."

#: weblate/addons/flags.py:113 weblate/templates/category-language.html:60
#: weblate/templates/category-language.html:148
#: weblate/templates/category.html:90 weblate/templates/category.html:251
#: weblate/templates/component.html:109 weblate/templates/component.html:313
#: weblate/templates/language-project.html:84
#: weblate/templates/language-project.html:216
#: weblate/templates/project.html:105 weblate/templates/project.html:318
#: weblate/templates/translation.html:80 weblate/templates/translation.html:227
#: weblate/templates/workspace.html:38 weblate/templates/workspace.html:120
msgid "Bulk edit"
msgstr "Chỉnh sửa hàng loạt"

#: weblate/addons/flags.py:114
msgid "Bulk edit flags, labels, or states of strings."
msgstr "Chỉnh sửa hàng loạt cờ, nhãn hoặc trạng thái của chuỗi."

#: weblate/addons/flags.py:145
msgid "Flag updated translations from repository as \"Needs rewriting\""
msgstr "Đánh dấu bản dịch đã cập nhật từ repository là \"Cần sửa\""

#: weblate/addons/flags.py:148
msgid ""
"Whenever a string translation is changed from the VCS, it is flagged as "
"needing rewriting in Weblate. Especially useful if translation files are "
"often updated manually or by an external service."
msgstr ""
"Bất cứ khi nào một chuỗi dịch được thay đổi từ VCS, nó sẽ được đánh dấu là "
"cần viết lại trong Weblate. Điều này đặc biệt hữu ích nếu các tệp dịch "
"thường được cập nhật thủ công hoặc bởi một dịch vụ bên ngoài."

#: weblate/addons/forms.py:117
msgid "Path of generated MO file"
msgstr "Đường dẫn của tệp MO được tạo"

#: weblate/addons/forms.py:121
msgid "If not specified, the location of the PO file will be used."
msgstr "Nếu không chỉ định, vị trí của tệp PO sẽ được sử dụng."

#: weblate/addons/forms.py:125
msgid "Include strings needing editing"
msgstr "Bao gồm các chuỗi cần chỉnh sửa"

#: weblate/addons/forms.py:128
msgid ""
"Strings needing editing (fuzzy) are typically not ready for use as "
"translations."
msgstr ""
"Các chuỗi cần chỉnh sửa (mờ) thường chưa sẵn sàng để sử dụng làm bản dịch."

#: weblate/addons/forms.py:154
msgid "Update frequency"
msgstr "Tần suất cập nhật"

#: weblate/addons/forms.py:156
msgid "Daily"
msgstr "Hằng ngày"

#: weblate/addons/forms.py:157
msgid "Weekly"
msgstr "Hàng tuần"

#: weblate/addons/forms.py:158
msgid "Monthly"
msgstr "Hàng tháng"

#: weblate/addons/forms.py:163
msgid ""
"How often the add-on should update the POT file when the component is "
"refreshed."
msgstr ""
"Tần suất cập nhật tệp POT của tiện ích bổ sung khi thành phần được làm mới "
"là bao nhiêu."

#: weblate/addons/forms.py:167
msgid "Normalize POT header"
msgstr "Tiêu đề POT bình thường"

#: weblate/addons/forms.py:171
msgid "Updates gettext headers and replaces placeholder POT comments."
msgstr "Cập nhật tiêu đề gettext và thay thế các bình luận POT giữ chỗ."

#: weblate/addons/forms.py:175
msgid "Update PO files using msgmerge"
msgstr "Cập nhật các tệp PO bằng msgmerge"

#: weblate/addons/forms.py:180
msgid ""
"Ensures the msgmerge add-on is installed and triggers it after the POT file "
"is updated."
msgstr ""
"Đảm bảo tiện ích bổ sung msgmerge được cài đặt và kích hoạt nó sau khi tệp "
"POT được cập nhật."

#: weblate/addons/forms.py:205
msgid "Do not extract comments"
msgstr "Không trích xuất bình luận"

#: weblate/addons/forms.py:206
msgid "Extract all comments"
msgstr "Trích xuất tất cả bình luận"

#: weblate/addons/forms.py:207
msgid "Extract comments with tag"
msgstr "Trích xuất bình luận có gắn thẻ"

#: weblate/addons/forms.py:216
msgid "Code comments"
msgstr "Chú thích mã"

#: weblate/addons/forms.py:221
msgid ""
"Choose whether xgettext should extract no comments, all comments, or only "
"comments marked with a specific tag."
msgstr ""
"Chọn xem xgettext có nên trích xuất không có bình luận nào, tất cả bình "
"luận, hoặc chỉ những bình luận được đánh dấu bằng một thẻ cụ thể hay không."

#: weblate/addons/forms.py:226
msgid "Comment tag"
msgstr "Thẻ bình luận"

#: weblate/addons/forms.py:229
msgid ""
"Tag passed to xgettext for comment extraction when using tagged comment mode."
msgstr ""
"Thẻ được truyền đến xgettext để trích xuất bình luận khi sử dụng chế độ bình "
"luận có gắn thẻ."

#: weblate/addons/forms.py:234
msgid "xgettext checks"
msgstr "xgettext kiểm tra"

#: weblate/addons/forms.py:239
msgid "Additional xgettext validation checks to enable for extracted messages."
msgstr ""
"Thêm các bước kiểm tra xác thực xgettext bổ sung để kích hoạt cho các tin "
"nhắn đã trích xuất."

#: weblate/addons/forms.py:243
msgid "Additional keyword"
msgstr "Từ khóa bổ sung"

#: weblate/addons/forms.py:246
msgid "Optional extra keyword passed to xgettext using --keyword."
msgstr ""
"Từ khóa bổ sung tùy chọn được truyền cho xgettext bằng cách sử dụng --"
"keyword."

#: weblate/addons/forms.py:275 weblate/addons/forms.py:367
#: weblate/addons/forms.py:374
msgid "This field is required."
msgstr "Trường này là bắt buộc."

#: weblate/addons/forms.py:285
msgid "Input source"
msgstr "Nguồn đầu vào"

#: weblate/addons/forms.py:287 weblate/addons/forms.py:307
msgid "Source file patterns"
msgstr "Các mẫu tệp nguồn"

#: weblate/addons/forms.py:288
msgid "POTFILES manifest"
msgstr "Tệp kê khai POTFILES"

#: weblate/addons/forms.py:293
msgid ""
"Choose whether xgettext should read source files from glob patterns or from "
"a POTFILES/POTFILES.in manifest."
msgstr ""
"Chọn xem xgettext nên đọc các tệp nguồn từ các mẫu glob hay từ tệp kê khai "
"POTFILES/POTFILES.in."

#: weblate/addons/forms.py:298
msgid "xgettext language"
msgstr "ngôn ngữ xgettext"

#: weblate/addons/forms.py:302
msgid ""
"Programming language passed to xgettext, for example Python or C. Leave "
"blank to let xgettext guess the language from file extensions."
msgstr ""
"Ngôn ngữ lập trình được truyền cho xgettext, ví dụ như Python hoặc C. Để "
"trống để xgettext tự động đoán ngôn ngữ từ phần mở rộng tệp."

#: weblate/addons/forms.py:311
msgid ""
"Newline-separated repository-relative glob patterns for files to extract "
"with xgettext."
msgstr ""
"Các mẫu glob tương đối với kho lưu trữ được phân tách bằng dấu xuống dòng "
"dùng để trích xuất tệp bằng xgettext."

#: weblate/addons/forms.py:316
msgid "POTFILES path"
msgstr "Đường dẫn POTFILES"

#: weblate/addons/forms.py:320
msgid ""
"Repository-relative path to POTFILES or POTFILES.in. Entries are resolved "
"relative to the repository root. If present next to the manifest, "
"POTFILES.skip excludes listed files from extraction."
msgstr ""
"Đường dẫn tương đối so với kho lưu trữ đến POTFILES hoặc POTFILES.in. Các "
"mục được giải quyết tương đối so với thư mục gốc của kho lưu trữ. Nếu có mặt "
"bên cạnh tệp kê khai, POTFILES.skip sẽ loại trừ các tệp được liệt kê khỏi "
"quá trình giải nén."

#: weblate/addons/forms.py:384 weblate/trans/models/component.py:6196
msgid "Invalid symbolic link in a repository."
msgstr "Liên kết tượng trưng không hợp lệ trong kho lưu trữ."

#: weblate/addons/forms.py:395
msgid "POTFILES path has to point to a file."
msgstr "Đường dẫn POTFILES phải trỏ đến một tệp."

#: weblate/addons/forms.py:404
msgid "Meson preset"
msgstr "Cài đặt sẵn Meson"

#: weblate/addons/forms.py:405
msgid "GLib"
msgstr "GLib"

#: weblate/addons/forms.py:409
msgid ""
"Built-in xgettext argument preset matching Meson gettext integration. The "
"GLib preset adds the keyword and format-flag options used by Meson's gettext "
"helper."
msgstr ""
"Thiết lập sẵn đối số xgettext tích hợp phù hợp với tích hợp gettext của "
"Meson. Thiết lập sẵn GLib bổ sung các tùy chọn từ khóa và cờ định dạng được "
"sử dụng bởi trình trợ giúp gettext của Meson."

#: weblate/addons/forms.py:439
msgid ""
"The Meson add-on expects a Meson gettext directory with meson.build and "
"POTFILES or POTFILES.in."
msgstr ""
"Tiện ích bổ sung Meson yêu cầu thư mục Meson gettext với các tệp meson.build "
"và POTFILES hoặc POTFILES.in."

#: weblate/addons/forms.py:457
msgid "The component has to define a gettext template for new translations."
msgstr "Thành phần này cần định nghĩa một mẫu gettext cho các bản dịch mới."

#: weblate/addons/forms.py:465
msgid ""
"The Django add-on expects the template for new translations to be named "
"\"django.pot\", \"djangojs.pot\", \"django.po\", or \"djangojs.po\"."
msgstr ""
"Tiện ích bổ sung Django yêu cầu mẫu cho các bản dịch mới phải được đặt tên "
"là \"django.pot\", \"djangojs.pot\", \"django.po\" hoặc \"djangojs.po\"."

#: weblate/addons/forms.py:475
msgid "Filtering"
msgstr "Lọc"

#: weblate/addons/forms.py:477
msgctxt "None filtering"
msgid "None"
msgstr "Không"

#: weblate/addons/forms.py:478
msgid "Weblate documentation"
msgstr "Tài liệu Weblate"

#: weblate/addons/forms.py:483
msgid ""
"Optionally remove strings that are not useful to translate after Sphinx "
"extraction."
msgstr ""
"Tùy chọn loại bỏ các chuỗi không hữu ích cho việc dịch sau khi trích xuất "
"bằng Sphinx."

#: weblate/addons/forms.py:506
msgid ""
"The Sphinx add-on expects the template for new translations to be a .pot "
"file."
msgstr ""
"Tiện ích bổ sung Sphinx dự kiến mẫu cho các bản dịch mới sẽ là tệp .pot."

#: weblate/addons/forms.py:517
msgid ""
"The Sphinx add-on expects the template for new translations to live in a "
"\"locales\" directory."
msgstr ""
"Tiện ích bổ sung Sphinx mong đợi mẫu cho các bản dịch mới sẽ nằm trong thư "
"mục \"ngôn ngữ\"."

#: weblate/addons/forms.py:532 weblate/addons/forms.py:538
msgid "Could not determine Sphinx source directory."
msgstr "Không thể xác định thư mục nguồn Sphinx."

#: weblate/addons/forms.py:547
msgid "Name of generated file"
msgstr "Tên của tệp được tạo"

#: weblate/addons/forms.py:551
msgid "Content of generated file"
msgstr "Nội dung của tệp được tạo"

#: weblate/addons/forms.py:589
msgid "Commit squashing"
msgstr "Gom commit"

#: weblate/addons/forms.py:592
msgid "All commits into one"
msgstr "Tất cả commit thành một"

#: weblate/addons/forms.py:593
msgid "Per language"
msgstr "Theo ngôn ngữ"

#: weblate/addons/forms.py:594
msgid "Per file"
msgstr "Theo tập tin"

#: weblate/addons/forms.py:595
msgid "Per author"
msgstr "Theo tác giả"

#: weblate/addons/forms.py:601
msgid "Append trailers to squashed commit message"
msgstr "Thêm đoạn giới thiệu vào thông báo commit đã nén"

#: weblate/addons/forms.py:605
msgid ""
"Trailer lines are lines that look similar to RFC 822 e-mail headers, at the "
"end of the otherwise free-form part of a commit message, such as 'Co-"
"authored-by: …'."
