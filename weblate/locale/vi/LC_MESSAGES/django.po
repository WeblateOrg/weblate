#: weblate/accounts/forms.py:1020
msgid "Component: {}"
msgstr "Thành phần: {}"

#: weblate/accounts/forms.py:1026
msgid ""
"You will receive a notification for every such event in non-watched projects."
msgstr ""
"Bạn sẽ nhận một thông báo cho mỗi sự việc như vậy trong các dự án không được "
"theo dõi."

#: weblate/accounts/forms.py:1031
msgid ""
"You will receive a notification for every such event in your watched "
"projects."
msgstr ""
"Bạn sẽ nhận một thông báo cho mỗi sự việc như vậy trong các dự án đã theo "
"dõi của bạn."

#: weblate/accounts/forms.py:1036
msgid ""
"You will receive a notification for every such event in projects where you "
"have admin permissions."
msgstr ""
"Bạn sẽ nhận một thông báo cho mỗi sự việc như vậy trong các dự án mà bạn có "
"quyền quản trị viên."

#: weblate/accounts/forms.py:1041
#, python-format
msgid "You will receive a notification for every such event in %(project)s."
msgstr "Bạn sẽ nhận một thông báo cho mỗi sự việc như vậy trong %(project)s."

#: weblate/accounts/forms.py:1044
#, python-format
msgid "You will receive a notification for every such event in %(component)s."
msgstr "Bạn sẽ nhận một thông báo cho mỗi sự việc như vậy trong %(component)s."

#: weblate/accounts/forms.py:1051
msgid ""
"You will only receive these notifications for your translated languages in "
"non-watched projects."
msgstr ""
"Bạn sẽ chỉ nhận các thông báo này cho các ngôn ngữ đã dịch của bạn trong các "
"dự án không được theo dõi."

#: weblate/accounts/forms.py:1056
msgid ""
"You will only receive these notifications for your translated languages in "
"your watched projects."
msgstr ""
"Bạn sẽ chỉ nhận các thông báo này cho các ngôn ngữ đã dịch của bạn trong các "
"dự án đã theo dõi của bạn."

#: weblate/accounts/forms.py:1061
msgid ""
"You will only receive these notifications for your translated languages in "
"projects where you have admin permissions."
msgstr ""
"Bạn sẽ chỉ nhận các thông báo này cho các ngôn ngữ đã dịch của bạn trong các "
"dự án mà bạn có quyền quản trị viên."

#: weblate/accounts/forms.py:1066
#, python-format
msgid ""
"You will only receive these notifications for your translated languages in "
"%(project)s."
msgstr ""
"Bạn sẽ chỉ nhận các thông báo này cho các ngôn ngữ đã dịch của bạn trong "
"%(project)s."

#: weblate/accounts/forms.py:1070
#, python-format
msgid ""
"You will only receive these notifications for your translated languages in "
"%(component)s."
msgstr ""
"Bạn sẽ chỉ nhận các thông báo này cho các ngôn ngữ đã dịch của bạn trong "
"%(component)s."

