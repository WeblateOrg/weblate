msgstr "Add-on này sẽ thực thi một tập lệnh."

#: weblate/addons/fedora_messaging.py:117
msgid "Fedora Messaging"
msgstr "Thông Báo Fedora"

#: weblate/addons/fedora_messaging.py:119
msgid "Sends notifications to a Fedora Messaging compatible AMQP exchange."
msgstr ""
"Gửi thông báo đến một cơ chế trao đổi AMQP tương thích với Thông Báo Fedora."

#: weblate/addons/fedora_messaging.py:204
#, python-format
msgid "Message ID: %(message_id)s"
msgstr ""

#: weblate/addons/fedora_messaging.py:456
#, python-format
msgid ""
"Fedora Messaging publish timed out; the broker connection or delivery "
"confirmation did not complete: %(error)s"
msgstr ""
"Quá trình gửi tin nhắn Fedora đã hết thời gian chờ; lỗi kết nối với máy chủ "
"trung gian hoặc xác nhận gửi tin nhắn không hoàn tất: %(error)s"

#: weblate/addons/fedora_messaging.py:460
#, python-format
msgid ""
"Fedora Messaging publisher service was unavailable; the connection will be "
"recreated on the next attempt: %(error)s"
msgstr ""
"Dịch vụ gửi tin nhắn Fedora không khả dụng; kết nối sẽ được tạo lại trong "
"lần thử tiếp theo: %(error)s"

#: weblate/addons/fedora_messaging.py:464
#, python-format
msgid "Fedora Messaging broker returned the message: %(error)s"
msgstr "Máy chủ nhắn tin Fedora trả về thông báo: %(error)s"

#: weblate/addons/fedora_messaging.py:468
#, python-format
msgid "Fedora Messaging broker rejected the message: %(error)s"
msgstr "Máy chủ nhắn tin Fedora đã từ chối tin nhắn: %(error)s"

#: weblate/addons/fedora_messaging.py:470
#, python-format
msgid "Fedora Messaging publish failed: %(error)s"
msgstr "Quá trình xuất bản tin nhắn Fedora thất bại: %(error)s"

#: weblate/addons/fedora_messaging.py:556
msgid "configured"
msgstr "đã cấu hình"

#: weblate/addons/fedora_messaging.py:611
msgid "Could not reset Fedora Messaging publisher service."
msgstr "Không thể đặt lại dịch vụ xuất bản tin nhắn Fedora."

#: weblate/addons/fedora_messaging.py:701
msgid "CA certificates must be valid PEM encoded X.509 certificates."
msgstr "Chứng chỉ CA phải là chứng chỉ X.509 được mã hóa PEM hợp lệ."

#: weblate/addons/fedora_messaging.py:705
msgid "Client SSL key must be an unencrypted PEM encoded private key."
msgstr ""
"Khóa SSL của máy khách phải là khóa riêng được mã hóa PEM mà không qua mã "
"hóa."

#: weblate/addons/fedora_messaging.py:710
msgid "Client SSL certificates must be valid PEM encoded X.509 certificates."
msgstr ""
"Chứng chỉ SSL của máy khách phải là chứng chỉ X.509 được mã hóa PEM hợp lệ."

#: weblate/addons/fedora_messaging.py:730
#, python-format
msgid "Fedora Messaging broker URL is invalid: %(error)s"
msgstr "URL của trình môi giới tin nhắn Fedora không hợp lệ: %(error)s"

#: weblate/addons/fedora_messaging.py:756
#, python-format
msgid ""
"Could not verify TLS connection to the Fedora Messaging broker: %(error)s"
msgstr ""
"Không thể xác minh kết nối TLS với máy chủ môi giới tin nhắn Fedora: "
"%(error)s"

#: weblate/addons/flags.py:55
msgid "Flag new source strings as \"Needs checking\""
msgstr "Đánh dấu các chuỗi nguồn mới là \"Cần kiểm tra\""

#: weblate/addons/flags.py:57
msgid ""
"Whenever a new source string is imported from the VCS, it is flagged as "
"needing checking in Weblate. This way you can easily filter and edit source "
"strings written by the developers."
msgstr ""
"Bất cứ khi nào một chuỗi nguồn mới được nhập từ VCS, nó sẽ được đánh dấu là "
"cần chỉnh sửa trong Weblate. Bằng cách này, bạn có thể dễ dàng lọc và chỉnh "
"sửa các chuỗi nguồn do nhà phát triển viết."

#: weblate/addons/flags.py:76
msgid "Flag new translations as \"Needs rewriting\""
msgstr "Đánh dấu các bản dịch mới là \"Cần viết lại\""

#: weblate/addons/flags.py:78
msgid ""
"Whenever a new translatable string is imported from the VCS, it is flagged "
"as needing rewriting in Weblate. This way you can easily filter and edit "
"translations created by the developers."
msgstr ""
"Bất cứ khi nào một chuỗi dịch mới được nhập từ VCS, nó sẽ được đánh dấu là "
"cần viết lại trong Weblate. Bằng cách này, bạn có thể dễ dàng lọc và chỉnh "
"sửa các bản dịch do nhà phát triển tạo ra."

#: weblate/addons/flags.py:94
msgid "Flag unchanged translations as \"Needs rewriting\""
msgstr "Gắn cờ các bản dịch chưa thay đổi là \"Cần viết lại\""

#: weblate/addons/flags.py:96
msgid ""
"Whenever a new translatable string is imported from the VCS and it matches a "
"source string, it is flagged as needing rewriting in Weblate. Especially "
"useful for file formats that include source strings for untranslated strings."
msgstr ""
"Bất cứ khi nào một chuỗi dịch mới được nhập từ VCS và khớp với chuỗi nguồn, "
"chuỗi đó sẽ được đánh dấu là cần viết lại trong Weblate. Điều này đặc biệt "
"hữu ích cho các định dạng tệp bao gồm chuỗi nguồn cho các chuỗi chưa dịch."

#: weblate/addons/flags.py:117 weblate/templates/category-language.html:60
#: weblate/templates/category-language.html:148
#: weblate/templates/category.html:89 weblate/templates/category.html:249
#: weblate/templates/component.html:108 weblate/templates/component.html:326
#: weblate/templates/language-project.html:84
#: weblate/templates/language-project.html:216
#: weblate/templates/project.html:113 weblate/templates/project.html:331
#: weblate/templates/translation.html:80 weblate/templates/translation.html:227
#: weblate/templates/workspace.html:47 weblate/templates/workspace.html:152
msgid "Bulk edit"
msgstr "Chỉnh sửa hàng loạt"

#: weblate/addons/flags.py:118
msgid "Bulk edit flags, labels, or states of strings."
msgstr "Chỉnh sửa hàng loạt cờ, nhãn hoặc trạng thái của chuỗi."

#: weblate/addons/flags.py:149
msgid "Flag updated translations from repository as \"Needs rewriting\""
msgstr "Đánh dấu bản dịch đã cập nhật từ repository là \"Cần sửa\""

#: weblate/addons/flags.py:152
msgid ""
"Whenever a string translation is changed from the VCS, it is flagged as "
"needing rewriting in Weblate. Especially useful if translation files are "
"often updated manually or by an external service."
msgstr ""
"Bất cứ khi nào một chuỗi dịch được thay đổi từ VCS, nó sẽ được đánh dấu là "
"cần viết lại trong Weblate. Điều này đặc biệt hữu ích nếu các tệp dịch "
"thường được cập nhật thủ công hoặc bởi một dịch vụ bên ngoài."

#: weblate/addons/forms.py:130
msgid "Path of generated MO file"
msgstr "Đường dẫn của tệp MO được tạo"

#: weblate/addons/forms.py:134
msgid "If not specified, the location of the PO file will be used."
msgstr "Nếu không chỉ định, vị trí của tệp PO sẽ được sử dụng."

#: weblate/addons/forms.py:138
msgid "Include strings needing editing"
msgstr "Bao gồm các chuỗi cần chỉnh sửa"

#: weblate/addons/forms.py:141
msgid ""
"Strings needing editing (fuzzy) are typically not ready for use as "
"translations."
msgstr ""
"Các chuỗi cần chỉnh sửa (mờ) thường chưa sẵn sàng để sử dụng làm bản dịch."

#: weblate/addons/forms.py:167
msgid "Update frequency"
msgstr "Tần suất cập nhật"

#: weblate/addons/forms.py:169
msgid "Daily"
msgstr "Hằng ngày"

#: weblate/addons/forms.py:170
msgid "Weekly"
msgstr "Hàng tuần"

#: weblate/addons/forms.py:171
msgid "Monthly"
msgstr "Hàng tháng"

#: weblate/addons/forms.py:176
msgid ""
"How often the add-on should update the POT file when the component is "
"refreshed."
msgstr ""
"Tần suất cập nhật tệp POT của tiện ích bổ sung khi thành phần được làm mới "
"là bao nhiêu."

#: weblate/addons/forms.py:180
msgid "Normalize POT header"
msgstr "Tiêu đề POT bình thường"

#: weblate/addons/forms.py:184
msgid "Updates gettext headers and replaces placeholder POT comments."
msgstr "Cập nhật tiêu đề gettext và thay thế các bình luận POT giữ chỗ."

#: weblate/addons/forms.py:188
msgid "Update PO files using msgmerge"
msgstr "Cập nhật các tệp PO bằng msgmerge"

#: weblate/addons/forms.py:193
msgid ""
"Ensures the msgmerge add-on is installed and triggers it after the POT file "
"is updated."
msgstr ""
"Đảm bảo tiện ích bổ sung msgmerge được cài đặt và kích hoạt nó sau khi tệp "
"POT được cập nhật."

#: weblate/addons/forms.py:197
msgid "Source locations"
msgstr "Vị trí nguồn"

#: weblate/addons/forms.py:199
msgid "Use file format settings"
msgstr "Sử dụng cài đặt định dạng tệp"

#: weblate/addons/forms.py:200
msgid "Extract locations to the POT file"
msgstr "Trích xuất vị trí vào tệp POT"

#: weblate/addons/forms.py:201
msgid "Do not extract locations"
msgstr "Không trích xuất vị trí"

#: weblate/addons/forms.py:206
msgid ""
"Choose how extraction writes source locations to the POT file. Use this to "
"keep locations in the template while omitting them from translated PO files."
msgstr ""
"Chọn cách thức trích xuất ghi vị trí nguồn vào tệp POT. Sử dụng tùy chọn này "
"để giữ lại các vị trí trong mẫu trong khi loại bỏ chúng khỏi các tệp PO đã "
"dịch."

#: weblate/addons/forms.py:251
msgid "Do not extract comments"
msgstr "Không trích xuất bình luận"

#: weblate/addons/forms.py:252
msgid "Extract all comments"
msgstr "Trích xuất tất cả bình luận"

#: weblate/addons/forms.py:253
msgid "Extract comments with tag"
msgstr "Trích xuất bình luận có gắn thẻ"

#: weblate/addons/forms.py:262
msgid "Code comments"
msgstr "Chú thích mã"

#: weblate/addons/forms.py:267
msgid ""
"Choose whether xgettext should extract no comments, all comments, or only "
"comments marked with a specific tag."
msgstr ""
"Chọn xem xgettext có nên trích xuất không có bình luận nào, tất cả bình "
"luận, hoặc chỉ những bình luận được đánh dấu bằng một thẻ cụ thể hay không."

#: weblate/addons/forms.py:272
msgid "Comment tag"
msgstr "Thẻ bình luận"

#: weblate/addons/forms.py:275
msgid ""
"Tag passed to xgettext for comment extraction when using tagged comment mode."
msgstr ""
"Thẻ được truyền đến xgettext để trích xuất bình luận khi sử dụng chế độ bình "
"luận có gắn thẻ."

#: weblate/addons/forms.py:280
msgid "xgettext checks"
msgstr "xgettext kiểm tra"

#: weblate/addons/forms.py:285
msgid "Additional xgettext validation checks to enable for extracted messages."
msgstr ""
"Thêm các bước kiểm tra xác thực xgettext bổ sung để kích hoạt cho các tin "
"nhắn đã trích xuất."

#: weblate/addons/forms.py:289
msgid "Additional keyword"
msgstr "Từ khóa bổ sung"

#: weblate/addons/forms.py:292
msgid "Optional extra keyword passed to xgettext using --keyword."
msgstr ""
"Từ khóa bổ sung tùy chọn được truyền cho xgettext bằng cách sử dụng --"
"keyword."

#: weblate/addons/forms.py:296
msgid "Use keywords exclusively"
msgstr ""

#: weblate/addons/forms.py:299
msgid ""
"When enabled, passes --keyword without a value to xgettext before the "
"additional keyword, disabling all default keywords so that only the keyword "
"specified above is recognized."
msgstr ""

#: weblate/addons/forms.py:318 weblate/addons/forms.py:422
#: weblate/addons/forms.py:429
msgid "This field is required."
msgstr "Trường này là bắt buộc."

#: weblate/addons/forms.py:328
msgid "An additional keyword is required when using keywords exclusively."
msgstr ""

#: weblate/addons/forms.py:338
msgid "Input source"
msgstr "Nguồn đầu vào"

#: weblate/addons/forms.py:340 weblate/addons/forms.py:360
msgid "Source file patterns"
msgstr "Các mẫu tệp nguồn"

#: weblate/addons/forms.py:341
msgid "POTFILES manifest"
msgstr "Tệp kê khai POTFILES"

#: weblate/addons/forms.py:346
msgid ""
"Choose whether xgettext should read source files from glob patterns or from "
"a POTFILES/POTFILES.in manifest."
msgstr ""
"Chọn xem xgettext nên đọc các tệp nguồn từ các mẫu glob hay từ tệp kê khai "
"POTFILES/POTFILES.in."

#: weblate/addons/forms.py:351
msgid "xgettext language"
msgstr "ngôn ngữ xgettext"

#: weblate/addons/forms.py:355
msgid ""
"Programming language passed to xgettext, for example Python or C. Leave "
"blank to let xgettext guess the language from file extensions."
msgstr ""
"Ngôn ngữ lập trình được truyền cho xgettext, ví dụ như Python hoặc C. Để "
"trống để xgettext tự động đoán ngôn ngữ từ phần mở rộng tệp."

#: weblate/addons/forms.py:364
msgid ""
"Newline-separated repository-relative glob patterns for files to extract "
