msgid "Active"
msgstr "ເປີດໃຊ້ງານ"

#: weblate/auth/models.py:833
msgid "Mark user as inactive instead of removing."
msgstr "ຕັ້ງສະຖານະຜູ້ໃຊ້ເປັນ ບໍ່ໄດ້ໃຊ້ງານ ແທນການລຶບອອກ."

#: weblate/auth/models.py:841 weblate/templates/trans/project-access.html:396
msgid "Expires"
msgstr "ວັນໝົດອາຍຸ"

#: weblate/auth/models.py:846
msgid "The account will be disabled after the expiry."
msgstr "ບັນຊີຈະຖືກປິດໃຊ້ງານຫຼັງຈາກໝົດອາຍຸ."

#: weblate/auth/models.py:853 weblate/templates/accounts/profile.html:30
#: weblate/templates/accounts/user.html:198 weblate/templates/auth/team.html:57
#: weblate/templates/manage/teams.html:10
#: weblate/templates/manage/users.html:63
#: weblate/templates/trans/project-access.html:21
#: weblate/templates/trans/project-access.html:64
#: weblate/templates/trans/project-access.html:294
