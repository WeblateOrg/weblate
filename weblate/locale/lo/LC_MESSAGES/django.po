#: weblate/templates/accounts/trial.html:22
msgid "Your trial offer"
msgstr "ຂໍ້ສະເໜີທົດລອງໃຊ້ຂອງທ່ານ"

#: weblate/templates/accounts/trial.html:26
#, python-format
