#: weblate/wladmin/views.py:123
msgid "Teams"
msgstr "ທີມ"

#: weblate/auth/models.py:857 weblate/auth/models.py:1955
msgid ""
"The user is granted all permissions included in membership of these teams."
msgstr "ຜູ້ໃຊ້ຈະໄດ້ຮັບສິດອະນຸຍາດທັງໝົດທີ່ມີຢູ່ໃນການເປັນສະມາຊິກຂອງທີມເຫຼົ່ານີ້."

#: weblate/auth/models.py:1683
msgid "Regular expression for e-mail address"
msgstr "Regular expression ສຳລັບທີ່ຢູອີເມວ"

#: weblate/auth/models.py:1687
msgid "Users with e-mail addresses found to match will be added to this team."
msgstr "ຜູ້ໃຊ້ທີ່ມີທີ່ຢູອີເມວກົງກັບທີ່ກຳນົດຈະຖືກເພີ່ມເຂົ້າໃນທີມນີ້."

#: weblate/auth/models.py:1692
msgid "Team to assign"
msgstr "ທີມທີ່ຈະມອບໝາຍ"

#: weblate/auth/models.py:1707 weblate/trans/forms.py:1632
msgid "User to block"
msgstr "ຜູ້ໃຊ້ທີ່ຈະບລັອກ"

#: weblate/auth/models.py:1714
msgid "Block expiry"
msgstr "ວັນໝົດອາຍຸການບລັອກ"

#: weblate/auth/models.py:1716 weblate/trans/forms.py:1650
msgid "Block note"
msgstr "ໝາຍເຫດການບລັອກ"

#: weblate/auth/models.py:1719 weblate/trans/forms.py:1652
msgid ""
"Internal notes regarding blocking the user that are not visible to the user."
msgstr "ໝາຍເຫດພາຍໃນກ່ຽວກັບການບລັອກຜູ້ໃຊ້ ເຊິ່ງຜູ້ໃຊ້ຈະບໍ່ສາມາດເບິ່ງເຫັນໄດ້."

#: weblate/auth/models.py:1928 weblate/trans/forms.py:1563
msgid "User to add"
msgstr "ຜູ້ໃຊ້ທີ່ຈະເພີ່ມ"

#: weblate/auth/models.py:1930 weblate/trans/forms.py:1566
#: weblate/trans/forms.py:1634
msgid "Please type in an existing Weblate account name or e-mail address."
msgstr "ກະລຸນາພິມຊື່ບັນຊີ Weblate ທີ່ມີຢູ່ແລ້ວ ຫຼື ທີ່ຢູອີເມວ."

#: weblate/auth/models.py:1938
msgid "Suggest username for the user. It can be changed later."
msgstr "ແນະນຳຊື່ຜູ້ໃຊ້ສຳລັບຜູ້ໃຊ້. ສາມາດປ່ຽນແປງໄດ້ໃນພາຍຫຼັງ."

#: weblate/auth/models.py:1947
msgid "Suggest full name for the user. It can be changed later."
msgstr "ແນະນຳຊື່ເຕັມສຳລັບຜູ້ໃຊ້. ສາມາດປ່ຽນແປງໄດ້ໃນພາຍຫຼັງ."

#: weblate/auth/permissions.py:206
msgid "You do not have permission to edit glossary entries."
msgstr "ທ່ານບໍ່ມີສິດອະນຸຍາດໃນການແກ້ໄຂລາຍການພົດຈະນານຸກົມ."

#: weblate/auth/permissions.py:208
msgid "You do not have permission to add glossary entries."
msgstr "ທ່ານບໍ່ມີສິດອະນຸຍາດໃນການເພີ່ມລາຍການພົດຈະນານຸກົມ."

#: weblate/auth/permissions.py:210
msgid "You do not have permission to delete glossary entries."
msgstr "ທ່ານບໍ່ມີສິດອະນຸຍາດໃນການລຶບລາຍການພົດຈະນານຸກົມ."

#: weblate/auth/permissions.py:212
msgid "You do not have permission to upload glossary entries."
msgstr "ທ່ານບໍ່ມີສິດອະນຸຍາດໃນການອັບໂຫຼດລາຍການພົດຈະນານຸກົມ."

#: weblate/auth/permissions.py:372
msgid "Can not perform this operation without an e-mail address."
msgstr "ບໍ່ສາມາດດຳເນີນການນີ້ໄດ້ຫາກບໍ່ມີທີ່ຢູອີເມວ."

#: weblate/auth/permissions.py:380
msgid ""
"This project requires two-factor authentication; configure it in your "
"profile."
msgstr "ໂຄງການນີ້ຕ້ອງການການຢືນຢັນຕົວຕົນແບບສອງຂັ້ນຕອນ; ກະລຸນາຕັ້ງຄ່າໃນໂປຣໄຟລ໌ຂອງທ່ານ."

#: weblate/auth/permissions.py:387 weblate/templates/translate.html:191
#: weblate/templates/translate.html:263
msgid "This translation is currently locked."
msgstr "ການແປນີ້ຖືກລັອກໄວ້ໃນຂະນະນີ້."

#: weblate/auth/permissions.py:397
#: weblate/templates/snippets/component/contributor-agreement.html:12
#: weblate/templates/trans/other-row.html:26
msgid ""
"Contributing to this translation requires agreeing to its contributor "
"license agreement."
msgstr "ການປະກອບສ່ວນເຂົ້າໃນການແປນີ້ ຮຽກຮ້ອງໃຫ້ມີການຍອມຮັບຂໍ້ຕົກລົງໃບອະນຸຍາດຂອງຜູ້ປະກອບສ່ວນ."

#: weblate/auth/permissions.py:414
msgid "Sign in to save translations."
msgstr "ເຂົ້າສູ່ລະບົບເພື່ອບັນທຶກການແປ."

#: weblate/auth/permissions.py:419
msgid ""
"You do not have permission to approve translations in this restricted "
"component."
msgstr "ທ່ານບໍ່ມີສິດໃນການອະນຸມັດການແປໃນສ່ວນປະກອບທີ່ຖືກຈຳກັດນີ້."

#: weblate/auth/permissions.py:424
msgid ""
"You do not have permission to save translations in this restricted component."
msgstr "ທ່ານບໍ່ມີສິດໃນການບັນທຶກການແປໃນສ່ວນປະກອບທີ່ຖືກຈຳກັດນີ້."

#: weblate/auth/permissions.py:429
msgid "You do not have permission to approve translations."
msgstr "ທ່ານບໍ່ມີສິດໃນການອະນຸມັດການແປ."

#: weblate/auth/permissions.py:434
msgid "You do not have permission to save translations in this project."
msgstr "ທ່ານບໍ່ມີສິດໃນການບັນທຶກການແປໃນໂຄງການນີ້."

#: weblate/auth/permissions.py:443 weblate/auth/permissions.py:922
msgid "You do not have permission to edit source strings."
msgstr "ທ່ານບໍ່ມີສິດໃນການແກ້ໄຂຂໍ້ຄວາມຕົ້ນສະບັບ."

#: weblate/auth/permissions.py:447
msgid "Suggestion voting is disabled."
msgstr "ການລົງຄະແນນສຽງໃຫ້ຄຳແນະນຳຖືກປິດໃຊ້ງານ."

#: weblate/auth/permissions.py:457
msgid ""
"This translation is configured for suggestion voting. Add a suggestion "
"instead of saving a direct translation."
msgstr ""
"ການແປນີ້ຖືກຕັ້ງຄ່າໄວ້ສຳລັບການລົງຄະແນນສຽງໃຫ້ຄຳແນະນຳ. "
"ກະລຸນາເພີ່ມຄຳແນະນຳແທນການບັນທຶກການແປໂດຍກົງ."

#: weblate/auth/permissions.py:463
#: weblate/templates/snippets/project/state.html:4
msgid "Pay the bills to unlock this project."
msgstr "ຊຳລະຄ່າບໍລິການເພື່ອປົດລັອກໂຄງການນີ້."

#: weblate/auth/permissions.py:493 weblate/auth/permissions.py:558
msgid "The translation is read-only."
msgstr "ການແປນີ້ແມ່ນໃຫ້ອ່ານໄດ້ຢ່າງດຽວ."

#: weblate/auth/permissions.py:496
msgid "Source-string reviews are turned off."
msgstr "ການກວດສອບຂໍ້ຄວາມຕົ້ນສະບັບຖືກປິດໄວ້."

#: weblate/auth/permissions.py:497
msgid "Translation reviews are turned off."
msgstr "ການກວດສອບການແປຖືກປິດໄວ້."

#: weblate/auth/permissions.py:509
msgid "Reviewing is turned off."
msgstr "ການກວດສອບຖືກປິດໄວ້."

#: weblate/auth/permissions.py:536 weblate/templates/translate.html:172
msgid "The source string needs review."
msgstr "ຂໍ້ຄວາມຕົ້ນສະບັບຕ້ອງການການກວດສອບ."

#: weblate/auth/permissions.py:537
msgid "The string is read-only."
msgstr "ຂໍ້ຄວາມນີ້ແມ່ນໃຫ້ອ່ານໄດ້ຢ່າງດຽວ."

#: weblate/auth/permissions.py:547
msgid ""
"Only reviewers can change approved strings. Please add a suggestion if you "
"think the string should be changed."
msgstr ""
"ສະເພາະຜູ້ກວດສອບເທົ່ານັ້ນທີ່ສາມາດປ່ຽນແປງຂໍ້ຄວາມທີ່ອະນຸມັດແລ້ວ. ກະລຸນາເພີ່ມຄຳແນະນຳ "
"ຖ້າທ່ານຄິດວ່າຂໍ້ຄວາມຄວນຖືກປ່ຽນແປງ."

#: weblate/auth/permissions.py:580
msgid "Add the string to the source language instead."
msgstr "ໃຫ້ເພີ່ມຂໍ້ຄວາມລົງໃນພາສາຕົ້ນສະບັບແທນ."

#: weblate/auth/permissions.py:584
msgid "Adding strings is disabled in the component configuration."
msgstr "ການເພີ່ມຂໍ້ຄວາມຖືກປິດໃຊ້ງານໃນການຕັ້ງຄ່າສ່ວນປະກອບ."

#: weblate/auth/permissions.py:601
msgid ""
"Cannot remove terminology translation. Remove the source string instead."
msgstr "ບໍ່ສາມາດລຶບການແປຄຳສັບສະເພາະໄດ້. ໃຫ້ລຶບຂໍ້ຄວາມຕົ້ນສະບັບແທນ."

#: weblate/auth/permissions.py:613 weblate/auth/permissions.py:632
msgid "The file format does not support this."
msgstr "ຮູບແບບໄຟລ໌ບໍ່ຮອງຮັບສິ່ງນີ້."

#: weblate/auth/permissions.py:651
msgid "Adding new translations is turned off in the component configuration."
msgstr "ການເພີ່ມການແປໃໝ່ຖືກປິດໄວ້ໃນການຕັ້ງຄ່າສ່ວນປະກອບ."

#: weblate/auth/permissions.py:655
msgid "This component is currently locked."
msgstr "ສ່ວນປະກອບນີ້ຖືກລັອກໄວ້ໃນຂະນະນີ້."

#: weblate/auth/permissions.py:930
msgid "The file format does not support updating source strings."
msgstr "ຮູບແບບໄຟລ໌ບໍ່ຮອງຮັບການອັບເດດຂໍ້ຄວາມຕົ້ນສະບັບ."

#: weblate/auth/permissions.py:1103
msgid ""
"Create the component and grant yourself explicit access before enabling "
"restricted access."
msgstr "ສ້າງສ່ວນປະກອບ ແລະ ອະນຸຍາດໃຫ້ຕົນເອງເຂົ້າເຖິງໄດ້ກ່ອນທີ່ຈະເປີດໃຊ້ງານການເຂົ້າເຖິງແບບຈຳກັດ."

#: weblate/auth/permissions.py:1108
msgid "The billing plan does not allow private access control."
