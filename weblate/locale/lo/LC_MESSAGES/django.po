#: weblate/trans/forms.py:866
msgid "Conflict handling"
msgstr "ການຈັດການຄວາມຂັດແຍ້ງ"

#: weblate/trans/forms.py:868
msgid ""
"Whether to overwrite existing translations if the string is already "
"translated."
msgstr "ກຳນົດວ່າຈະຂຽນທັບການແປທີ່ມີຢູ່ແລ້ວຫຼືບໍ່ ຖ້າຂໍ້ຄວາມນັ້ນຖືກແປແລ້ວ."

#: weblate/trans/forms.py:872
msgid "Change only untranslated strings"
msgstr "ປ່ຽນແປງສະເພາະຂໍ້ຄວາມທີ່ຍັງບໍ່ໄດ້ແປ"

#: weblate/trans/forms.py:873
msgid "Change translated strings"
msgstr "ປ່ຽນແປງຂໍ້ຄວາມທີ່ແປແລ້ວ"

#: weblate/trans/forms.py:876
