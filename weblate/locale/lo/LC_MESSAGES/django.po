#: weblate/api/views.py:387 weblate/trans/views/edit.py:101
msgid ""
"Could not remove the string because another background operation is in "
"progress. Please try again later."
msgstr ""
"ບໍ່ສາມາດລຶບຂໍ້ຄວາມໄດ້ເນື່ອງຈາກມີການດຳເນີນການອື່ນໃນພື້ນຫຼັງກຳລັງເຮັດວຽກຢູ່. ກະລຸນາລອງໃໝ່ພາຍຫຼັງ."

#: weblate/api/views.py:393
msgid "Could not obtain the lock to perform the operation."
msgstr "ບໍ່ສາມາດໄດ້ຮັບສິດລັອກ (lock) ເພື່ອດຳເນີນການ."

#: weblate/api/views.py:399
msgid "Specified unit id is not a translation source unit."
msgstr "Unit id ທີ່ລະບຸບໍ່ແມ່ນ unit ຕົ້ນສະບັບຂອງການແປ."

#: weblate/api/views.py:410
#, python-format
msgid "Could not obtain the repository lock for %s to perform the operation."
msgstr "ບໍ່ສາມາດໄດ້ຮັບສິດລັອກຄັງເກັບລະຫັດສຳລັບ %s ເພື່ອດຳເນີນການ."

#: weblate/api/views.py:418
#, python-format
msgid ""
"Could not obtain the update lock for component %s to perform the operation."
msgstr "ບໍ່ສາມາດໄດ້ຮັບສິດລັອກການອັບເດດສຳລັບສ່ວນປະກອບ %s ເພື່ອດຳເນີນການ."

#: weblate/api/views.py:425
#, python-format
msgid ""
"Could not obtain the %(scope)s lock for %(origin)s to perform the operation."
msgstr "ບໍ່ສາມາດໄດ້ຮັບສິດລັອກ %(scope)s ສຳລັບ %(origin)s ເພື່ອດຳເນີນການ."

