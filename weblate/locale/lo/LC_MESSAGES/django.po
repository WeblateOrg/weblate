#: weblate/utils/validators.py:276
msgid "This username cannot be registered. Please choose a different one."
msgstr "ຊື່ຜູ້ໃຊ້ນີ້ບໍ່ສາມາດລົງທະບຽນໄດ້. ກະລຸນາເລືອກຊື່ອື່ນ."

#: weblate/utils/validators.py:282 weblate/utils/validators.py:290
msgid "Enter a valid e-mail address."
msgstr "ກະລຸນາປ້ອນທີ່ຢູ່ວີເມລທີ່ຖືກຕ້ອງ."

#: weblate/utils/validators.py:292
msgid "This e-mail address is disallowed."
msgstr "ທີ່ຢູ່ວີເມລນີ້ບໍ່ໄດ້ຮັບອະນຸຍາດ."

#: weblate/utils/validators.py:297
msgid "Invalid e-mail address: {}"
msgstr "ທີ່ຢູ່ວີເມລບໍ່ຖືກຕ້ອງ: {}"

#: weblate/utils/validators.py:304
msgid "Disposable e-mail domains are disallowed."
msgstr "ບໍ່ອະນຸຍາດໃຫ້ໃຊ້ໂດເມນອີເມລແບບໃຊ້ແລ້ວຖິ້ມ."

#: weblate/utils/validators.py:315
msgid "Could not evaluate plural formula: {}"
msgstr "ບໍ່ສາມາດປະເມີນສູດພຫຸພົດໄດ້: {}"

#: weblate/utils/validators.py:341
#, python-brace-format
msgid "Could not evaluate plural formula for count {count}: {error}"
msgstr "ບໍ່ສາມາດປະເມີນສູດພຫຸພົດສຳລັບຈຳນວນ {count}: {error}"

#: weblate/utils/validators.py:347
#, python-brace-format
msgid ""
"Plural formula result {result} for count {count} is outside the allowed "
"range 0..{max}."
msgstr "ຜົນຂອງສູດພຫຸພົດ {result} ສຳລັບຈຳນວນ {count} ຢູ່ນອກຂອບເຂດທີ່ອະນຸຍາດ 0..{max}."

#: weblate/utils/validators.py:356
msgid "The filename can not contain reference to a parent directory."
msgstr "ຊື່ໄຟລ໌ບໍ່ສາມາດມີການອ້າງອີງເຖິງໄດເຣັກທໍຣີຫຼັກ (Parent directory) ໄດ້."

#: weblate/utils/validators.py:359
msgid "The filename can not be an absolute path."
msgstr "ຊື່ໄຟລ໌ບໍ່ສາມາດເປັນທີ່ຢູ່ໄຟລ໌ແບບເຕັມ (Absolute path) ໄດ້."

#: weblate/utils/validators.py:365
msgid "The filename should be as simple as possible. Maybe you want to use: {}"
msgstr "ຊື່ໄຟລ໌ຄວນຈະງ່າຍທີ່ສຸດເທົ່າທີ່ຈະເປັນໄປໄດ້. ບາງທີທ່ານອາດຈະຕ້ອງການໃຊ້: {}"

#: weblate/utils/validators.py:370
msgid "The filename contains a prohibited folder."
msgstr "ຊື່ໄຟລ໌ມີຊື່ໂຟນເດີທີ່ຕ້ອງຫ້າມ."

#: weblate/utils/validators.py:384
msgid "No archive can be specified in backup location."
msgstr "ບໍ່ສາມາດລະບຸໄຟລ໌ບີບອັດ (Archive) ໃນບ່ອນເກັບການສຳຮອງຂໍ້ມູນໄດ້."

#: weblate/utils/validators.py:390 weblate/utils/validators.py:398
msgid "Backup location has to be an absolute path."
msgstr "ບ່ອນເກັບການສຳຮອງຂໍ້ມູນຕ້ອງເປັນທີ່ຢູ່ໄຟລ໌ແບບເຕັມ."

#: weblate/utils/validators.py:405
msgid "Backup location should be outside Weblate backups in DATA_DIR."
msgstr "ບ່ອນເກັບການສຳຮອງຂໍ້ມູນຄວນຢູ່ຂ້າງນອກ Weblate backups ໃນ DATA_DIR."

#: weblate/utils/validators.py:414 weblate/utils/validators.py:431
msgid "This name is prohibited"
msgstr "ຊື່ນີ້ຖືກຕ້ອງຫ້າມ"

#: weblate/utils/validators.py:423
msgid "Syntax error in language aliases."
msgstr "ມີຂໍ້ຜິດພາດທາງໄວຍາກອນໃນພາສາສຳຮອງ (Language aliases)."

#: weblate/utils/validators.py:472
msgid "This URL is prohibited because it matches a restricted pattern."
msgstr "URL ນີ້ຖືກຫ້າມເນື່ອງຈາກມັນກົງກັບຮູບແບບທີ່ຖືກຈຳກັດ."

#: weblate/utils/validators.py:483
msgid "This URL is prohibited because it uses a restricted host."
msgstr "URL ນີ້ຖືກຫ້າມເນື່ອງຈາກມັນໃຊ້ໂຮສ (Host) ທີ່ຖືກຈຳກັດ."

#: weblate/utils/validators.py:494
msgid "This URL is prohibited because it uses a numeric IP address."
msgstr "URL ນີ້ຖືກຫ້າມເນື່ອງຈາກມັນໃຊ້ທີ່ຢູ່ IP ແບບຕົວເລກ."

#: weblate/utils/validators.py:511
msgid "Invalid base64 encoded string"
msgstr "ຂໍ້ຄວາມທີ່ເຂົ້າລະຫັດ base64 ບໍ່ຖືກຕ້ອງ"

#: weblate/utils/validators.py:514
msgid "The provided secret is too short."
msgstr "ລະຫັດລັບ (Secret) ທີ່ລະບຸສັ້ນເກີນໄປ."

#: weblate/utils/validators.py:516
msgid "The provided secret is too long."
msgstr "ລະຫັດລັບ (Secret) ທີ່ລະບຸຍາວເກີນໄປ."

#: weblate/utils/validators.py:532
msgid "This website cannot be used. Please provide a different one."
msgstr "ເວັບໄຊນີ້ບໍ່ສາມາດໃຊ້ໄດ້. ກະລຸນາລະບຸເວັບໄຊອື່ນ."

#: weblate/utils/validators.py:666 weblate/utils/validators.py:680
msgid "Profile URL cannot include username or password credentials."
msgstr "URL ຂອງໂປຣໄຟລ໌ບໍ່ສາມາດລວມເອົາຊື່ຜູ້ໃຊ້ ຫຼື ລະຫັດຜ່ານໄດ້."

#: weblate/utils/validators.py:669 weblate/utils/validators.py:683
msgid ""
"Profile URL should link to a profile page, not directly to a file download."
msgstr "URL ຂອງໂປຣໄຟລ໌ຄວນເຊື່ອມຕໍ່ໄປຍັງໜ້າໂປຣໄຟລ໌, ບໍ່ແມ່ນລິ້ງດາວໂຫຼດໄຟລ໌ໂດຍກົງ."

#: weblate/utils/validators.py:711
msgid ""
"Code site URL should link to a user profile or repository page on a code-"
"hosting site."
msgstr "URL ຂອງເວັບໄຊຝາກໂຄ້ດຄວນເຊື່ອມຕໍ່ໄປຍັງໂປຣໄຟລ໌ຜູ້ໃຊ້ ຫຼື ໜ້າຄັງເກັບໂຄ້ດ."

#: weblate/utils/validators.py:722
msgid "Contact URL cannot include username or password credentials."
msgstr "URL ການຕິດຕໍ່ບໍ່ສາມາດລວມເອົາຊື່ຜູ້ໃຊ້ ຫຼື ລະຫັດຜ່ານໄດ້."

#: weblate/utils/validators.py:725
msgid ""
"Contact URL should link to a contact or profile page, not directly to a file "
"download."
msgstr "URL ການຕິດຕໍ່ຄວນເຊື່ອມຕໍ່ໄປຍັງໜ້າຕິດຕໍ່ ຫຼື ໂປຣໄຟລ໌, ບໍ່ແມ່ນລິ້ງດາວໂຫຼດໄຟລ໌ໂດຍກົງ."

#: weblate/utils/validators.py:768
msgid "Fediverse URL should link to a Fediverse user profile."
msgstr "URL ຂອງ Fediverse ຄວນເຊື່ອມຕໍ່ໄປຍັງໂປຣໄຟລ໌ຜູ້ໃຊ້ຂອງ Fediverse."

#: weblate/utils/validators.py:777
msgid "URL domain is not allowed."
msgstr "ໂດເມນຂອງ URL ບໍ່ໄດ້ຮັບອະນຸຍາດ."

#: weblate/utils/validators.py:907 weblate/utils/validators.py:926
#, python-format
msgid "Fetching VCS repository using %s is not allowed."
msgstr "ບໍ່ອະນຸຍາດໃຫ້ດຶງຂໍ້ມູນຄັງເກັບ VCS ໂດຍໃຊ້ %s."

#: weblate/utils/validators.py:916
msgid "Could not parse URL: {}"
msgstr "ບໍ່ສາມາດອ່ານວິເຄາະ URL ໄດ້: {}"

#: weblate/utils/validators.py:947
#, python-format
msgid "Fetching VCS repository from %s is not allowed."
msgstr "ບໍ່ອະນຸຍາດໃຫ້ດຶງຂໍ້ມູນຄັງເກັບ VCS ຈາກ %s."

#: weblate/utils/validators.py:977
msgid "Enter a valid domain name or IP address."
msgstr "ກະລຸນາປ້ອນຊື່ໂດເມນ ຫຼື ທີ່ຢູ່ IP ທີ່ຖືກຕ້ອງ."

#: weblate/utils/views.py:230 weblate/utils/views.py:264
msgid "Position and priority"
msgstr "ຕຳແໜ່ງ ແລະ ບຸລິມະສິດ"

#: weblate/utils/views.py:231
msgid "Position"
msgstr "ຕຳແໜ່ງ"

#: weblate/utils/views.py:238
msgid "Number of words"
msgstr "ຈຳນວນຄຳສັບ"

#: weblate/utils/views.py:239
msgid "Number of comments"
msgstr "ຈຳນວນຄຳເຫັນ"

#: weblate/utils/views.py:240
msgid "Number of failing checks"
msgstr "ຈຳນວນການກວດສອບທີ່ບໍ່ຜ່ານ"

#: weblate/utils/views.py:242
msgid "String location"
msgstr "ຕຳແໜ່ງຂອງຂໍ້ຄວາມ"

#: weblate/utils/views.py:243
msgid "Component and priority"
msgstr "ສ່ວນປະກອບ ແລະ ບຸລິມະສິດ"

#: weblate/utils/zip.py:55 weblate/utils/zip.py:149
#, python-brace-format
msgid "ZIP file contains invalid path: {path}"
msgstr "ໄຟລ໌ ZIP ມີທີ່ຢູ່ໄຟລ໌ (Path) ທີ່ບໍ່ຖືກຕ້ອງ: {path}"

#: weblate/utils/zip.py:63
msgid "ZIP file contains unsupported symbolic links."
msgstr "ໄຟລ໌ ZIP ມີລິ້ງສັນຍະລັກ (Symbolic links) ທີ່ບໍ່ຮອງຮັບ."

#: weblate/utils/zip.py:67 weblate/utils/zip.py:71
msgid "ZIP file contains unsupported special files."
msgstr "ໄຟລ໌ ZIP ມີໄຟລ໌ພິເສດທີ່ບໍ່ຮອງຮັບ."

#: weblate/utils/zip.py:85
msgid "The ZIP file contains too many entries."
msgstr "ໄຟລ໌ ZIP ມີຈຳນວນລາຍການຫຼາຍເກີນໄປ."

#: weblate/utils/zip.py:95
msgid ""
"The zip file contains duplicate files. Please generate a new backup with a "
"newer version of Weblate."
msgstr "ໄຟລ໌ ZIP ມີໄຟລ໌ທີ່ຊ້ຳກັນ. ກະລຸນາສ້າງໄຟລ໌ສຳຮອງໃໝ່ດ້ວຍ Weblate ເວີຊັນທີ່ໃໝ່ກວ່າ."

#: weblate/utils/zip.py:116
#, python-format
msgid ""
"The ZIP file contains %(actual_size)s of data after unpacking, exceeding the "
"configured limit of %(limit_size)s."
msgstr ""
"ໄຟລ໌ ZIP ມີຂໍ້ມູນ %(actual_size)s ຫຼັງຈາກແຕກໄຟລ໌, ເຊິ່ງເກີນຂີດຈຳກັດ %(limit_size)s ທີ່ຕັ້ງໄວ້."

#: weblate/utils/zip.py:134
msgid "The ZIP file contains a compressed entry that is too large."
msgstr "ໄຟລ໌ ZIP ມີລາຍການທີ່ຖືກບີບອັດທີ່ມີຂະໜາດໃຫຍ່ເກີນໄປ."

#: weblate/vcs/base.py:324
msgid "This will push changes to the upstream repository."
msgstr "ນີ້ຈະທຳການ Push ການປ່ຽນແປງໄປຍັງຄັງເກັບ (Repository) ຕົ້ນທາງ."

#: weblate/vcs/forms.py:30 weblate/vcs/forms.py:42 weblate/vcs/views.py:1103
msgid "Enter a valid GitHub host."
msgstr "ກະລຸນາປ້ອນ GitHub host ທີ່ຖືກຕ້ອງ."

#: weblate/vcs/forms.py:63
msgid ""
"Use github.com for GitHub.com, or the web hostname for GitHub Enterprise "
"Server."
msgstr ""
"ໃຊ້ github.com ສຳລັບ GitHub.com, ຫຼື ໃຊ້ hostname ຂອງເວັບສຳລັບ GitHub Enterprise "
"Server."

#: weblate/vcs/forms.py:69
msgid "Organization (optional)"
msgstr "ອົງກອນ (ເລືອກໄດ້)"

#: weblate/vcs/forms.py:72
msgid ""
"Enter a GitHub organization slug to register the App under that organization "
"instead of your personal account."
msgstr ""
"ປ້ອນ slug ຂອງອົງກອນໃນ GitHub ເພື່ອລົງທະບຽນ App ພາຍໃຕ້ອົງກອນນັ້ນແທນບັນຊີສ່ວນຕົວຂອງທ່ານ."

#: weblate/vcs/forms.py:78
msgid "Leave blank to register on your personal account"
msgstr "ປະວ່າງໄວ້ເພື່ອລົງທະບຽນໃນບັນຊີສ່ວນຕົວຂອງທ່ານ"

#: weblate/vcs/forms.py:86
#, python-format
msgid ""
"GitHub App names must be unique and at most %(limit)s characters. You will "
"still be able to change the name on GitHub before confirming."
msgstr ""
"ຊື່ GitHub App ຕ້ອງບໍ່ຊ້ຳໃຜ ແລະ ຍາວບໍ່ເກີນ %(limit)s ຕົວອັກສອນ. ທ່ານຍັງສາມາດປ່ຽນຊື່ໃນ GitHub "
"ໄດ້ກ່ອນທີ່ຈະຢືນຢັນ."

#: weblate/vcs/forms.py:93
msgid "Public (any GitHub account can install it)"
msgstr "ສາທາລະນະ (ບັນຊີ GitHub ໃດກໍສາມາດຕິດຕັ້ງໄດ້)"

#: weblate/vcs/forms.py:96
msgid ""
"Required to install the App on more than one user or organization. Public "
"here only means the App is not restricted to its owner; it does not list the "
"App on the GitHub Marketplace."
msgstr ""
"ຈຳເປັນຕ້ອງໃຊ້ເພື່ອຕິດຕັ້ງ App ໃນຜູ້ໃຊ້ ຫຼື ອົງກອນຫຼາຍກວ່າໜຶ່ງບ່ອນ. \"ສາທາລະນະ\" ໃນທີ່ນີ້ໝາຍເຖິງ App "
"ບໍ່ໄດ້ຖືກຈຳກັດໄວ້ສະເພາະເຈົ້າຂອງເທົ່ານັ້ນ; ມັນບໍ່ໄດ້ໝາຍເຖິງການເອົາ App ໄປສະແດງໃນ GitHub "
"Marketplace."

#: weblate/vcs/git.py:126 weblate/vcs/git.py:1785
#, python-format
msgid "%(message)s Please retry later."
msgstr "%(message)s ກະລຸນາລອງໃໝ່ພາຍຫຼັງ."

#: weblate/vcs/git.py:174
msgid "This will push changes to the upstream Git repository."
msgstr "ນີ້ຈະທຳການ Push ການປ່ຽນແປງໄປຍັງຄັງເກັບ Git ຕົ້ນທາງ."

#: weblate/vcs/git.py:323
#, python-format
msgid "Repository has an interrupted Git %(operation)s operation."
msgstr "ຄັງເກັບມີການດຳເນີນການ Git %(operation)s ທີ່ຖືກຂັດຈັງຫວະ."

#: weblate/vcs/git.py:343
#, python-format
msgid "Unsupported interrupted Git operation: %(operation)s"
msgstr "ບໍ່ຮອງຮັບການດຳເນີນການ Git ທີ່ຖືກຂັດຈັງຫວະ: %(operation)s"

#: weblate/vcs/git.py:357
#, python-format
msgid "Could not recover interrupted Git %(operation)s operation."
msgstr "ບໍ່ສາມາດກູ້ຄືນການດຳເນີນການ Git %(operation)s ທີ່ຖືກຂັດຈັງຫວະໄດ້."

#: weblate/vcs/git.py:526
msgid ""
"Remote branch could not be verified against the shallow existing repository."
