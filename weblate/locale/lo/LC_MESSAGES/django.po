#: weblate/trans/models/project.py:89
msgid "Only include approved translations"
msgstr "ລວມເອົາສະເພາະການແປທີ່ຖືກອະນຸມັດແລ້ວ"

#: weblate/trans/models/project.py:232
msgid "Protected"
msgstr "ຖືກປົກປ້ອງ"

#: weblate/trans/models/project.py:234
msgid "Custom"
msgstr "ກຳນົດເອງ"

#: weblate/trans/models/project.py:254
msgid "Main website of translated project."
msgstr "ເວັບໄຊຫຼັກຂອງໂຄງການທີ່ຖືກແປ."

#: weblate/trans/models/project.py:258
msgid "Translation instructions"
msgstr "ຄຳແນະນຳການແປ"

#: weblate/trans/models/project.py:270
msgid "Workspace this project belongs to. Standalone projects do not need one."
msgstr "ພື້ນທີ່ເຮັດວຽກທີ່ໂຄງການນີ້ຂຶ້ນກັບ. ໂຄງການແບບເອກະລາດບໍ່ຈຳເປັນຕ້ອງມີ."

#: weblate/trans/models/project.py:275
msgid "Use shared translation memory"
msgstr "ໃຊ້ຄວາມຈຳການແປທີ່ແບ່ງປັນກັນ"

