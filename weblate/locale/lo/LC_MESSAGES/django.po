#: weblate/templates/js/git-status.html:66
#, python-format
msgid "(%(count)s missing in the push branch)"
msgid_plural "(%(count)s missing in the push branch)"
msgstr[0] "(ຂາດ %(count)s ລາຍການໃນບຣານຊ໌ທີ່ພຸຊໄປ)"

#: weblate/templates/js/git-status.html:105
#, python-format
msgid "%(count)s missing commit"
msgid_plural "%(count)s missing commits"
msgstr[0] "%(count)s ຄອມມິດທີ່ຂາດໄປ"

#: weblate/templates/js/git-status.html:107
msgid "This will update the Weblate repository with the upstream changes."
msgstr "ສິ່ງນີ້ຈະອັບເດດຄັງເກັບ Weblate ດ້ວຍການປ່ຽນແປງຈາກອັບສະຕຣີມ."

#: weblate/templates/js/git-status.html:116
msgid "Allow changes to the Weblate repository"
msgstr "ອະນຸຍາດໃຫ້ມີການປ່ຽນແປງໃນຄັງເກັບ Weblate"

#: weblate/templates/js/git-status.html:116
#: weblate/templates/snippets/component/lock.html:13
msgid "Unlock"
msgstr "ປົດລັອກ"

#: weblate/templates/js/git-status.html:122
msgid "Prevent any changes in the Weblate repository"
msgstr "ປ້ອງກັນບໍ່ໃຫ້ມີການປ່ຽນແປງໃດໆໃນຄັງເກັບ Weblate"

#: weblate/templates/js/git-status.html:122
msgid "Lock"
msgstr "ລັອກ"

#: weblate/templates/js/git-status.html:128
#, python-format
msgid "%(count)s component is locked"
msgid_plural "%(count)s components are locked"
msgstr[0] "%(count)s ອົງປະກອບຖືກລັອກຢູ່"

#: weblate/templates/js/git-status.html:132 weblate/utils/html.py:434
msgctxt "Joins a list of values"
msgid ", "
msgstr ", "

#: weblate/templates/js/git-status.html:134
#, python-format
msgid "%(count)s component is unlocked"
msgid_plural "%(count)s components are unlocked"
msgstr[0] "%(count)s ອົງປະກອບຖືກປົດລັອກແລ້ວ"

#: weblate/templates/js/git-status.html:137
#: weblate/templates/js/git-status.html:142
msgid "Weblate translations are unlocked"
msgstr "ຄຳແປໃນ Weblate ຖືກປົດລັອກແລ້ວ"

#: weblate/templates/js/git-status.html:140
msgid "Weblate translations are locked"
msgstr "ຄຳແປໃນ Weblate ຖືກລັອກຢູ່"

#: weblate/templates/js/git-status.html:145
msgid "Locking prevents translators from doing changes."
msgstr "ການລັອກຈະປ້ອງກັນບໍ່ໃຫ້ຜູ້ແປເຮັດການປ່ຽນແປງໃດໆ."

#: weblate/templates/js/git-status.html:156
msgid "Danger zone"
msgstr "ເຂດອັນຕະລາຍ"

#: weblate/templates/js/git-status.html:163
msgid "Reset and discard"
msgstr "ຣີເຊັດ ແລະ ຖິ້ມທັງໝົດ"

#: weblate/templates/js/git-status.html:166
msgid ""
"Resets Weblate’s repository to match upstream and discards any pending "
"changes in Weblate."
msgstr ""
"ຣີເຊັດຄັງເກັບຂອງ Weblate ໃຫ້ກົງກັບອັບສະຕຣີມ ແລະ ຖິ້ມການປ່ຽນແປງໃດໆທີ່ຍັງຄ້າງຢູ່ໃນ Weblate."

#: weblate/templates/js/git-status.html:167
msgid "Use when you want the upstream to be the authority for translations."
msgstr "ໃຊ້ເມື່ອທ່ານຕ້ອງການໃຫ້ອັບສະຕຣີມເປັນບ່ອນອ້າງອີງຫຼັກສຳລັບຄຳແປ."

#: weblate/templates/js/git-status.html:168
msgid ""
"It will discard changes in Weblate repo and bring it in sync with the "
"upstream repository."
msgstr "ມັນຈະຖິ້ມການປ່ຽນແປງໃນຄັງເກັບ Weblate ແລະ ເຮັດໃຫ້ມັນຊິງຄ໌ກັບຄັງເກັບອັບສະຕຣີມ."

#: weblate/templates/js/git-status.html:175
msgid "Reset and reapply"
msgstr "ຣີເຊັດ ແລະ ນຳໃຊ້ຄືນໃໝ່"

#: weblate/templates/js/git-status.html:178
msgid ""
"Resets Weblate’s repository to match upstream and reapplies pending "
"translations onto the reset repository state."
msgstr ""
"ຣີເຊັດຄັງເກັບຂອງ Weblate ໃຫ້ກົງກັບອັບສະຕຣີມ ແລະ "
"ນຳໃຊ້ຄຳແປທີ່ຍັງຄ້າງຢູ່ຄືນໃໝ່ໃສ່ສະຖານະຄັງເກັບທີ່ຖືກຣີເຊັດແລ້ວ."

#: weblate/templates/js/git-status.html:179
msgid "Use when you want Weblate to be the authority for translations."
msgstr "ໃຊ້ເມື່ອທ່ານຕ້ອງການໃຫ້ Weblate ເປັນບ່ອນອ້າງອີງຫຼັກສຳລັບຄຳແປ."

#: weblate/templates/js/git-status.html:180
msgid ""
"Missing language files must already exist upstream or Weblate must be able "
"to create them for the component."
msgstr ""
"ໄຟລ໌ພາສາທີ່ຂາດຫາຍໄປຈະຕ້ອງມີຢູ່ໃນອັບສະຕຣີມແລ້ວ ຫຼື Weblate "
"ຈະຕ້ອງສາມາດສ້າງພວກມັນຂຶ້ນມາໃຫມ່ໄດ້ສຳລັບອົງປະກອບນັ້ນ."

#: weblate/templates/js/git-status.html:186
msgid "Cleanup"
msgstr "ລ້າງຂໍ້ມູນ"

#: weblate/templates/js/git-status.html:189
msgid ""
"Cleanup removes all files which are not tracked by the version control from "
"the repository."
msgstr "ການລ້າງຂໍ້ມູນຈະລຶບໄຟລ໌ທັງໝົດທີ່ບໍ່ໄດ້ຖືກຕິດຕາມໂດຍລະບົບຄວບຄຸມເວີຊັນອອກຈາກຄັງເກັບ."

#: weblate/templates/js/git-status.html:190
msgid "It also removes stale branches which are not used by Weblate."
msgstr "ມັນຍັງລຶບບຣານຊ໌ທີ່ເກົ່າ ແລະ ບໍ່ໄດ້ຖືກໃຊ້ໂດຍ Weblate ອອກນຳ."

#: weblate/templates/js/git-status.html:191
msgid "Use when there is some garbage left in the Weblate repository."
msgstr "ໃຊ້ເມື່ອມີໄຟລ໌ທີ່ບໍ່ຈຳເປັນເຫຼືອຄ້າງຢູ່ໃນຄັງເກັບ Weblate."

#: weblate/templates/js/git-status.html:197
msgid "Synchronize"
msgstr "ຊິງໂຄໄນຊ໌"

#: weblate/templates/js/git-status.html:200
msgid "Forces writing all strings to the translation files."
msgstr "ບັງຄັບໃຫ້ຂຽນຂໍ້ຄວາມທັງໝົດລົງໃນໄຟລ໌ແປ."

#: weblate/templates/js/git-status.html:201
msgid ""
"Use this when repository files became out of sync with Weblate for some "
"reason."
msgstr "ໃຊ້ສິ່ງນີ້ເມື່ອໄຟລ໌ໃນຄັງເກັບບໍ່ຊິງຄ໌ກັບ Weblate ຍ້ອນເຫດຜົນບາງຢ່າງ."

#: weblate/templates/js/git-status.html:207
msgid "Rescan"
msgstr "ສະແກນໃໝ່"

#: weblate/templates/js/git-status.html:210
msgid "Loads translations from the files into Weblate."
msgstr "ໂຫຼດຄຳແປຈາກໄຟລ໌ເຂົ້າສູ່ Weblate."

#: weblate/templates/js/git-status.html:211
msgid ""
"Use when Weblate missed some of the strings after updating the repository."
msgstr "ໃຊ້ເມື່ອ Weblate ຂາດຂໍ້ຄວາມບາງຢ່າງຫຼັງຈາກອັບເດດຄັງເກັບ."

#: weblate/templates/js/git-status.html:212
msgid ""
"This might discard edits that cannot be committed because of the configured "
"commit policy."
msgstr "ສິ່ງນີ້ອາດຈະຖິ້ມການແກ້ໄຂທີ່ບໍ່ສາມາດຄອມມິດໄດ້ ຍ້ອນນະໂຍບາຍການຄອມມິດທີ່ຕັ້ງຄ່າໄວ້."

#: weblate/templates/js/git-status.html:217
msgid "Use these operations with caution, they can lead to data loss."
msgstr "ໃຊ້ການດຳເນີນການເຫຼົ່ານີ້ດ້ວຍຄວາມລະມັດລະວັງ, ພວກມັນອາດນຳໄປສູ່ການສູນເສຍຂໍ້ມູນໄດ້."

#: weblate/templates/js/git-status.html:227
msgid "File management"
msgstr "ການຈັດການໄຟລ໌"

#: weblate/templates/js/git-status.html:235
msgid "Remove duplicates"
msgstr "ລຶບລາຍການທີ່ຊ້ຳກັນ"

#: weblate/templates/js/git-status.html:236
msgid "Remove duplicated strings from the translation file"
msgstr "ລຶບຂໍ້ຄວາມທີ່ຊ້ຳກັນອອກຈາກໄຟລ໌ແປ"

#: weblate/templates/js/git-status.html:238
msgid ""
"Removes repeated strings with the same identifier from the translation file."
msgstr "ລຶບຂໍ້ຄວາມທີ່ຊ້ຳກັນທີ່ມີຕົວລະບຸອັນດຽວກັນອອກຈາກໄຟລ໌ແປ."

#: weblate/templates/js/git-status.html:239
msgid ""
"Use when the translation file contains duplicate strings that are not "
"present in Weblate."
msgstr "ໃຊ້ເມື່ອໄຟລ໌ແປມີຂໍ້ຄວາມທີ່ຊ້ຳກັນ ເຊິ່ງບໍ່ມີຢູ່ໃນ Weblate."

#: weblate/templates/js/git-status.html:247
msgid "Cleanup unused"
msgstr "ລ້າງລາຍການທີ່ບໍ່ໄດ້ໃຊ້"

#: weblate/templates/js/git-status.html:248
msgid "Remove unused strings from the translation file"
msgstr "ລຶບຂໍ້ຄວາມທີ່ບໍ່ໄດ້ໃຊ້ອອກຈາກໄຟລ໌ແປ"

#: weblate/templates/js/git-status.html:250
msgid "Removes strings that are no longer present in the base file."
msgstr "ລຶບຂໍ້ຄວາມທີ່ບໍ່ມີຢູ່ໃນໄຟລ໌ຫຼັກອີກຕໍ່ໄປ."

#: weblate/templates/js/git-status.html:251
msgid "The cleanup translation files add-on can perform this automatically."
msgstr "ສ່ວນເສີມລ້າງໄຟລ໌ແປສາມາດເຮັດສິ່ງນີ້ໄດ້ໂດຍອັດຕະໂນມັດ."

#: weblate/templates/js/git-status.html:259
msgid "Remove obsolete"
msgstr "ລຶບຂໍ້ຄວາມທີ່ລ້າສະໄໝ"

#: weblate/templates/js/git-status.html:260
msgid "Remove obsolete strings from the translation file"
msgstr "ລຶບຂໍ້ຄວາມທີ່ລ້າສະໄໝອອກຈາກໄຟລ໌ແປ"

#: weblate/templates/js/git-status.html:262
msgid "Removes obsolete strings from PO files."
msgstr "ລຶບຂໍ້ຄວາມທີ່ລ້າສະໄໝອອກຈາກໄຟລ໌ PO."

#: weblate/templates/js/git-status.html:263
msgid ""
"Use when obsolete entries should be pruned without enabling automatic "
"removal on save."
msgstr "ໃຊ້ເມື່ອຕ້ອງການຕັດລາຍການທີ່ລ້າສະໄໝອອກ ໂດຍບໍ່ຕ້ອງເປີດໃຊ້ການລຶບອັດຕະໂນມັດຕອນບັນທຶກ."

#: weblate/templates/js/git-status.html:269
msgid "Use these operations with caution, they rewrite the translation file."
msgstr "ໃຊ້ການດຳເນີນການເຫຼົ່ານີ້ດ້ວຍຄວາມລະມັດລະວັງ, ພວກມັນຈະຂຽນໄຟລ໌ແປໃໝ່."

#: weblate/templates/js/git-status.html:278
#, python-format
msgid "Repository for %(component)s"
msgstr "ຄັງເກັບສຳລັບ %(component)s"

#: weblate/templates/js/git-status.html:284
msgid "Repository details"
msgstr "ລາຍລະອຽດຄັງເກັບ"

#: weblate/templates/js/git-status.html:295
msgid "Repository changes"
msgstr "ການປ່ຽນແປງຄັງເກັບ"

#: weblate/templates/js/git-status.html:300
msgid "Browse all repository changes"
msgstr "ຊອກເບິ່ງການປ່ຽນແປງທັງໝົດຂອງຄັງເກັບ"

#: weblate/templates/keyboard-shortcuts.html:22
msgid "Shortcut"
msgstr "ຄີລັດ"

#: weblate/templates/keyboard-shortcuts.html:23 weblate/trans/forms.py:4323
msgid "Action"
msgstr "ການດຳເນີນການ"

#: weblate/templates/keyboard-shortcuts.html:31
msgid "Open available keyboard shortcuts."
msgstr "ເປີດຄີລັດຄີບອດທີ່ມີໃຫ້."

