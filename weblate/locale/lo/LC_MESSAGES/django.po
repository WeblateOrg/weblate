#: weblate/addons/webhooks.py:120
msgid "Webhook"
msgstr "ເວັບຮຸກ"

#: weblate/addons/webhooks.py:122
msgid ""
"Sends notifications to external services based on selected events, following "
"the Standard Webhooks specification."
msgstr ""
