#: weblate/vcs/views.py:557 weblate/vcs/views.py:600 weblate/vcs/views.py:739
msgid "Weblate GitHub app is not configured on this Weblate instance."
msgstr "Weblate GitHub app ບໍ່ໄດ້ຖືກຕັ້ງຄ່າໃນ Weblate instance ນີ້."

#: weblate/vcs/views.py:565
msgid "Select a workspace before connecting a GitHub account."
msgstr "ເລືອກພື້ນທີ່ເຮັດວຽກກ່ອນທີ່ຈະເຊື່ອມຕໍ່ບັນຊີ GitHub."

#: weblate/vcs/views.py:575
msgid "Weblate GitHub app is not configured for the selected host."
msgstr "Weblate GitHub app ບໍ່ໄດ້ຖືກຕັ້ງຄ່າສຳລັບໂຮສທີ່ເລືອກ."

#: weblate/vcs/views.py:688 weblate/vcs/views.py:822
msgid "Connected GitHub account updated."
msgstr "ອັບເດດບັນຊີ GitHub ທີ່ເຊື່ອມຕໍ່ແລ້ວ."

#: weblate/vcs/views.py:694 weblate/vcs/views.py:714
msgid ""
"The Weblate GitHub app installation link is no longer valid. Start the "
"installation again."
msgstr "ລິ້ງການຕິດຕັ້ງ Weblate GitHub app ໃຊ້ງານບໍ່ໄດ້ແລ້ວ. ກະລຸນາເລີ່ມຕົ້ນການຕິດຕັ້ງໃໝ່."

#: weblate/vcs/views.py:722 weblate/vcs/views.py:746
msgid "You do not have permission to connect GitHub to this workspace."
msgstr "ທ່ານບໍ່ມີສິດໃນການເຊື່ອມຕໍ່ GitHub ເຂົ້າກັບພື້ນທີ່ເຮັດວຽກນີ້."

#: weblate/vcs/views.py:730
msgid "GitHub did not return a valid installation ID."
msgstr "GitHub ບໍ່ໄດ້ສົ່ງ ID ການຕິດຕັ້ງທີ່ຖືກຕ້ອງກັບມາ."

#: weblate/vcs/views.py:754
msgid ""
"Too many GitHub account connection attempts. The GitHub installation was not "
"connected and might still be pending. Try connecting the account again later."
msgstr ""
"ມີການພະຍາຍາມເຊື່ອມຕໍ່ບັນຊີ GitHub ຫຼາຍເກີນໄປ. ການຕິດຕັ້ງ GitHub ບໍ່ໄດ້ເຊື່ອມຕໍ່ ແລະ "
"ອາດຈະຍັງຄ້າງຢູ່. ກະລຸນາລອງເຊື່ອມຕໍ່ບັນຊີໃໝ່ພາຍຫຼັງ."

#: weblate/vcs/views.py:769
msgid ""
"Weblate could not confirm that you can administer this GitHub installation. "
"Start the installation again with a GitHub user who owns the account or can "
"administer the organization."
msgstr ""
"Weblate ບໍ່ສາມາດຢືນຢັນໄດ້ວ່າທ່ານສາມາດດູແລການຕິດຕັ້ງ GitHub ນີ້ໄດ້. ກະລຸນາເລີ່ມການຕິດຕັ້ງໃໝ່ດ້ວຍຜູ້ໃຊ້ "
"GitHub ທີ່ເປັນເຈົ້າຂອງບັນຊີ ຫຼື ສາມາດດູແລອົງກອນໄດ້."

#: weblate/vcs/views.py:795
msgid ""
"GitHub is still syncing the connected GitHub account. The connection is "
"pending and repositories might not appear yet. Try connecting the account "
"again later if they do not show up."
msgstr ""
"GitHub ກຳລັງຊິງຄ໌ບັນຊີ GitHub ທີ່ເຊື່ອມຕໍ່ຢູ່. ການເຊື່ອມຕໍ່ກຳລັງຄ້າງຢູ່ ແລະ "
"ຄັງເກັບຂໍ້ມູນອາດຈະຍັງບໍ່ປະກົດຂຶ້ນ. ກະລຸນາລອງເຊື່ອມຕໍ່ບັນຊີໃໝ່ພາຍຫຼັງຖ້າມັນຍັງບໍ່ສະແດງ."

#: weblate/vcs/views.py:809
msgid ""
"The connected GitHub account was saved, but refreshing the repository list "
"failed. Try again in a moment."
msgstr ""
"ບັນທຶກບັນຊີ GitHub ທີ່ເຊື່ອມຕໍ່ແລ້ວ, ແຕ່ການຣີເຟຣຊລາຍຊື່ຄັງເກັບຂໍ້ມູນບໍ່ສຳເລັດ. ກະລຸນາລອງໃໝ່ໃນຈັກບຶດ."

#: weblate/vcs/views.py:817
msgid "Connected GitHub account added."
msgstr "ເພີ່ມບັນຊີ GitHub ທີ່ເຊື່ອມຕໍ່ແລ້ວ."

#: weblate/vcs/views.py:1134
msgid "Enter a valid GitHub App name and host."
msgstr "ກະລຸນາປ້ອນຊື່ GitHub App ແລະ ໂຮສທີ່ຖືກຕ້ອງ."

#: weblate/vcs/views.py:1145
#, python-format
msgid ""
"A Weblate GitHub App is already registered for %(hostname)s. Remove it "
"before registering another one."
msgstr ""
"ມີ Weblate GitHub App ທີ່ລົງທະບຽນສຳລັບ %(hostname)s ຢູ່ແລ້ວ. "
"ກະລຸນາລຶບອອກກ່ອນທີ່ຈະລົງທະບຽນອັນໃໝ່."

#: weblate/vcs/views.py:1195
msgid "GitHub did not return a valid registration code."
msgstr "GitHub ບໍ່ໄດ້ສົ່ງລະຫັດລົງທະບຽນທີ່ຖືກຕ້ອງກັບມາ."

#: weblate/vcs/views.py:1208
msgid ""
"The GitHub App registration link is no longer valid. Start the registration "
"again."
msgstr "ລິ້ງລົງທະບຽນ GitHub App ໃຊ້ງານບໍ່ໄດ້ແລ້ວ. ກະລຸນາເລີ່ມຕົ້ນການລົງທະບຽນໃໝ່."

#: weblate/vcs/views.py:1221
msgid "GitHub rejected the registration code. Start the registration again."
msgstr "GitHub ປະຕິເສດລະຫັດລົງທະບຽນ. ກະລຸນາເລີ່ມຕົ້ນການລົງທະບຽນໃໝ່."

#: weblate/vcs/views.py:1244
msgid "GitHub returned an incomplete App registration response."
msgstr "GitHub ສົ່ງການຕອບສະໜອງການລົງທະບຽນ App ທີ່ບໍ່ຄົບຖ້ວນກັບມາ."

#: weblate/vcs/views.py:1273
msgid "Weblate GitHub App registered. You can now connect a GitHub account."
msgstr "ລົງທະບຽນ Weblate GitHub App ແລ້ວ. ຕອນນີ້ທ່ານສາມາດເຊື່ອມຕໍ່ບັນຊີ GitHub ໄດ້ແລ້ວ."

#: weblate/vcs/views.py:1279
msgid "Weblate GitHub App credentials updated."
msgstr "ອັບເດດຂໍ້ມູນປະຈຳຕົວຂອງ Weblate GitHub App ແລ້ວ."

#: weblate/wladmin/forms.py:18
msgid "Activation token"
msgstr "ໂທເຄັນການເປີດໃຊ້ງານ"

#: weblate/wladmin/forms.py:22
msgid ""
"Please enter the activation token obtained when making the subscription."
msgstr "ກະລຸນາປ້ອນໂທເຄັນການເປີດໃຊ້ງານທີ່ໄດ້ຮັບຕອນສະໝັກໃຊ້ບໍລິການ."

#: weblate/wladmin/forms.py:35
msgid "Port"
msgstr "ພອດ (Port)"

#: weblate/wladmin/forms.py:39
msgid "Keep blank for using the default SSH port."
msgstr "ປະວ່າງໄວ້ເພື່ອໃຊ້ພອດ SSH ເລີ່ມຕົ້ນ."

#: weblate/wladmin/forms.py:45
msgid ""
"Fingerprint of key to add. Keep blank to add all keys offered by the host."
msgstr "ລາຍນິ້ວມືຂອງຄີທີ່ຈະເພີ່ມ. ປະວ່າງໄວ້ເພື່ອເພີ່ມທຸກຄີທີ່ໂຮສມີໃຫ້."

#: weblate/wladmin/forms.py:59
msgid "The test e-mail will be sent to this address."
msgstr "ອີເມລທົດສອບຈະຖືກສົ່ງໄປຍັງທີ່ຢູ່ນີ້."

#: weblate/wladmin/forms.py:100
msgid "Please provide font family suitable for CSS."
msgstr "ກະລຸນາລະບຸ font family ທີ່ເໝາະສົມສຳລັບ CSS."

#: weblate/wladmin/forms.py:134
msgid "Page font"
msgstr "ຟອນຂອງໜ້າ"

#: weblate/wladmin/forms.py:135
msgid "Header font"
msgstr "ຟອນຂອງສ່ວນຫົວ"

#: weblate/wladmin/forms.py:138 weblate/wladmin/forms.py:145
msgid "Navigation color (Light, Dark)"
msgstr "ສີຂອງແຖບນຳທາງ (ສະຫວ່າງ, ມືດ)"

#: weblate/wladmin/forms.py:141
msgid "Navigation text color (Light, Dark)"
msgstr "ສີຂອງຂໍ້ຄວາມແຖບນຳທາງ (ສະຫວ່າງ, ມືດ)"

#: weblate/wladmin/forms.py:148
msgid "Focus color (Light, Dark)"
msgstr "ສີເມື່ອໂຟກັດ (ສະຫວ່າງ, ມືດ)"

#: weblate/wladmin/forms.py:151
msgid "Hover color (Light, Dark)"
msgstr "ສີເມື່ອຊີ້ເມົາສ໌ (ສະຫວ່າງ, ມືດ)"

#: weblate/wladmin/forms.py:155
msgid "Hide page footer"
msgstr "ເຊື່ອງສ່ວນທ້າຍຂອງໜ້າ"

#: weblate/wladmin/forms.py:158
msgid "Always show hamburger menu"
msgstr "ສະແດງເມນູແບບແຮມເບີເກີສະເໝີ"

#: weblate/wladmin/forms.py:161
msgid ""
"Persistent navigational drop-down menu in the top right corner, even if "
"there is room for a full menu."
msgstr ""
"ສະແດງເມນູລົງມາ (Drop-down) ທີ່ມຸມຂວາເທິງຕະຫຼອດເວລາ ເຖິງວ່າຈະມີບ່ອນພໍສຳລັບເມນູເຕັມຮູບແບບກໍຕາມ."

#. Translators: The Weblate server has no paid support by the Weblate team
#: weblate/wladmin/models.py:146
msgid "Community support"
msgstr "ການສະໜັບສະໜູນຈາກຊຸມຊົນ"

#. Translators: The Weblate server is hosted by the Weblate team
#: weblate/wladmin/models.py:148
msgid "Hosted service"
msgstr "ບໍລິການແບບໂຮສໃຫ້"

#. Translators: The Weblate server has paid support from the Weblate team
#: weblate/wladmin/models.py:150
msgid "Basic self-hosted support"
msgstr "ການສະໜັບສະໜູນພື້ນຖານແບບຕິດຕັ້ງເອງ"

#. Translators: The Weblate server has extended support from the Weblate team
#: weblate/wladmin/models.py:152
msgid "Extended self-hosted support"
msgstr "ການສະໜັບສະໜູນແບບຂະຫຍາຍແບບຕິດຕັ້ງເອງ"

#. Translators: The Weblate server has premium support from the Weblate team
#: weblate/wladmin/models.py:154
msgid "Premium self-hosted support"
msgstr "ການສະໜັບສະໜູນແບບພຣີມຽມແບບຕິດຕັ້ງເອງ"

#: weblate/wladmin/models.py:191
msgid "Unpaid subscription"
msgstr "ການສະໝັກໃຊ້ທີ່ຍັງບໍ່ໄດ້ຊຳລະເງິນ"

#: weblate/wladmin/models.py:287
msgid "Backup repository URL"
msgstr "URL ຄັງເກັບຂໍ້ມູນສຳຮອງ"

#: weblate/wladmin/models.py:289
msgid ""
"Use /path/to/repo for local backups or user@host:/path/to/repo or ssh://"
"user@host:port/path/to/backups for remote SSH backups."
msgstr ""
"ໃຊ້ /path/to/repo ສຳລັບການສຳຮອງຂໍ້ມູນພາຍໃນ ຫຼື user@host:/path/to/repo ຫຼື ssh://"
"user@host:port/path/to/backups ສຳລັບການສຳຮອງຂໍ້ມູນທາງໄກຜ່ານ SSH."

#. Translators: Backup repository operation
#: weblate/wladmin/models.py:397
msgid "Backup performed"
msgstr "ດຳເນີນການສຳຮອງຂໍ້ມູນແລ້ວ"

#. Translators: Backup repository operation
#: weblate/wladmin/models.py:399
msgid "Backup failed"
msgstr "ການສຳຮອງຂໍ້ມູນບໍ່ສຳເລັດ"

#. Translators: Backup repository operation
#: weblate/wladmin/models.py:401
msgid "Deleted the oldest backups"
msgstr "ລຶບຂໍ້ມູນສຳຮອງທີ່ເກົ່າທີ່ສຸດແລ້ວ"

#. Translators: Backup repository operation
#: weblate/wladmin/models.py:403
msgid "Cleaned up backup storage"
msgstr "ທຳຄວາມສະອາດບ່ອນເກັບຂໍ້ມູນສຳຮອງແລ້ວ"

#. Translators: Backup repository operation
#: weblate/wladmin/models.py:405
msgid "Repository initialization"
msgstr "ການເລີ່ມຕົ້ນຄັງເກັບຂໍ້ມູນ"

#: weblate/wladmin/sites.py:25 weblate/wladmin/sites.py:26
msgid "Weblate administration"
msgstr "ການດູແລລະບົບ Weblate"

#: weblate/wladmin/sites.py:96
msgid "Object listing turned off"
msgstr "ປິດການສະແດງລາຍການວັດຖຸແລ້ວ"

#: weblate/wladmin/templates/admin/base.html:7
msgid "Return to Weblate"
msgstr "ກັບຄືນສູ່ Weblate"

#. Translators: link to https://docs.weblate.org/en/latest/admin/projects.html#import-speed
#: weblate/wladmin/templates/admin/trans/change_form.html:10
msgid "Import speed documentation"
msgstr "ເອກະສານກ່ຽວກັບຄວາມໄວໃນການນຳເຂົ້າ"

#: weblate/wladmin/templates/admin/trans/change_form.html:39
msgid "Required fields are marked in bold."
msgstr "ຟີວ (Fields) ທີ່ຈຳເປັນຈະຖືກໝາຍດ້ວຍຕົວໜາ."

#: weblate/wladmin/templates/admin/trans/change_form.html:43
msgid ""
"Do not change the object here, please use the Weblate interface instead."
msgstr "ກະລຸນາຢ່າປ່ຽນແປງວັດຖຸຢູ່ທີ່ນີ້, ໃຫ້ໃຊ້ສ່ວນຕິດຕໍ່ຜູ້ໃຊ້ຂອງ Weblate ແທນ."

#: weblate/wladmin/templates/admin/weblate-index.html:11
msgid "Reports"
msgstr "ລາຍງານ"

#: weblate/wladmin/views.py:114
msgid "Weblate status"
msgstr "ສະຖານະຂອງ Weblate"

#: weblate/wladmin/views.py:178
msgid ""
"Please change SITE_TITLE in settings to make your Weblate easy to recognize "
"in Discover Weblate."
msgstr ""
"ກະລຸນາປ່ຽນ SITE_TITLE ໃນການຕັ້ງຄ່າເພື່ອໃຫ້ Weblate ຂອງທ່ານຖືກຈົດຈຳໄດ້ງ່າຍໃນ Discover "
"Weblate."

#: weblate/wladmin/views.py:248
msgid "Customer care ticket created:"
msgstr "ສ້າງທິກເກັດ (Ticket) ບໍລິການລູກຄ້າແລ້ວ:"

#: weblate/wladmin/views.py:284
msgid "Test e-mail sent."
msgstr "ສົ່ງອີເມລທົດສອບແລ້ວ."

#: weblate/wladmin/views.py:288
#, python-format
msgid "Could not send test e-mail: %s"
msgstr "ບໍ່ສາມາດສົ່ງອີເມລທົດສອບໄດ້: %s"

#: weblate/wladmin/views.py:346
msgid ""
"This installation is already linked to weblate.org. Use discovery settings "
"to manage its listing."
msgstr ""
"ການຕິດຕັ້ງນີ້ໄດ້ຖືກລິ້ງກັບ weblate.org ແລ້ວ. ໃຫ້ໃຊ້ການຕັ້ງຄ່າການຄົ້ນພົບ (Discovery) "
"ເພື່ອຈັດການການສະແດງລາຍຊື່."

#: weblate/wladmin/views.py:375
msgid "Could not activate your installation. Invalid activation state."
msgstr "ບໍ່ສາມາດເປີດໃຊ້ການຕິດຕັ້ງຂອງທ່ານໄດ້. ສະຖານະການເປີດໃຊ້ງານບໍ່ຖືກຕ້ອງ."

#: weblate/wladmin/views.py:381
msgid "Could not activate your installation. Missing activation code."
msgstr "ບໍ່ສາມາດເປີດໃຊ້ການຕິດຕັ້ງຂອງທ່ານໄດ້. ຂາດລະຫັດການເປີດໃຊ້ງານ."

#: weblate/wladmin/views.py:387
msgid "Could not activate your installation. Invalid activation code."
msgstr "ບໍ່ສາມາດເປີດໃຊ້ການຕິດຕັ້ງຂອງທ່ານໄດ້. ລະຫັດການເປີດໃຊ້ງານບໍ່ຖືກຕ້ອງ."

#: weblate/wladmin/views.py:407 weblate/wladmin/views.py:413
#: weblate/wladmin/views.py:471 weblate/wladmin/views.py:482
msgid "Could not activate your installation. Please try again later."
msgstr "ບໍ່ສາມາດເປີດໃຊ້ການຕິດຕັ້ງຂອງທ່ານໄດ້. ກະລຸນາລອງໃໝ່ພາຍຫຼັງ."

#: weblate/wladmin/views.py:426
msgid ""
"Could not activate discovery because a support package is already linked."
msgstr "ບໍ່ສາມາດເປີດໃຊ້ການຄົ້ນພົບ (Discovery) ໄດ້ ເພາະມີແພັກເກັດການຊ່ວຍເຫຼືອຖືກລິ້ງໄວ້ຢູ່ແລ້ວ."

#: weblate/wladmin/views.py:437 weblate/wladmin/views.py:511
msgid "Activation completed."
msgstr "ການເປີດໃຊ້ງານສຳເລັດແລ້ວ."

#: weblate/wladmin/views.py:477
msgid ""
"Could not activate your installation. Please ensure your activation token is "
"correct."
msgstr "ບໍ່ສາມາດເປີດໃຊ້ການຕິດຕັ້ງຂອງທ່ານໄດ້. ກະລຸນາກວດສອບວ່າໂທເຄັນການເປີດໃຊ້ງານຂອງທ່ານຖືກຕ້ອງ."

#: weblate/wladmin/views.py:487
#, python-format
msgid "Could not activate your installation: %s"
msgstr "ບໍ່ສາມາດເປີດໃຊ້ການຕິດຕັ້ງຂອງທ່ານໄດ້: %s"

#: weblate/wladmin/views.py:495
msgid ""
"The support package was unlinked locally, but Discover Weblate could not be "
"disabled on weblate.org. The site may remain listed."
msgstr ""
"ແພັກເກັດການຊ່ວຍເຫຼືອຖືກຍົກເລີກການລິ້ງໃນເຄື່ອງແລ້ວ, ແຕ່ບໍ່ສາມາດປິດ Discover Weblate ໃນ "
"weblate.org ໄດ້. ເວັບໄຊອາດຈະຍັງຄົງສະແດງຢູ່ໃນລາຍຊື່."

#: weblate/wladmin/views.py:553
