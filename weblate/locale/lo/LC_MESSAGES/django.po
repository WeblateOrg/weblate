#: weblate/trans/models/component.py:4717
msgid "Invalid link to a Weblate project, cannot link to linked repository!"
msgstr "ລິ້ງໄປຫາໂຄງການ Weblate ບໍ່ຖືກຕ້ອງ, ບໍ່ສາມາດລິ້ງໄປຫາຄັງເກັບທີ່ເຊື່ອມໂຍງແລ້ວໄດ້!"

#: weblate/trans/models/component.py:4726
msgid "Invalid link to a Weblate project, cannot link it to itself!"
msgstr "ລິ້ງໄປຫາໂຄງການ Weblate ບໍ່ຖືກຕ້ອງ, ບໍ່ສາມາດລິ້ງຫາຕົວມັນເອງໄດ້!"

#: weblate/trans/models/component.py:4744
msgid "The file mask did not match any files."
msgstr "ໜ້າກາກໄຟລ໌ບໍ່ກົງກັບໄຟລ໌ໃດໆ."

#: weblate/trans/models/component.py:4759
#, python-format
msgid ""
"There is more than one file for %(language)s language: %(filename1)s, "
"%(filename2)s Please adjust the file mask and use components for translating "
"different resources."
msgstr ""
"ມີຫຼາຍກວ່າໜຶ່ງໄຟລ໌ສຳລັບພາສາ %(language)s: %(filename1)s, %(filename2)s "
"ກະລຸນາປັບໜ້າກາກໄຟລ໌ ແລະ ໃຊ້ສ່ວນປະກອບສຳລັບການແປຊັບພະຍາກອນທີ່ແຕກຕ່າງກັນ."

#: weblate/trans/models/component.py:4777
msgid "Could not find any matching language, please check the file mask."
msgstr "ບໍ່ພົບພາສາທີ່ກົງກັນ, ກະລຸນາກວດສອບໜ້າກາກໄຟລ໌."

#: weblate/trans/models/component.py:4798
#, python-brace-format
msgid "Could not parse {file}: {error}"
msgstr "ບໍ່ສາມາດວິເຄາະ {file}: {error}"

#: weblate/trans/models/component.py:4806
#, python-format
msgid "Could not parse %d matched file."
msgid_plural "Could not parse %d matched files."
msgstr[0] "ບໍ່ສາມາດວິເຄາະ %d ໄຟລ໌ທີ່ກົງກັນໄດ້."

#: weblate/trans/models/component.py:4846
msgid ""
"You have set up Weblate to add new translation files, but did not provide a "
"base file to do that."
msgstr "ທ່ານໄດ້ຕັ້ງຄ່າ Weblate ເພື່ອເພີ່ມໄຟລ໌ການແປໃໝ່, ແຕ່ບໍ່ໄດ້ສະໜອງໄຟລ໌ພື້ນຖານເພື່ອເຮັດແນວນັ້ນ."

#: weblate/trans/models/component.py:4858
msgid "Could not parse base file for new translations:"
msgstr "ບໍ່ສາມາດວິເຄາະໄຟລ໌ພື້ນຖານສຳລັບການແປໃໝ່:"

#: weblate/trans/models/component.py:4863
msgid "Unrecognized base file for new translations."
msgstr "ບໍ່ຮູ້ຈັກຮູບແບບໄຟລ໌ພື້ນຖານສຳລັບການແປໃໝ່."

#: weblate/trans/models/component.py:4884
msgid "Adding and removing strings is not supported with this file format."
msgstr "ບໍ່ຮອງຮັບການເພີ່ມ ແລະ ລຶບຂໍ້ຄວາມດ້ວຍຮູບແບບໄຟລ໌ນີ້."

#: weblate/trans/models/component.py:4889
msgid "Editing template is not supported with this file format."
msgstr "ບໍ່ຮອງຮັບການແກ້ໄຂແມ່ແບບດ້ວຍຮູບແບບໄຟລ໌ນີ້."

#: weblate/trans/models/component.py:4895
#: weblate/trans/models/component.py:4912
msgid ""
"An intermediate language file can not be used without an editing template."
msgstr "ບໍ່ສາມາດໃຊ້ໄຟລ໌ພາສາລະຫວ່າງກາງໄດ້ໂດຍບໍ່ມີແມ່ແບບການແກ້ໄຂ."

#: weblate/trans/models/component.py:4904
msgid ""
"An intermediate language file has to be different from monolingual base "
"language file. You can probably keep it empty."
msgstr ""
"ໄຟລ໌ພາສາລະຫວ່າງກາງຕ້ອງແຕກຕ່າງຈາກໄຟລ໌ພາສາພື້ນຖານແບບພາສາພຽງຢ່າງດຽວ. "
"ທ່ານອາດຈະປະມັນວ່າງໄວ້ໄດ້."

#: weblate/trans/models/component.py:4919
msgid "Using a .pot file as base file is unsupported."
msgstr "ບໍ່ຮອງຮັບການໃຊ້ໄຟລ໌ .pot ເປັນໄຟລ໌ພື້ນຖານ."

#: weblate/trans/models/component.py:4935
#, python-format
msgid "Could not parse translation base file: %s"
msgstr "ບໍ່ສາມາດວິເຄາະໄຟລ໌ພື້ນຖານການແປ: %s"

#: weblate/trans/models/component.py:4946
#, python-brace-format
msgid "Template language ({0}) does not match source language ({1})!"
msgstr "ພາສາແມ່ແບບ ({0}) ບໍ່ກົງກັບພາສາຕົ້ນສະບັບ ({1})!"

#: weblate/trans/models/component.py:4988
#: weblate/trans/models/component.py:5027
msgid "Push URL is not used without a remote repository."
msgstr "URL ສຳລັບ Push ຈະບໍ່ຖືກໃຊ້ຫາກບໍ່ມີຄັງເກັບປາຍທາງ (Remote repository)."

#: weblate/trans/models/component.py:4993
#, python-format
msgid "Could not validate push URL: %s"
msgstr "ບໍ່ສາມາດກວດສອບຄວາມຖືກຕ້ອງຂອງ URL push: %s"

#: weblate/trans/models/component.py:5001
msgid ""
"Pull and push branches cannot be the same when using pull/merge requests and "
"not pushing to a fork."
msgstr ""
"ສາຂາ Pull ແລະ Push ບໍ່ສາມາດເປັນສາຂາດຽວກັນໄດ້ເມື່ອໃຊ້ pull/merge requests ແລະ ບໍ່ໄດ້ "
"push ໄປຍັງ fork."

#: weblate/trans/models/component.py:5007
msgid ""
"Push branch cannot be empty when using pull/merge requests and not pushing "
"to a fork."
msgstr ""
"ສາຂາ Push ບໍ່ສາມາດວ່າງເປົ່າໄດ້ເມື່ອໃຊ້ pull/merge requests ແລະ ບໍ່ໄດ້ push ໄປຍັງ fork."

#: weblate/trans/models/component.py:5022
msgid "Choose No remote repository for local: URL."
msgstr "ເລືອກ \"No remote repository\" ສຳລັບ URL ທີ່ເປັນ local:."

#: weblate/trans/models/component.py:5063
msgid ""
"Your push URL seems to miss credentials. Either provide them in the URL or "
"use SSH with key based authentication."
msgstr ""
"URL push ຂອງທ່ານເບິ່ງຄືວ່າຈະຂາດຂໍ້ມູນປະຈຳຕົວ. ກະລຸນາລະບຸມັນໃນ URL ຫຼື ໃຊ້ SSH "
"ທີ່ມີການຢືນຢັນຕົວຕົນດ້ວຍຄີ."

#: weblate/trans/models/component.py:5068
#, python-format
msgid "Could not update repository: %s"
msgstr "ບໍ່ສາມາດອັບເດດຄັງເກັບ: %s"

#: weblate/trans/models/component.py:5092
#, python-format
msgid "Invalid repository branch: %s"
msgstr "ສາຂາຄັງເກັບບໍ່ຖືກຕ້ອງ: %s"

#: weblate/trans/models/component.py:5093
#, python-format
msgid "Invalid push branch: %s"
msgstr "ສາຂາ push ບໍ່ຖືກຕ້ອງ: %s"

#: weblate/trans/models/component.py:5107
#, python-format
msgid ""
"Use %(branch)s instead of %(ref)s; Weblate and git-review add the Gerrit "
"refs automatically."
msgstr ""
"ໃຊ້ %(branch)s ແທນ %(ref)s; Weblate ແລະ git-review ຈະເພີ່ມ Gerrit refs "
"ໃຫ້ໂດຍອັດຕະໂນມັດ."

#: weblate/trans/models/component.py:5120
#, python-format
msgid ""
"The parameter '%(param)s' is not applicable for the file format '%(format)s'."
msgstr "ພາລາມິເຕີ '%(param)s' ບໍ່ສາມາດໃຊ້ໄດ້ກັບຮູບແບບໄຟລ໌ '%(format)s'."

#: weblate/trans/models/component.py:5179
msgid ""
"Please either fill in an instruction URL or use a different option for "
"adding a new language."
msgstr "ກະລຸນາປ້ອນ URL ຄຳແນະນຳ ຫຼື ໃຊ້ຕົວເລືອກອື່ນໃນການເພີ່ມພາສາໃໝ່."

#: weblate/trans/models/component.py:5201
msgid ""
"Source language can not be changed, please recreate the component instead."
msgstr "ບໍ່ສາມາດປ່ຽນແປງພາສາຕົ້ນສະບັບໄດ້, ກະລຸນາສ້າງສ່ວນປະກອບໃໝ່ແທນ."

#: weblate/trans/models/component.py:5216 weblate/trans/models/workflow.py:59
msgid "Accepting suggestions automatically only works with voting turned on."
msgstr "ການຍອມຮັບການແນະນຳໂດຍອັດຕະໂນມັດຈະເຮັດວຽກໄດ້ເມື່ອເປີດການລົງຄະແນນສຽງເທົ່ານັ້ນ."

#: weblate/trans/models/component.py:5226
msgid "To use the key filter, the file format must be monolingual."
msgstr "ເພື່ອໃຊ້ຕົວກັ່ນຕອງຄີ, ຮູບແບບໄຟລ໌ຕ້ອງເປັນແບບພາສາພຽງຢ່າງດຽວ."

#: weblate/trans/models/component.py:5285
msgid "Can not validate file matches due to invalid regular expression."
msgstr "ບໍ່ສາມາດກວດສອບຄວາມຖືກຕ້ອງຂອງໄຟລ໌ທີ່ກົງກັນໄດ້ເນື່ອງຈາກນິພົດປົກກະຕິບໍ່ຖືກຕ້ອງ."

#: weblate/trans/models/component.py:5296 weblate/utils/validators.py:132
msgid "The regular expression is too complex and took too long to evaluate."
msgstr "ນິພົດປົກກະຕິມີຄວາມຊັບຊ້ອນເກີນໄປ ແລະ ໃຊ້ເວລານານເກີນໄປໃນການປະມວນຜົນ."

#: weblate/trans/models/component.py:5880
#: weblate/trans/models/component.py:6002
msgid "Could not add new translation file."
msgstr "ບໍ່ສາມາດເພີ່ມໄຟລ໌ການແປໃໝ່ໄດ້."

#: weblate/trans/models/component.py:5887
msgid "You do not have permissions to add new translation file."
msgstr "ທ່ານບໍ່ມີສິດໃນການເພີ່ມໄຟລ໌ການແປໃໝ່."

#: weblate/trans/models/component.py:5895
#: weblate/trans/models/component.py:5903
msgid "The monolingual base language file is invalid."
msgstr "ໄຟລ໌ພາສາພື້ນຖານແບບພາສາພຽງຢ່າງດຽວບໍ່ຖືກຕ້ອງ."

#: weblate/trans/models/component.py:5908
msgid "The template for new translations is invalid."
msgstr "ແມ່ແບບສຳລັບການແປໃໝ່ບໍ່ຖືກຕ້ອງ."

#: weblate/trans/models/component.py:5974
msgid "The given language already exists."
msgstr "ພາສາທີ່ລະບຸມີຢູ່ແລ້ວ."

#: weblate/trans/models/component.py:6024
msgid "Translation file already exists!"
msgstr "ໄຟລ໌ການແປມີຢູ່ແລ້ວ!"

#: weblate/trans/models/component.py:6057
msgid "The translation will be updated in the background."
msgstr "ການແປຈະຖືກອັບເດດໃນພື້ນຫຼັງ."

