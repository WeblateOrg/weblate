msgstr "teanga xgettext"

#: weblate/addons/forms.py:286
#, fuzzy
#| msgid "Programming language passed to xgettext, for example Python or C."
msgid ""
"Programming language passed to xgettext, for example Python or C. Leave "
"blank to let xgettext guess the language from file extensions."
msgstr ""
"Teanga ríomhchlárúcháin a chuirtear ar aghaidh chuig xgettext, mar shampla "
