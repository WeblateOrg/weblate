#: weblate/addons/forms.py:300
msgid "POTFILES path"
msgstr "Cosán POTFILES"

#: weblate/addons/forms.py:304
msgid ""
"Repository-relative path to POTFILES or POTFILES.in. Entries are resolved "
"relative to the repository root. If present next to the manifest, "
"POTFILES.skip excludes listed files from extraction."
msgstr ""
"Cosán gaolmhar leis an stórlann chuig POTFILES nó POTFILES.in. Réitítear "
"iontrálacha i gcoibhneas le fréamh an stórlainne. Má tá sé i láthair in aice "
"leis an manifíse, ní dhéanann POTFILES.skip comhaid liostaithe a eastóscadh."

#: weblate/addons/forms.py:368 weblate/trans/models/component.py:5765
msgid "Invalid symbolic link in a repository."
msgstr "Nasc siombalach neamhbhailí i stórlann."

#: weblate/addons/forms.py:379
msgid "POTFILES path has to point to a file."
msgstr "Caithfidh cosán POTFILES pointeáil chuig comhad."

#: weblate/addons/forms.py:388
