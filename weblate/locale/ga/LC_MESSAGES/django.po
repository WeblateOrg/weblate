msgid "An e-mail with a confirmation link will be sent here."
msgstr "Seolfar r-phost anseo le nasc deimhnithe."

#: weblate/accounts/forms.py:734
msgid "New password"
msgstr "Pasfhocal nua"

#: weblate/accounts/forms.py:739
msgid "New password confirmation"
msgstr "Deimhniúcháin an phasfhocail nua"

#: weblate/accounts/forms.py:743 weblate/templates/accounts/profile.html:562
msgid "Regenerate API key"
msgstr "Athghin eochair API"

#: weblate/accounts/forms.py:745
msgid ""
"Leave enabled to revoke the current API key and generate a new one. This is "
"recommended if you suspect your password was compromised. Disable it to keep "
"your current API key active after changing your password."
msgstr ""
"Fág cumasaithe chun an eochair API reatha a chúlghairm agus ceann nua a "
"ghiniúint. Moltar é seo má cheapann tú gur cuireadh do phasfhocal i mbaol. "
"Díchumasaigh é chun d’eochair API reatha a choinneáil gníomhach tar éis duit "
"do phasfhocal a athrú."

#: weblate/accounts/forms.py:781
msgid "Your password has been changed."
msgstr "Athraíodh do phasfhocal."

#: weblate/accounts/forms.py:795
msgid "Current password"
msgstr "Pasfhocal reatha"

#: weblate/accounts/forms.py:796
msgid "Leave empty if you have not set a password yet."
msgstr "Fág folamh mura bhfuil pasfhocal socraithe agat fós."

#: weblate/accounts/forms.py:810
msgid "You have entered an invalid password."
msgstr "Chuir tú isteach pasfhocal neamhbhailí."

#: weblate/accounts/forms.py:823
msgid "Username or e-mail"
msgstr "Ainm úsáideora nó r-phost"

