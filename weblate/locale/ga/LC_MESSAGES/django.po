msgid "Inherit merge request message"
msgstr "Teachtaireacht iarratais chumasc a oidhreachtú"

#: weblate/trans/models/category.py:296
msgid ""
"Use the merge request message configured in the parent category or project."
msgstr ""
"Úsáid an teachtaireacht iarratais chumasc atá cumraithe sa chatagóir nó sa "
"tionscadal tuismitheora."

#: weblate/trans/models/category.py:417
msgid "Too deep nesting of categories!"
msgstr "Neadú ró-dhomhain na gcatagóirí!"

#: weblate/trans/models/category.py:422
msgid "Parent category has to be in the same project!"
msgstr "Caithfidh an chatagóir tuismitheora a bheith sa tionscadal céanna!"

#: weblate/trans/models/category.py:427
msgid "Parent category has to be different!"
msgstr "Caithfidh catagóir na dtuismitheoirí a bheith difriúil!"

#: weblate/trans/models/category.py:445
msgid "Repository path for this category already exists and is not empty."
msgstr ""
"Tá an cosán stórais don chatagóir seo ann cheana féin agus níl sé folamh."

#: weblate/trans/models/change.py:74
msgid "Component created from scratch"
msgstr "Comhpháirt cruthaithe ó thús"

#: weblate/trans/models/change.py:75
msgid "Component created as a branch"
msgstr "Comhpháirt cruthaithe mar bhrainse"

#: weblate/trans/models/change.py:76
msgid "Component created via API"
msgstr "Comhpháirt cruthaithe trí API"

#: weblate/trans/models/change.py:77
msgid "Component created from version control"
msgstr "Comhpháirt cruthaithe ó rialú leagan"

#: weblate/trans/models/change.py:78
msgid "Component created via ZIP upload"
msgstr "Comhpháirt cruthaithe trí uaslódáil ZIP"

#: weblate/trans/models/change.py:79
msgid "Component created via document upload"
msgstr "Comhpháirt cruthaithe trí uaslódáil doiciméad"

#. Translators: condensed rendering of a change action in history
#: weblate/trans/models/change.py:672
#, python-format
msgid "%(action)s at %(time)s on %(translation)s by %(user)s"
msgstr "%(action)s ag %(time)s ar %(translation)s le %(user)s"

#. Translators: condensed rendering of a change action in history
#: weblate/trans/models/change.py:682
#, python-format
msgid "%(action)s at %(time)s on %(translation)s"
msgstr "%(action)s ag %(time)s ar %(translation)s"

#: weblate/trans/models/comment.py:83
msgid "Source needs review"
msgstr "Ní mór athbhreithniú a dhéanamh ar fhoinse"

#: weblate/trans/models/component.py:201
msgid "Merge"
msgstr "Cumaisc"

#: weblate/trans/models/component.py:202
msgid "Rebase"
msgstr "sionnach"

#: weblate/trans/models/component.py:203
msgid "Merge without fast-forward"
msgstr "Cumaisc gan tapa-ar aghaidh"

#: weblate/trans/models/component.py:517
msgid ""
"Option is not available for linked repositories. Setting from linked "
"component will be used."
msgstr ""
"Níl an rogha ar fáil do stórtha nasctha. Úsáidfear socrú ón gcomhpháirt "
"nasctha."

#: weblate/trans/models/component.py:548
msgid ""
"Version control system to use to access your repository containing "
"translations. You can also choose additional integration with third party "
"providers to submit pull/merge requests."
msgstr ""
"Córas rialaithe leaganacha le húsáid chun rochtain a fháil ar do stór ina "
"bhfuil aistriúcháin. Is féidir leat comhtháthú breise le soláthraithe tríú "
"páirtí a roghnú freisin chun iarratais tarraingthe/chumaisc a chur isteach."

#: weblate/trans/models/component.py:560
msgid ""
"URL of a repository, use weblate://project/component to share it with other "
"component."
msgstr ""
"URL stórais, úsáid weblate://project/component chun é a roinnt le comhpháirt "
"eile."

#: weblate/trans/models/component.py:573
msgid "Repository push URL"
msgstr "URL bhrú stórais"

#: weblate/trans/models/component.py:576
msgid ""
"URL of a push repository, pushing is turned off if empty. When using pull/"
"merge requests, keep empty to fork the repository."
msgstr ""
"URL stórtha brú, múchtar an brú má tá sé folamh. Agus iarratais tarraingthe/"
"chumaisc in úsáid, coinnigh folamh chun an stór a fhorcáil."

#: weblate/trans/models/component.py:582
msgid "Repository browser"
msgstr "Brabhsálaí stórtha"

#: weblate/trans/models/component.py:585
msgid ""
"Link to repository browser, use {{branch}} for branch, {{filename}} and "
"{{line}} as filename and line placeholders. You might want to strip leading "
"directory by using {{filename|parentdir}}."
msgstr ""
"Nasc le brabhsálaí an taisclainne, bain úsáid as {{branch}} le haghaidh "
"brainse, {{filename}} agus {{line}} mar ainm comhaid agus sealbhóirí áite "
"líne. Seans gur mhaith leat an t-eolaire tosaigh a bhaint de trí úsáid a "
"bhaint as {{filename|parentdir}}."

#: weblate/trans/models/component.py:593
msgid "Exported repository URL"
msgstr "URL stórtha easpórtáilte"

#: weblate/trans/models/component.py:596
msgid "URL of repository where users can fetch changes from Weblate"
msgstr ""
"URL an taisclann inar féidir le húsáideoirí athruithe a fháil ó Weblate"

#: weblate/trans/models/component.py:601
msgid "Source string bug reporting address"
msgstr "Seoladh tuairiscithe fabht teaghrán foinse"

#: weblate/trans/models/component.py:603
msgid ""
"E-mail address for reports on errors in source strings. Leave empty for no e-"
"mails."
msgstr ""
"Seoladh r-phoist le haghaidh tuairiscí ar earráidí sna teaghráin foinse. Fág "
"folamh gan aon r-phoist."

#: weblate/trans/models/component.py:611
msgid "Repository branch to translate"
msgstr "Brainse stórtha le haistriú"

#: weblate/trans/models/component.py:616
msgid "Push branch"
msgstr "Brainse a bhrú"

#: weblate/trans/models/component.py:619
msgid ""
"Branch for pushing changes. Leave empty to use repository branch when "
"pushing directly to the repository. When using pull/merge requests, specify "
"a branch name different from the repository branch."
msgstr ""
"Brainse le haghaidh athruithe a bhrú. Fág folamh chun brainse an stórais a "
"úsáid agus tú ag brú go díreach chuig an stóras. Agus iarratais tarraingthe/"
"chumaisc in úsáid agat, sonraigh ainm brainse atá difriúil ó bhrainse an "
"stórais."

#: weblate/trans/models/component.py:631
msgid ""
"Path of files to translate relative to repository root, use * instead of "
"language code, for example: po/*.po or locale/*/LC_MESSAGES/django.po."
msgstr ""
"Conair na gcomhad le haistriú i gcoibhneas le fréamh an taisclainne, bain "
"úsáid as * in ionad an chóid teanga, mar shampla: po/*.po nó locale/*/"
"LC_MESSAGES/django.po."

#: weblate/trans/models/component.py:637
msgid "Screenshot file mask"
msgstr "Masc comhaid scáileáin"

#: weblate/trans/models/component.py:642
msgid ""
"Path of screenshots relative to repository root, for example: docs/"
"screenshots/*.png."
msgstr ""
"Conair na ngabhálacha scáileáin i gcoibhneas le fréamh an taisclainne, mar "
"shampla: docs/screenshots/*.png."

#: weblate/trans/models/component.py:651
msgid ""
"Filename of translation base file, containing all strings and their source "
"for monolingual translations."
msgstr ""
"Ainm comhaid an bhunchomhaid aistriúcháin, ina bhfuil gach teaghrán agus a "
"bhfoinse le haghaidh aistriúcháin aonteangacha."

#: weblate/trans/models/component.py:658
msgid "Edit base file"
msgstr "Cuir bunchomhad in eagar"

#: weblate/trans/models/component.py:661
msgid ""
"Whether users will be able to edit the base file for monolingual "
"translations."
msgstr ""
"Cé acu an mbeidh úsáideoirí in ann an bunchomhad le haghaidh aistriúcháin "
"aonteangacha a chur in eagar."

#: weblate/trans/models/component.py:670
msgid ""
"Filename of intermediate translation file. In most cases this is a "
"translation file provided by developers and is used when creating actual "
"source strings."
msgstr ""
"Ainm comhaid an chomhaid aistriúcháin idirmheánach. I bhformhór na gcásanna "
"is comhad aistriúcháin é seo a sholáthraíonn forbróirí agus a úsáidtear "
"nuair a bhíonn teaghráin fhoinse iarbhír á gcruthú."

#: weblate/trans/models/component.py:682
msgid ""
"Filename of file used for creating new translations. For gettext choose .pot "
"file."
msgstr ""
"Ainm comhaid an chomhaid a úsáidtear chun aistriúcháin nua a chruthú. Le "
"haghaidh gettext roghnaigh comhad .pot."

#: weblate/trans/models/component.py:695
msgid "File format parameters"
msgstr "Paraiméadair formáid comhaid"

#: weblate/trans/models/component.py:705
msgid "Locked component will not get any translation updates."
msgstr ""
"Ní bhfaighidh an chomhpháirt faoi ghlas aon nuashonruithe aistriúcháin."

#: weblate/trans/models/component.py:709
msgid "Do not show glossary matches"
msgstr "Ná taispeáin cluichí glosaire"

#: weblate/trans/models/component.py:711
msgid "Hides the glossary panel in the translation editor."
msgstr "Folaíonn sé an painéal gluaise san eagarthóir aistriúcháin."

#: weblate/trans/models/component.py:714
msgid "Allow translation propagation"
msgstr "Ceadaigh iomadú aistriúcháin"

#: weblate/trans/models/component.py:717
msgid ""
"Whether translation updates in other components will cause automatic "
"translation in this one"
msgstr ""
"Cibé an mbeidh nuashonruithe aistriúcháin i gcomhpháirteanna eile ina gcúis "
"le haistriúchán uathoibríoch sa cheann seo"

#: weblate/trans/models/component.py:722
msgid "Contribute to project translation memory"
msgstr "Rannchuidiú le cuimhne aistriúcháin tionscadail"

#: weblate/trans/models/component.py:725
msgid ""
"Allow this component's translations to be added to the project-level "
"translation memory."
msgstr ""
"Ceadaigh aistriúcháin an chomhpháirte seo a chur leis an gcuimhne "
"aistriúcháin ar leibhéal an tionscadail."

#: weblate/trans/models/component.py:731 weblate/trans/models/workflow.py:30
msgid "Turn on suggestions"
msgstr "Cuir moltaí ar siúl"

#: weblate/trans/models/component.py:733 weblate/trans/models/workflow.py:32
msgid "Whether to allow translation suggestions at all."
msgstr "Cibé an gceadófar moltaí aistriúcháin ar chor ar bith."

#: weblate/trans/models/component.py:737 weblate/trans/models/workflow.py:36
msgid "Suggestion voting"
msgstr "Vótáil moltaí"

#: weblate/trans/models/component.py:740 weblate/trans/models/workflow.py:39
msgid "Users can only vote for suggestions and can’t make direct translations."
msgstr ""
"Ní féidir le húsáideoirí vótáil ach le haghaidh moltaí agus ní féidir leo "
"aistriúcháin dhíreacha a dhéanamh."

#: weblate/trans/models/component.py:745 weblate/trans/models/workflow.py:44
msgid "Automatically accept suggestions"
msgstr "Glac le moltaí go huathoibríoch"

#: weblate/trans/models/component.py:748 weblate/trans/models/workflow.py:47
msgid ""
"Automatically accept suggestions with this number of votes, use 0 to turn it "
"off."
msgstr ""
"Glac le moltaí leis an líon vótaí seo go huathoibríoch, bain úsáid as 0 chun "
"é a chasadh as."

#: weblate/trans/models/component.py:763
msgid "Enforced checks"
msgstr "Seiceálacha forfheidhmithe"

#: weblate/trans/models/component.py:764
msgid "List of checks which can not be dismissed."
msgstr "Liosta seiceálacha nach féidir a dhíbhe."

#: weblate/trans/models/component.py:781
msgid "Use the translation license configured in the category or project."
msgstr ""
"Bain úsáid as an gceadúnas aistriúcháin atá cumraithe sa chatagóir nó sa "
"tionscadal."

#: weblate/trans/models/component.py:789
msgid ""
"Contributor license agreement which needs to be approved before a user can "
"translate this component."
msgstr ""
"Comhaontú ceadúnais ranníocóra a chaithfear a cheadú sular féidir le "
"húsáideoir an chomhpháirt seo a aistriú."

#: weblate/trans/models/component.py:797
msgid ""
"Use the contributor license agreement configured in the category or project."
msgstr ""
"Bain úsáid as an gcomhaontú ceadúnais rannpháirtí atá cumraithe sa chatagóir "
"nó sa tionscadal."

#: weblate/trans/models/component.py:813
msgid ""
"Use the adding new translations setting configured in the category or "
"project."
msgstr ""
"Bain úsáid as an socrú chun aistriúcháin nua a chur leis atá cumraithe sa "
"chatagóir nó sa tionscadal."

#: weblate/trans/models/component.py:831
msgid "Use the language code style configured in the category or project."
msgstr ""
"Bain úsáid as an stíl chód teanga atá cumraithe sa chatagóir nó sa "
"tionscadal."

#: weblate/trans/models/component.py:835
msgid "Manage strings"
msgstr "Bainistigh teaghráin"

#: weblate/trans/models/component.py:838
msgid ""
"Enables adding and removing strings straight from Weblate. If your strings "
"are extracted from the source code or managed externally you probably want "
"to keep it disabled."
msgstr ""
"Cumasaíonn sé teaghráin a shuimiú agus a bhaint díreach ó Weblate. Má "
"bhaintear do theaghráin ón gcód foinse nó má bhainistítear iad go seachtrach "
"is dócha gur mhaith leat é a choinneáil díchumasaithe."

#: weblate/trans/models/component.py:846
msgid "Merge style"
msgstr "Cumasc stíl"

#: weblate/trans/models/component.py:851
msgid ""
"Define whether Weblate should merge the upstream repository or rebase "
"changes onto it."
msgstr ""
"Sainmhínigh ar cheart do Weblate an stór in aghaidh an tsrutha a chumasc nó "
"na hathruithe a athbhunú air."

#: weblate/trans/models/component.py:868
msgid ""
"Use the commit message when translating configured in the category or "
"project."
msgstr ""
"Bain úsáid as an teachtaireacht tiomantais agus tú ag aistriú rud atá "
"cumraithe sa chatagóir nó sa tionscadal."

#: weblate/trans/models/component.py:884
msgid ""
"Use the commit message when adding translation configured in the category or "
"project."
msgstr ""
"Bain úsáid as an teachtaireacht tiomantais agus aistriúchán atá cumraithe sa "
"chatagóir nó sa tionscadal á chur leis."

#: weblate/trans/models/component.py:900
msgid ""
"Use the commit message when removing translation configured in the category "
"or project."
msgstr ""
"Úsáid an teachtaireacht tiomantais agus aistriúchán atá cumraithe sa "
"chatagóir nó sa tionscadal á bhaint."

#: weblate/trans/models/component.py:917
msgid ""
"Use the commit message when merging translation configured in the category "
"or project."
msgstr ""
"Bain úsáid as an teachtaireacht tiomantais agus aistriúcháin atá cumraithe "
"sa chatagóir nó sa tionscadal á gcumaisc."

#: weblate/trans/models/component.py:933
msgid ""
"Use the commit message when add-on makes a change configured in the category "
"or project."
msgstr ""
"Úsáid an teachtaireacht tiomantais nuair a dhéanann breiseán athrú atá "
"cumraithe sa chatagóir nó sa tionscadal."

#: weblate/trans/models/component.py:949
msgid "Use the merge request message configured in the category or project."
msgstr ""
"Úsáid an teachtaireacht iarratais chumasc atá cumraithe sa chatagóir nó sa "
"tionscadal."

#: weblate/trans/models/component.py:953
msgid "Push on commit"
msgstr "Brúigh ar thiomantas"

#: weblate/trans/models/component.py:956
msgid "Whether the repository should be pushed upstream on every commit."
msgstr "Ar cheart an stór a bhrú suas an sruth ar gach gealltanas."

#: weblate/trans/models/component.py:960
msgid "Age of changes to commit"
msgstr "Aois na n-athruithe le gealltanas"

#: weblate/trans/models/component.py:964
msgid ""
"Time in hours after which any pending changes will be committed to the VCS."
msgstr ""
"Am ina n-uaireanta ina dhiaidh sin beidh aon athruithe ar feitheamh geallta "
"don VCS."

#: weblate/trans/models/component.py:969
msgid "Lock on error"
msgstr "Earráid a ghlasáil"

#: weblate/trans/models/component.py:972
msgid "Whether the component should be locked on repository errors."
msgstr "Cibé ar cheart an chomhpháirt a ghlasáil ar earráidí stórtha."

#: weblate/trans/models/component.py:979
msgid "Language used for source strings in all components"
msgstr ""
"An teanga a úsáidtear le haghaidh teaghráin foinse sna comhpháirteanna go "
"léir"

#: weblate/trans/models/component.py:989
msgid ""
"Regular expression used to filter translation files when scanning for file "
"mask."
msgstr ""
"Sloinneadh rialta a úsáidtear chun comhaid aistriúcháin a scagadh nuair a "
"bhíonn masc comhaid á scanadh."

#: weblate/trans/models/component.py:994
msgid "Variants regular expression"
msgstr "Leaganacha abairt rialta"

#: weblate/trans/models/component.py:1000
msgid "Regular expression used to determine variants of a string."
msgstr "Sloinneadh rialta a úsáidtear chun malairtí teaghrán a aimsiú."

#: weblate/trans/models/component.py:1009
msgid "Components with higher priority are offered first to translators."
msgstr ""
"Déantar comhpháirteanna a bhfuil tosaíocht níos airde acu a thairiscint "
"d’aistritheoirí ar dtús."

#: weblate/trans/models/component.py:1013
msgid "Restricted component"
msgstr "Comhpháirt srianta"

#: weblate/trans/models/component.py:1017
msgid ""
"Restrict access to the component to only those explicitly given permission."
msgstr ""
"Srian a chur le rochtain ar an gcomhpháirt dóibh siúd amháin ar tugadh cead "
"sainráite dóibh."

#: weblate/trans/models/component.py:1029
msgid "Choose additional projects where this component will be listed."
msgstr ""
"Roghnaigh tionscadail bhreise ina mbeidh an chomhpháirt seo liostaithe."

#: weblate/trans/models/component.py:1035
msgid "Use as a glossary"
msgstr "Úsáid mar ghluais"

#: weblate/trans/models/component.py:1039
msgid ""
"Glossaries are different from regular translations but help keep track of "
"and share consistent terminology."
msgstr ""
"Tá gluaiseanna difriúil ó aistriúcháin rialta ach cabhraíonn siad le "
"téarmaíocht chomhsheasmhach a rianú agus a roinnt."

#: weblate/trans/models/component.py:1043
msgid "Glossary color"
msgstr "Dath gluais"

#: weblate/trans/models/component.py:1054
msgid "Key filter"
msgstr "Scagaire eochair"

#: weblate/trans/models/component.py:1058
msgid ""
"Regular expression used to filter keys. This is only available for "
"monolingual formats."
msgstr ""
"Sloinneadh rialta a úsáidtear chun eochracha a scagadh. Níl sé seo ar fáil "
"ach i bhformáidí aonteangacha."

#: weblate/trans/models/component.py:1071
msgid "This setting is inherited from the project if left empty."
msgstr ""
"Faightear an socrú seo mar oidhreacht ón tionscadal má fhágtar folamh é."

#: weblate/trans/models/component.py:1083
msgid "Use the secondary language configured in the category or project."
msgstr ""
"Úsáid an teanga thánaisteach atá cumraithe sa chatagóir nó sa tionscadal."

#: weblate/trans/models/component.py:2133
msgid ""
"Could not verify the SSH host key. Please add it on the SSH page in the "
"admin interface."
msgstr ""
"Níorbh fhéidir eochair óstach SSH a fhíorú. Cuir leis ar leathanach SSH sa "
"chomhéadan riaracháin é, le do thoil."

#: weblate/trans/models/component.py:2139
msgid ""
"The SSH host key for the repository has changed. Verify the new fingerprint, "
"remove the stored host key, and add the new one on the SSH page in the admin "
"interface."
