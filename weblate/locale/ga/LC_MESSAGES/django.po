msgstr "Folaigh seoladh r-phoist ó radharc an phobail"

#: weblate/accounts/forms.py:395
#, python-format
msgid "Component list: %s"
msgstr "Liosta na ngnéithe: %s"

#: weblate/accounts/forms.py:422
msgid "Account e-mail"
msgstr "Ríomhphost cuntais"

#: weblate/accounts/forms.py:424
msgid ""
"Used for e-mail notifications and as a commit e-mail if it is not configured "
"below."
msgstr ""
"Úsáidtear é le haghaidh fógraí ríomhphoist agus mar r-phost geallta mura "
"bhfuil sé cumraithe thíos."

#: weblate/accounts/forms.py:502
msgid "Human verification"
msgstr "Fíorú daonna"

