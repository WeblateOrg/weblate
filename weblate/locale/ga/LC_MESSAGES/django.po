#: weblate/accounts/forms.py:1207
msgid "The entered token is not valid."
msgstr "Níl an comhartha iontrála bailí."

#: weblate/accounts/forms.py:1277
msgid "Recovery token"
msgstr "Comhartha aisghabhála"

#: weblate/accounts/forms.py:1279
msgid ""
"Recovery codes can only be used once. Remember to mark used ones as expired."
msgstr ""
"Ní féidir cóid aisghabhála a úsáid ach uair amháin. Ná déan dearmad na cinn "
"a úsáideadh a mharcáil mar rud atá imithe in éag."

