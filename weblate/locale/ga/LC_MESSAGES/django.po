msgstr "Minicíocht nuashonraithe"

#: weblate/addons/forms.py:140
msgid "Daily"
msgstr "Laethúil"

#: weblate/addons/forms.py:141
msgid "Weekly"
msgstr "Seachtainiúil"

#: weblate/addons/forms.py:142
msgid "Monthly"
msgstr "Míosúil"

#: weblate/addons/forms.py:147
msgid ""
"How often the add-on should update the POT file when the component is "
"refreshed."
msgstr ""
"Cé chomh minic ba chóir don bhreiseán an comhad POT a nuashonrú nuair a "
"athnuachantar an chomhpháirt."

#: weblate/addons/forms.py:151
msgid "Normalize POT header"
msgstr "Ceanntásc POT a normalú"

