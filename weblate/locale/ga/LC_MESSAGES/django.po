msgstr ""
"Ní eilimint fholús aitheanta í an eilimint HTML {name}, mar sin níor cheart "
"go mbeadh clib féindhúnta aige: {self_close}."

#: weblate/checks/fluent/inner_html.py:327
#, python-brace-format
msgid "The HTML {tag} tag is missing a matching end tag: {end}."
msgstr "Tá clib deiridh meaitseáilte in easnamh ar an gclib {tag} HTML: {end}."

