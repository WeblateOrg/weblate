msgid "Use account e-mail address"
msgstr "Úsáid seoladh ríomhphoist an chuntais"

#: weblate/accounts/forms.py:215
msgid ""
"Used in version-control commits. The address stays in the repository forever "
"once changes are committed by Weblate."
msgstr ""
"A úsáidtear i leagan-rialú gealltanas. Fanann an seoladh sa stór go deo "
"nuair a bhíonn athruithe geallta ag Weblate."

#: weblate/accounts/forms.py:222 weblate/accounts/models.py:985
msgid "Commit name"
msgstr "Ainm tiomantais"

#: weblate/accounts/forms.py:225
msgid ""
"Used in version control commits. The name stays in the repository forever, "
"once changes are committed by Weblate."
msgstr ""
"Úsáidtear é i ngealltanais rialaithe leaganacha. Fanann an t-ainm sa "
"stórlann go deo, a luaithe a dhéanann Weblate athruithe."

#: weblate/accounts/forms.py:253
msgid "Use anonymous account name"
msgstr "Úsáid ainm cuntais gan ainm"

#: weblate/accounts/forms.py:255
msgid "Use account name"
msgstr "Úsáid ainm an chuntais"

#: weblate/accounts/forms.py:276 weblate/accounts/models.py:968
