msgid "Validation failed, please try again."
msgstr "Theip ar bhailíochtú, bain triail eile as."

#: weblate/accounts/forms.py:651
msgid "Subject"
msgstr "Ábhar"

#: weblate/accounts/forms.py:654
msgid "Your name"
msgstr "D'ainm"

#: weblate/accounts/forms.py:656
msgid "Your e-mail"
msgstr "Do r-phost"

