msgstr[2] "Ní thaispeántar ach cuid de na %(count)s teagmhas."
msgstr[3] "Ní thaispeántar ach cuid de na %(count)s teagmhas."
msgstr[4] "Ní thaispeántar ach cuid de na %(count)s teagmhas."

#: weblate/templates/trans/alert/parseerror.html:3
msgid ""
"Weblate could not parse the translation files while updating the "
