#: weblate/accounts/forms.py:100
msgid ""
"This e-mail address is already in use. Please supply a different e-mail "
"address."
msgstr ""
"Úsáideadh an seoladh ríomhphoist seo cheana. Cuir isteach seoladh "
"ríomhphoist eile."

#: weblate/accounts/forms.py:132
msgid "This username is already taken. Please pick something else."
msgstr ""
"Tá an t-ainm úsáideora seo tógtha cheana féin. Roghnaigh rud éigin eile le "
"do thoil."

