#: weblate/checks/fluent/inner_html.py:130
#, python-brace-format
msgid ""
"The Fluent reference in {sequence} may expand into an HTML tag. Maybe use "
"{suggestion}."
msgstr ""
"D’fhéadfadh an tagairt Fluent i {sequence} leathnú isteach i gclib HTML. "
"B’fhéidir {suggestion} a úsáid."

#: weblate/checks/fluent/inner_html.py:145
#, python-brace-format
msgid ""
"The Fluent reference in {sequence} may expand into an HTML character "
"reference. Maybe use {suggestion}."
msgstr ""
"D’fhéadfadh an tagairt Fluent i {sequence} leathnú isteach i dtagairt "
"carachtar HTML. B’fhéidir {suggestion} a úsáid."

#: weblate/checks/fluent/inner_html.py:173
#, python-brace-format
msgid ""
"The sequence {sequence} begins with an HTML closing tag, but the name or "
"syntax is not valid. If you do not want a closing tag, use {suggestion}."
msgstr ""
"Tosaíonn an seicheamh {sequence} le clib dhúnta HTML, ach níl an t-ainm ná "
"an comhréir bailí. Mura dteastaíonn clib dhúnta uait, bain úsáid as "
"{suggestion}."

#: weblate/checks/fluent/inner_html.py:186
#, python-brace-format
msgid ""
"The sequence {sequence} begins with an HTML tag, but the name is not valid. "
"If you do not want to begin an HTML tag, use {suggestion}."
msgstr ""
"Tosaíonn an seicheamh {sequence} le clib HTML, ach níl an t-ainm bailí. Mura "
"mian leat clib HTML a thosú, bain úsáid as {suggestion}."

#: weblate/checks/fluent/inner_html.py:199
#, python-brace-format
msgid ""
"The sequence {sequence} begins with an HTML tag, but the tag is never closed "
"by {close}. If you do not want to begin an HTML tag, use {suggestion}."
msgstr ""
"Tosaíonn an seicheamh {sequence} le clib HTML, ach ní dhúnann {close} an "
"clib choíche. Mura mian leat clib HTML a thosú, bain úsáid as {suggestion}."

#: weblate/checks/fluent/inner_html.py:213
#, python-brace-format
msgid ""
"Fluent inner HTML should not include {sequence}. Maybe use {suggestion}."
msgstr ""
"Níor cheart go gcuimseodh HTML líofa istigh {sequence}. B’fhéidir "
"{suggestion} a úsáid."

#: weblate/checks/fluent/inner_html.py:229
#, python-brace-format
msgid ""
"The sequence {sequence} begins with an HTML tag, but the sequence "
"{attribute} is not a valid attribute with a value. If you do not want to "
"begin an HTML tag, use {suggestion}."
msgstr ""
"Tosaíonn an seicheamh {sequence} le clib HTML, ach ní tréith bhailí le luach "
"í an seicheamh {attribute}. Mura mian leat clib HTML a thosú, bain úsáid as "
"{suggestion}."

#: weblate/checks/fluent/inner_html.py:247
#, python-brace-format
msgid "The HTML attribute name {name} for the {tag} tag is not valid."
msgstr "Níl an t-ainm aitreabúide HTML {name} don chlib {tag} bailí."

