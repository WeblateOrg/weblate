msgid "Password"
msgstr "Pasfhocal"

#: weblate/accounts/forms.py:845
msgid "Please enter the correct username and password."
msgstr "Cuir isteach an ainm úsáideora agus an pasfhocal i gceart."

#: weblate/accounts/forms.py:847
msgid "This account is inactive."
msgstr "Tá an cuntas seo neamhghníomhach."

#: weblate/accounts/forms.py:966
msgid "Component wide notifications"
msgstr "Fógraí ar fud na Comhpháirte"

#: weblate/accounts/forms.py:971
msgid "Translation notifications"
msgstr "Fógraí aistriúcháin"

#: weblate/accounts/forms.py:990
msgid "Use default setting"
msgstr "Úsáid an socrú réamhshocraithe"

#: weblate/accounts/forms.py:1022
msgid "Other projects"
msgstr "Tionscadail eile"

