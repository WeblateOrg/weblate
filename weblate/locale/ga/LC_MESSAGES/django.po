"Athruithe Rebase Weblate ar bharr an tsrutha agus aon choinbhleachtaí a "
"réiteach."

#: weblate/templates/trans/merge_instructions.html:36
msgid "Push changes into upstream repository."
msgstr "Brúigh athruithe isteach sa stór in aghaidh an tsrutha."

#: weblate/templates/trans/merge_instructions.html:41
