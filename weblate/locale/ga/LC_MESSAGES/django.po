#: weblate/templates/dashboard/user.html:43
msgid "Managed projects"
msgstr "Tionscadail bainistithe"

#: weblate/accounts/forms.py:1011
msgid "Project: {}"
msgstr "Tionscadal: {}"

#: weblate/accounts/forms.py:1012
msgid "Component: {}"
msgstr "Gné: {}"

#: weblate/accounts/forms.py:1018
msgid ""
"You will receive a notification for every such event in non-watched projects."
msgstr ""
"Gheobhaidh tú fógra le haghaidh gach ceann de na himeachtaí seo sna "
"tionscadail nach leanann tú."

#: weblate/accounts/forms.py:1023
msgid ""
"You will receive a notification for every such event in your watched "
"projects."
msgstr ""
"Gheobhaidh tú fógra le haghaidh gach ceann de na himeachtaí seo sna "
"tionscadail a leanann tú."

#: weblate/accounts/forms.py:1028
msgid ""
"You will receive a notification for every such event in projects where you "
"have admin permissions."
msgstr ""
"Gheobhaidh tú fógra le haghaidh gach ceann de na himeachtaí seo i "
"dtionscadail a bhfuil ceadanna riarthóra agat."

#: weblate/accounts/forms.py:1033
#, python-format
msgid "You will receive a notification for every such event in %(project)s."
msgstr ""
"Gheobhaidh tú fógra le haghaidh gach ceann de na himeachtaí seo i "
"%(project)s."

#: weblate/accounts/forms.py:1036
#, python-format
msgid "You will receive a notification for every such event in %(component)s."
msgstr ""
"Gheobhaidh tú fógra le haghaidh gach ceann de na himeachtaí seo i "
"%(component)s."

#: weblate/accounts/forms.py:1043
msgid ""
"You will only receive these notifications for your translated languages in "
"non-watched projects."
msgstr ""
"Ní bhfaighidh tú na fógraí seo ach le haghaidh na teangacha a d'aistrigh tú "
"sna tionscadail nach leanann tú."

#: weblate/accounts/forms.py:1048
msgid ""
"You will only receive these notifications for your translated languages in "
"your watched projects."
msgstr ""
"Ní bhfaighidh tú na fógraí seo ach le haghaidh na teangacha a d'aistrigh tú "
"sna tionscadail a leanann tú."

#: weblate/accounts/forms.py:1053
msgid ""
"You will only receive these notifications for your translated languages in "
"projects where you have admin permissions."
msgstr ""
"Ní bhfaighidh tú na fógraí seo ach le haghaidh na teangacha a d'aistrigh tú "
"sna tionscadail a bhfuil ceadanna riarthóra agat."

#: weblate/accounts/forms.py:1058
#, python-format
msgid ""
"You will only receive these notifications for your translated languages in "
"%(project)s."
msgstr ""
"Ní bhfaighidh tú na fógraí seo ach le haghaidh na teangacha a d'aistrigh tú "
"i %(project)s."

#: weblate/accounts/forms.py:1062
#, python-format
msgid ""
"You will only receive these notifications for your translated languages in "
"%(component)s."
msgstr ""
"Ní bhfaighidh tú na fógraí seo ach le haghaidh na teangacha a d'aistrigh tú "
"i %(component)s."

