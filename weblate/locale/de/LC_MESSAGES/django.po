msgid_plural ""
"The component has not received any translation within %(count)s days."
msgstr[0] ""
"Die Komponente hat innerhalb von %(count)s Tag keine Übersetzung erhalten."
msgstr[1] ""
"Die Komponente hat innerhalb von %(count)s Tagen keine Übersetzung erhalten."

#: app/src/weblate/templates/trans/alert/unusedcomponent.html:7
msgid "Please consider removing the component if it is no longer useful."
msgstr ""
"Bitte erwägen Sie, die Komponente zu entfernen, wenn sie nicht mehr benötigt "
"wird."

#: app/src/weblate/templates/trans/alert/unusedenforcedcheck.html:5
msgid "Following enforced checks are not used anywhere:"
msgstr "Folgende erzwungene Qualitätsprüfungen werden nirgends verwendet:"

