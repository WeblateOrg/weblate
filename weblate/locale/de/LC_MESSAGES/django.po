#: app/src/weblate/templates/snippets/about.html:4
msgid ""
"Weblate is a web-based translation tool with tight version control "
"integration. It features a simple and clean user interface, propagation of "
"translations across components, quality checks and automatic linking to "
"source files."
msgstr ""
"Weblate ist ein webbasiertes Übersetzungswerkzeug mit fester Einbindung von "
"Versionsverwaltungen. Es bietet eine einfache und klare Bedienoberfläche, "
"die Übertragung von Übersetzungen über Komponenten hinweg, "
"Qualitätsprüfungen und automatische Verlinkungen zu den Quelldateien."

#: app/src/weblate/templates/snippets/about.html:8
#, python-format
msgid "More information about Weblate can be found on %(weblate_link)s."
msgstr "Weitere Informationen zu Weblate finden Sie unter %(weblate_link)s."

#: app/src/weblate/templates/snippets/about.html:12
msgid ""
"Weblate is libre software with professional support and services for "
"commercial users."
msgstr ""
"Weblate ist eine Freie Software mit professionellem Support und Diensten für "
"kommerzielle Nutzung."

#: app/src/weblate/templates/snippets/about.html:15
msgid "Explore support options at weblate.org."
msgstr "Entdecken Sie die Supportoptionen unter weblate.org."

#: app/src/weblate/templates/snippets/activity.html:9
msgid "Last 12 months"
msgstr "Letzte 12 Monate"

#: app/src/weblate/templates/snippets/activity.html:13
msgctxt "Previous 12 months"
msgid "Previous"
msgstr "Vorherige"

#: app/src/weblate/templates/snippets/activity.html:15
