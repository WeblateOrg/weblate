#: weblate/addons/forms.py:1651
msgid "The AMQP broker URL to connect to."
msgstr "Die AMQP-Broker-URL, mit dem eine Verbindung hergestellt werden soll."

#: weblate/addons/forms.py:1656
msgid "CA certificate bundle (PEM)"
msgstr "CA-Zertifikatsbündel (PEM)"

#: weblate/addons/forms.py:1658
msgid ""
"Paste only PEM certificate blocks, each starting with \"-----BEGIN "
"CERTIFICATE-----\" and ending with \"-----END CERTIFICATE-----\"."
msgstr ""
"Fügen Sie nur PEM-Zertifikatsblöcke ein, die jeweils mit „-----BEGIN "
"CERTIFICATE-----“ beginnen und mit „-----END CERTIFICATE-----“ enden."

#: weblate/addons/forms.py:1664
msgid "Client private key (PEM)"
msgstr "Privater Client-Schlüssel (PEM)"

#: weblate/addons/forms.py:1666
msgid ""
"Paste a single unencrypted PEM private key block. Encrypted private keys are "
"not supported."
msgstr ""
"Fügen Sie einen einzelnen, unverschlüsselten PEM-Block für einen privaten "
"Schlüssel ein. Verschlüsselte private Schlüssel werden nicht unterstützt."

#: weblate/addons/forms.py:1673
msgid "Client certificate (PEM)"
msgstr "Client-Zertifikat (PEM)"

#: weblate/addons/forms.py:1675
msgid ""
"Paste only the PEM certificate block starting with \"-----BEGIN "
"CERTIFICATE-----\"; do not paste the output from \"openssl x509 -text\"."
msgstr ""
"Fügen Sie nur den PEM-Zertifikatsblock ein, der mit „-----BEGIN "
"CERTIFICATE-----“ beginnt; fügen Sie nicht die Ausgabe von „openssl x509 "
"-text“ ein."

#: weblate/addons/forms.py:1680
msgid "Publish timeout"
msgstr "Zeitüberschreitung für die Veröffentlichung"

#: weblate/addons/forms.py:1682
msgid "How many seconds to wait for the broker delivery acknowledgement."
msgstr ""
"Wie viele Sekunden auf die Zustellbestätigung des Brokers gewartet werden "
"soll."

#: weblate/addons/forms.py:1690
msgid "Connection attempts"
msgstr "Verbindungsversuche"

#: weblate/addons/forms.py:1691
msgid "How many times to try connecting to the broker."
msgstr "Wie oft ein Verbindungsaufbau zum Broker versucht werden soll."

#: weblate/addons/forms.py:1698
msgid "Retry delay"
msgstr "Wiederholungsverzögerung"

#: weblate/addons/forms.py:1699
msgid "How many seconds to wait between connection attempts."
msgstr ""
"Wie viele Sekunden zwischen den Verbindungsversuchen gewartet werden soll."

#: weblate/addons/forms.py:1763
msgid "The SSL certificates have to be provided for SSL connection."
msgstr ""
"Die SSL-Zertifikate müssen für die SSL-Verbindung bereitgestellt werden."

#: weblate/addons/forms.py:1776
msgid "The SSL certificates are not used without a SSL connection."
msgstr "Die SSL-Zertifikate werden ohne SSL-Verbindung nicht verwendet."

#: weblate/addons/generate.py:47
msgid "Statistics generator"
msgstr "Statistikgenerator"

#: weblate/addons/generate.py:49
msgid "Generates a file containing detailed info about the translation status."
msgstr ""
"Erzeugt eine Datei mit detaillierten Informationen zum Übersetzungsstatus."

#: weblate/addons/generate.py:185
msgid "Pseudolocale generation"
msgstr "Pseudolokale erzeugen"

#: weblate/addons/generate.py:187
msgid ""
"Generates a translation by adding prefix and suffix to source strings "
"automatically."
msgstr ""
"Erzeugt eine Übersetzung durch automatisches Hinzufügen von Präfix und "
"Suffix zu Ausgangszeichenketten."

#: weblate/addons/generate.py:274
msgid "Prefill translation with source"
msgstr "Übersetzung mit Ausgangszeichenkette ausfüllen"

#: weblate/addons/generate.py:275
msgid "Fills in translation strings with source string."
msgstr "Füllt Übersetzungszeichenketten mit der Ausgangszeichenkette aus."

#: weblate/addons/generate.py:313
msgid "Fill read-only strings with source"
msgstr "Schreibgeschützte Zeichenketten mit Ausgangszeichenkette ausfüllen"

#: weblate/addons/generate.py:315
msgid "Fills in translation of read-only strings with source string."
msgstr ""
"Füllt die Übersetzung von schreibgeschützten Zeichenketten mit der "
"Ausgangszeichenkette aus."

#: weblate/addons/gettext.py:94
msgid "Generate MO files"
msgstr "MO-Dateien erzeugen"

#: weblate/addons/gettext.py:96
msgid "Automatically generates a MO file for every changed PO file."
msgstr "Erzeugt automatisch eine MO-Datei für jede geänderte PO-Datei."

#: weblate/addons/gettext.py:136
msgid "Update LINGUAS file"
msgstr "LINGUAS-Datei aktualisieren"

#: weblate/addons/gettext.py:138
msgid "Updates the LINGUAS file when a translation is added or removed."
msgstr ""
"Aktualisiert die LINGUAS-Datei, wenn eine Übersetzung hinzugefügt oder "
"entfernt wird."

#: weblate/addons/gettext.py:278
msgid "Update ALL_LINGUAS variable in the \"configure\" file"
msgstr "ALL_LINGUAS-Variable in der Datei „configure“aktualisieren"

#: weblate/addons/gettext.py:280
msgid ""
"Updates the ALL_LINGUAS variable in \"configure\", \"configure.in\" or "
"\"configure.ac\" files, when a translation is added or removed."
msgstr ""
"Aktualisiert die Variable ALL_LINGUAS in „configure“, „configure.in“ oder "
"„configure.ac“-Dateien, wenn eine Übersetzung hinzugefügt oder entfernt wird."

#: weblate/addons/gettext.py:374
msgid "Update PO files to match POT (msgmerge)"
msgstr "PO-Dateien auf POT aktualisieren (msgmerge)"

#: weblate/addons/gettext.py:376
msgid ""
"Updates all PO files (as configured by \"File mask\") to match the POT file "
"(as configured by \"Template for new translations\") using msgmerge."
msgstr ""
"Aktualisiert alle PO-Dateien (wie mit „Dateimaske“ konfiguriert), damit sie "
"mit der POT-Datei (wie mit „Vorlage für neue Übersetzungen“ konfiguriert) "
"übereinstimmen, mit msgmerge."

#: weblate/addons/gettext.py:999
msgid "Update POT file (xgettext)"
msgstr "POT-Datei aktualisieren (xgettext)"

#: weblate/addons/gettext.py:1001
msgid "Updates the gettext template using xgettext on selected source files."
msgstr ""
"Aktualisiert die gettext-Vorlage mithilfe von xgettext für ausgewählte "
"Quelldateien."

#: weblate/addons/gettext.py:1412
msgid "Update POT file (Meson)"
msgstr "POT-Datei aktualisieren (Meson)"

#: weblate/addons/gettext.py:1414
msgid "Updates the gettext template using Meson gettext conventions."
msgstr ""
"Aktualisiert die gettext-Vorlage mithilfe der Meson-gettext-Konventionen."

#: weblate/addons/gettext.py:1562
msgid "Update gettext template (Django)"
msgstr "gettext-Vorlage aktualisieren (Django)"

#: weblate/addons/gettext.py:1564
msgid ""
"Updates the gettext template using Django's built-in makemessages command."
msgstr ""
"Aktualisiert die gettext-Vorlage mithilfe des in Django integrierten "
"makemessages-Befehls."

#: weblate/addons/gettext.py:1756
msgid "Update POT file (Sphinx)"
msgstr "POT-Datei aktualisieren (Sphinx)"

#: weblate/addons/gettext.py:1758
msgid ""
"Updates the gettext template using Sphinx's gettext builder without loading "
"project configuration."
msgstr ""
"Aktualisiert die gettext-Vorlage mithilfe des gettext-Builders von Sphinx, "
"ohne die Projektkonfiguration zu laden."

#: weblate/addons/gettext.py:2008
msgid "Contributors in comment"
msgstr "Mitwirkende im Kommentar"

#: weblate/addons/gettext.py:2010
msgid ""
"Updates the comment part of the PO file header to include contributor names "
"and years of contributions."
msgstr ""
"Aktualisiert den Kommentarteil im Header der PO-Datei, um den Namen des "
"Mitwirkenden und das Datum des Beitrags aufzunehmen."

#: weblate/addons/git.py:41
