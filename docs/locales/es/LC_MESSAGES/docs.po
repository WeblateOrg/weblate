#: changes/v4.rst:1125
msgid "Weblate 4.1"
msgstr "Weblate 4.1"

#: changes/v4.rst:1127
msgid "*Released on June 15th 2020.*"
msgstr "*Publicada el 15 de junio de 2020.*"

#: changes/v4.rst:1129
msgid "Added support for creating new translations with included country code."
msgstr "Pueden crearse traducciones nuevas con código de país."

#: changes/v4.rst:1130
msgid "Added support for searching source strings with screenshot."
msgstr "Es posible buscar cadenas de origen con captura de pantalla."

#: changes/v4.rst:1131
msgid "Extended info available in the stats insights."
msgstr "Información ampliada disponible en el seguimiento de estadísticas."

#: changes/v4.rst:1132
msgid "Improved search editing on \"Translate\" pages."
msgstr "Se mejoró la edición de la búsqueda en las páginas «Traducir»."

#: changes/v4.rst:1133
msgid "Improve handling of concurrent repository updates."
msgstr ""
"Se mejora el tratamiento de actualizaciones de repositorio concurrente."

#: changes/v4.rst:1134
msgid "Include source language in project creation form."
msgstr ""
"Se incluye el idioma de origen en el formulario de creación de proyecto."

#: changes/v4.rst:1135
msgid "Include changes count in credits."
msgstr "Se incluye el recuento de cambios en los créditos."

#: changes/v4.rst:1136
msgid "Fixed UI language selection in some cases."
msgstr "Se corrigió la selección del idioma de interfaz en casos puntuales."

#: changes/v4.rst:1137
msgid ""
"Possibility to allow certain registration methods with registrations closed."
msgstr ""
"Posibilidad de conceder determinados métodos de inscripción con las "
"inscripciones cerradas."

#: changes/v4.rst:1138
msgid "Improved lookup of related terms in glossary."
msgstr "Se mejoró la búsqueda de términos relacionados en el glosario."

#: changes/v4.rst:1139
msgid "Improved translation memory matches."
msgstr "Se mejoraron las coincidencias de memoria de traducción."

#: changes/v4.rst:1140
msgid "Group same machinery results."
msgstr "Se agrupan los resultados idénticos en la automatización."

#: changes/v4.rst:1141
msgid "Add direct link to edit screenshot from translate page."
msgstr ""
"Se añadió un enlace directo para editar capturas de pantalla desde la página "
