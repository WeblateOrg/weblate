msgstr "`Editada`"

#: devel/reporting.rst:93
msgid "Amount of edited strings which had a translation before."
msgstr "Cantidad de cadenas editadas que tuvieron una traducción antes."

#: devel/reporting.rst:95
msgid "The following metrics are available for each:"
msgstr "Las siguientes métricas están disponibles para cada uno:"

#: devel/reporting.rst:97
msgid "`Count`"
msgstr "`Conteo`"

#: devel/reporting.rst:98
msgid "Amount of strings."
msgstr "Cantidad de cadenas."

#: devel/reporting.rst:99
msgid "`Edits`"
msgstr "`Editadas`"

