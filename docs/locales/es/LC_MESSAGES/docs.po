#: changes/v4.rst:576
msgid "Improved performance of the translation pages."
msgstr "Se mejoró el rendimiento en las páginas de traducción."

#: changes/v4.rst:577
msgid "Added support for restricting translation file downloads."
msgstr ""
"Se añadió mantenimiento para restricción descargas del archivo de traducción."

