msgid "Weblate 5.1"
msgstr "Weblate 5.1"

#: changes.rst:1969
msgid "*Released on October 16th 2023.*"
msgstr "*Publicada el 15 de octubre de 2023.*"

#: changes.rst:1973
msgid ":ref:`mt-yandex-v2` machine translation service."
msgstr "Servicio de traducción de máquina :ref:`mt-yandex-v2`."

#: changes.rst:1974
msgid ""
":ref:`addon-weblate.autotranslate.autotranslate` and :ref:`auto-translation` "
