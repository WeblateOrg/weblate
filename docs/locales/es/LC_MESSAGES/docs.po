#: changes/v4.rst:1196
msgid "Weblate 4.0.3"
msgstr "Weblate 4.0.3"

#: changes/v4.rst:1198
msgid "*Released on May 2nd 2020.*"
msgstr "*Publicada el 2 de mayo de 2020.*"

#: changes/v4.rst:1200
msgid "Fixed possible crash in reports."
msgstr "Se corrigió cuelgue posible en informes."

#: changes/v4.rst:1201
