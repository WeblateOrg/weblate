msgstr "*Publicado el 16 de noviembre de 2023.*"

#: changes.rst:1909
msgid ":ref:`vcs-azure-devops`."
msgstr ":ref:`vcs-azure-devops`."

#: changes.rst:1913
msgid "Faster statistics updates."
msgstr "Actualizaciones estadísticas más rápidas."

#: changes.rst:1914
msgid "Better e-mail selection in user profile."
msgstr "Mejor selección de correo electrónico en el perfil de usuario."

#: changes.rst:1915
msgid ":ref:`autofix` are now applied to suggestions as well."
msgstr ":ref:`autofix` se aplican ahora también a las sugerencias."

#: changes.rst:1916
