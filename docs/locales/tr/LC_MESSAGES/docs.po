#: contributing/release.rst:38
msgid "Set final version by :command:`./scripts/prepare-release`."
msgstr "Son sürümü :command:`./scripts/prepare-release` ile ayarlayın."

#: contributing/release.rst:39
msgid ""
"Make sure screenshots are up to date :command:`make -j 12 -C docs update-"
"screenshots`."
msgstr ""
"Ekran görüntülerinin güncel olduğundan emin olun :command:`make -j 12 -C "
"docs update-screenshots`."

