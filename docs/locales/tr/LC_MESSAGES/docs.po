msgstr "https://weblate.org/user/ adresinden kendinizi kaydedin"

#: admin/support.rst:112
msgid ""
"Register your Weblate site at https://weblate.org/subscription/discovery/"
msgstr ""
"Weblate sunucunuzu https://weblate.org/subscription/discovery/ adresinden "
