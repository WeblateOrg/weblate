msgid ""
"Marina Sanchez-Torron and Philipp Koehn in Machine Translation Quality and "
"Post-Editor Productivity, Figure 1: https://www.cs.jhu.edu/~phi/publications/"
"machine-translation-quality.pdf"
msgstr ""

