msgid "Weblate 4.2.2"
msgstr "Weblate 4.2.2"

#: changes/v4.rst:1043
msgid "*Released on September 2nd 2020.*"
msgstr "*Uitgegeven op 2 september 2020.*"

#: changes/v4.rst:1045
msgid "Fixed matching of source strings for JSON formats."
msgstr "Gerepareerd overeenkomen van brontekenreeksen voor indelingen JSON."

#: changes/v4.rst:1046
