msgstr ""
"Verwijdert untracked bestanden en verouderde branches uit de checkout van de "
"lokale opslagruimte."

#: admin/continuous.rst:246
msgid ""
"Clean up leftover files or stale repository state in Weblate's checkout."
msgstr ""
"Opruimen van achtergebleven bestanden of verouderde staat van de "
"opslagruimte in Weblate's checkout."

#: admin/continuous.rst:248
msgid ":guilabel:`Synchronize`"
msgstr ":guilabel:`Synchroniseren`"

#: admin/continuous.rst:249
msgid ""
