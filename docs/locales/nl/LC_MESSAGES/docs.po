#: changes/v4.rst:1008
msgid "Improved JSON, YAML and CSV formats compatibility."
msgstr "Verbeterde compatibiliteit indelingen JSON, YAML en CSV."

#: changes/v4.rst:1009
msgid "Added support for removing strings."
