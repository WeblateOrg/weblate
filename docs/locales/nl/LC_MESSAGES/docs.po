#~ "naar persistente en gecachete gegevens."

#~ msgid "**Weblate application ↔ Logging:** Application logic creating logs."
#~ msgstr ""
#~ "**Weblate toepassing ↔ Loggen:** Logica van de toepassing maakt logs."

#~ msgid ""
#~ "**Weblate application ↔ Internal VCS repository:** Application logic "
#~ "interacting with its local copy of the VCS repository."
#~ msgstr ""
