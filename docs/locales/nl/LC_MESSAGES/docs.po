#: changes/v4.rst:1049
msgid "Fixed Git commit squashing with trailers enabled."
msgstr "Git indieningen squashen met trailers ingeschakeld gerepareerd."

#: changes/v4.rst:1050
msgid "Fixed creating local VCS components using the API."
msgstr "Maken van lokale onderdelen van VCS met de API gerepareerd."

#: changes/v4.rst:1053
msgid "Weblate 4.2.1"
msgstr "Weblate 4.2.1"

#: changes/v4.rst:1055
msgid "*Released on August 21st 2020.*"
msgstr "*Uitgegeven op 21 augustus 2020.*"

#: changes/v4.rst:1057
msgid "Fixed saving plurals for some locales in Android resources."
msgstr ""
"Opslaan meervouden voor sommige locales in Android-bronnen gerepareerd."

#: changes/v4.rst:1058
msgid "Fixed crash in the cleanup add-on for some XLIFF files."
msgstr ""
"Gerepareerde crash in de add-on opschonen voor sommige XLIFF-bestanden."

#: changes/v4.rst:1059
msgid "Allow setting up localization CDN in Docker image."
