#~ "geauthenticeerde eindpunten ingeschakeld per project."

#~ msgid ""
#~ "**Web server ↔ Weblate application:** Communication between the reverse "
#~ "proxy/web server and the application logic."
#~ msgstr ""
#~ "**Webserver ↔ Weblate toepassing:** Communicatie tussen de omgekeerde "
#~ "proxy/webserver en de logica van de toepassing."

#~ msgid ""
#~ "**Weblate application ↔ Database:** Application logic accessing "
#~ "persistent and cached data."
