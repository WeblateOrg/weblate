msgstr "Platte tekstbestand"

#: formats/txt.rst:14 snippets/addon-parameters-autogenerated.rst:104
msgid "DokuWiki text file"
msgstr "DokuWiki-tekstbestand"

#: formats/txt.rst:15 snippets/addon-parameters-autogenerated.rst:148
