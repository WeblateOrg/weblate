#~ msgid ""
#~ "**Assumptions:** Standard Weblate deployment with typical components "
#~ "(nginx/Apache, granian/Gunicorn/uWSGI, PostgreSQL, datastore, Celery) and "
#~ "user roles (unauthenticated user, authenticated user, reviewer, project "
