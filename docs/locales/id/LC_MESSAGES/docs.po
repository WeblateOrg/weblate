msgid "File format"
msgstr "Format berkas"

#: admin/projects.rst:765
msgid "Translation file format, see also :ref:`formats`."
msgstr "Format berkas terjemahan, lihat juga :ref:`formats`."

#: admin/projects.rst:770 formats.rst:199 formats/asciidoc.rst:38
#: formats/gettext.rst:180 formats/html.rst:37 formats/json.rst:89
#: formats/markdown.rst:47 formats/mdx.rst:46 formats/txt.rst:46
