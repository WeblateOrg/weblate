#: changes/v4.rst:339
msgid "Fixed configuring intermediate file in the discovery add-on."
msgstr ""
"Memperbaiki pengkonfigurasian berkas intermediasi dalam pengaya penemuan."

#: changes/v4.rst:340
msgid "Fixed DeepL translations behavior with placeholders."
msgstr "Memperbaiki perilaku terjemahan DeepL dengan pengganti."

