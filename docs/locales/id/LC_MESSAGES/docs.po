msgstr "Weblate 4.13.1"

#: changes/v4.rst:334
msgid "*Released on July 1st 2022.*"
msgstr "*Dirilis pada 1 Juli 2022.*"

#: changes/v4.rst:336
msgid "Fixed tracking suggestions in history."
msgstr "Memperbaiki saran pelacakan dalam riwayat."

#: changes/v4.rst:337
msgid "Fixed parsing reverse proxy info from Cloudflare."
msgstr "Memperbaiki penguraian info proksi terbalik dari Cloudflare."

