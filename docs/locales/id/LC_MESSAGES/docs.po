#: admin/management.rst:521
msgid "Imports a file into the Weblate translation memory."
msgstr "Mengimpor berkas ke dalam memori terjemahan Weblate."

#: admin/management.rst:523
msgid "Supported file formats are TMX, JSON, XLIFF, PO, CSV."
msgstr "Format berkas yang didukung adalah TMX, JSON, XLIFF, PO, CSV."

