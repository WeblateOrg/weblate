#: user/translating.rst:531
#, fuzzy
#| msgid ""
#| "This tool is called :guilabel:`Bulk edit`, accessible in "
#| "the :guilabel:`Tools` menu of each project, component or translation."
msgid ""
"This tool is called :guilabel:`Bulk edit`, accessible in "
"the :guilabel:`Operations` menu of each project, component or translation."
msgstr ""
"Alat ini disebut :guilabel:`Sunting massal`, dapat diakses di "
"menu :guilabel:`Alat` pada setiap proyek, komponen, atau terjemahan."

#: user/translating.rst:540
