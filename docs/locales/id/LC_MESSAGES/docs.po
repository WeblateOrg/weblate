#: changes/v0.rst:7
msgid "*Released on April 18th 2012.*"
msgstr "*Dirilis pada 18 April 2012.*"

#: changes/v0.rst:9
msgid "Fixed import of unknown languages."
msgstr "Memperbaiki impor bahasa yang tidak dikenal."

#: changes/v0.rst:10
msgid "Improved listing of nearby messages."
msgstr "Meningkatkan daftar pesan terdekat."

#: changes/v0.rst:11
msgid "Improved several checks."
msgstr "Memperbaiki beberapa pemeriksaan."

#: changes/v0.rst:12 changes/v3.rst:241
msgid "Documentation updates."
msgstr "Pembaruan dokumentasi."

#: changes/v0.rst:13
msgid "Added definition for several more languages."
msgstr "Menambahkan definisi untuk beberapa bahasa lainnya."

#: changes/v0.rst:14
msgid "Various code cleanups."
msgstr "Berbagai pembersihan kode."

#: changes/v0.rst:15 changes/v1.rst:30 changes/v1.rst:177 changes/v2.rst:286
#: changes/v2.rst:340 changes/v2.rst:373 changes/v2.rst:460 changes/v2.rst:476
#: changes/v4.rst:77 changes/v4.rst:124 changes/v4.rst:630
msgid "Documentation improvements."
msgstr "Peningkatan dokumentasi."

#: changes/v0.rst:16
msgid "Changed file layout."
msgstr "Tata letak berkas diubah."

#: changes/v0.rst:17
msgid "Update helper scripts to Django 1.4."
msgstr "Perbarui skrip pembantu ke Django 1.4."

#: changes/v0.rst:18
msgid "Improved navigation while translating."
msgstr "Meningkatkan navigasi saat menerjemahkan."

#: changes/v0.rst:19
msgid "Better handling of po file renames."
msgstr "Penanganan penggantian nama berkas po yang lebih baik."

#: changes/v0.rst:20 changes/v1.rst:185
msgid "Better validation while creating component."
msgstr "Validasi yang lebih baik saat membuat komponen."

#: changes/v0.rst:21
msgid "Integrated full setup into syncdb."
msgstr "Pengaturan lengkap terintegrasi ke dalam syncdb."

#: changes/v0.rst:22
msgid "Added list of recent changes to all translation pages."
msgstr "Menambahkan daftar perubahan terkini ke semua halaman terjemahan."

#: changes/v0.rst:23
msgid "Check for untranslated strings ignores format string only messages."
msgstr ""
"Pemeriksaan string yang tidak diterjemahkan mengabaikan pesan string format "
"saja."

#: changes/v0.rst:26
msgid "Weblate 0.8"
msgstr "Weblate 0.8"

#: changes/v0.rst:28
msgid "*Released on April 3rd 2012.*"
msgstr "*Dirilis pada tanggal 3 April 2012.*"

#: changes/v0.rst:30
msgid "Replaced own full text search with Whoosh."
msgstr "Mengganti pencarian teks lengkap sendiri dengan Whoosh."

#: changes/v0.rst:31
msgid "Various fixes and improvements to checks."
msgstr "Berbagai perbaikan dan peningkatan pada pemeriksaan."

#: changes/v0.rst:32
msgid "New command updatechecks."
msgstr "Pembaruan pemeriksaan perintah baru."

#: changes/v0.rst:33
msgid "Lot of translation updates."
msgstr "Banyak pembaruan terjemahan."

#: changes/v0.rst:34
msgid "Added dictionary for storing most frequently used terms."
msgstr ""
"Menambahkan kamus untuk menyimpan istilah yang paling sering digunakan."

#: changes/v0.rst:35
msgid "Added /admin/report/ for overview of repositories status."
msgstr "Menambahkan /admin/report/ untuk ikhtisar status repositori."

#: changes/v0.rst:36
msgid "Machine translation services no longer block page loading."
msgstr "Layanan terjemahan mesin tidak lagi memblokir pemuatan halaman."

#: changes/v0.rst:37
msgid "Management interface now contains also useful actions to update data."
msgstr ""
"Antarmuka pengelolaan sekarang juga berisi tindakan yang berguna untuk "
"memperbarui data."

#: changes/v0.rst:38
msgid "Records log of changes made by users."
msgstr "Merekam catatan perubahan yang dibuat oleh pengguna."

#: changes/v0.rst:39
msgid ""
"Ability to postpone commit to Git to generate less commits from single user."
msgstr ""
"Kemampuan untuk menunda komit pada Git untuk menghasilkan komit lebih "
"sedikit dari satu pengguna."

#: changes/v0.rst:40
msgid "Possibility to browse failing checks."
msgstr "Kemungkinan untuk menelusuri pemeriksaan yang gagal."

#: changes/v0.rst:41
msgid "Automatic translation using already translated strings."
msgstr "Terjemahan otomatis menggunakan string yang sudah diterjemahkan."

#: changes/v0.rst:42
msgid "New about page showing used versions."
msgstr "Halaman tentang baru yang menunjukkan versi yang digunakan."

#: changes/v0.rst:43
msgid "Django 1.4 compatibility."
msgstr "Kompatibilitas Django 1.4."

#: changes/v0.rst:44
msgid "Ability to push changes to remote repo from web interface."
msgstr ""
"Kemampuan untuk mendorong perubahan ke repo jarak jauh dari antarmuka web."

#: changes/v0.rst:45
msgid "Added review of translations done by others."
msgstr "Menambahkan tinjauan atas terjemahan yang dilakukan oleh orang lain."

#: changes/v0.rst:48
msgid "Weblate 0.7"
msgstr "Weblate 0.7"

#: changes/v0.rst:50
msgid "*Released on February 16th 2012.*"
msgstr "*Dirilis pada 16 Februari 2012.*"

#: changes/v0.rst:52
msgid "Direct support for GitHub notifications."
msgstr "Dukungan langsung untuk notifikasi GitHub."

#: changes/v0.rst:53
msgid "Added support for cleaning up orphaned checks and translations."
msgstr ""
"Menambahkan dukungan untuk membersihkan pemeriksaan dan terjemahan yang "
"tidak terpakai."

#: changes/v0.rst:54
msgid "Displays nearby strings while translating."
msgstr "Menampilkan string terdekat saat menerjemahkan."

#: changes/v0.rst:55
msgid "Displays similar strings while translating."
msgstr "Menampilkan string yang serupa saat menerjemahkan."

#: changes/v0.rst:56
msgid "Improved searching for string."
msgstr "Pencarian string ditingkatkan."

#: changes/v0.rst:59
msgid "Weblate 0.6"
msgstr "Weblate 0.6"

#: changes/v0.rst:61
msgid "*Released on February 14th 2012.*"
msgstr "*Dirilis pada 14 Februari 2012.*"

#: changes/v0.rst:63
msgid "Added various checks for translated messages."
msgstr "Menambahkan berbagai pemeriksaan untuk pesan yang diterjemahkan."

#: changes/v0.rst:64
msgid "Tunable access control."
msgstr "Kontrol akses yang dapat disesuaikan."

#: changes/v0.rst:65
msgid "Improved handling of translations with new lines."
msgstr "Peningkatan penanganan terjemahan dengan baris baru."

#: changes/v0.rst:66
msgid "Added client side sorting of tables."
msgstr "Menambahkan penyortiran tabel di sisi klien."

#: changes/v0.rst:67
msgid "Please check upgrading instructions in case you are upgrading."
msgstr "Silakan periksa petunjuk peningkatan jika Anda meningkatkan."

#: changes/v0.rst:70
msgid "Weblate 0.5"
msgstr "Weblate 0.5"

