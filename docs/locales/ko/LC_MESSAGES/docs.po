msgstr ""
"이러한 번역을 Weblate로 가져오려면 구성요소를 만들 때 다음 필드를 정의하기만 "
"하면 됩니다 (필드에 대한 자세한 설명은 :ref:`component` 참조):"

#: devel/gettext.rst:229
msgid "Field"
msgstr "필드"

#: devel/gettext.rst:229 snippets/checks-autogenerated.rst:2299
#: workflows.rst:119 workflows.rst:151 workflows.rst:184
msgid "Value"
msgstr "값"

#: devel/gettext.rst:231
msgid "URL of the VCS repository with your project"
msgstr "프로젝트가 있는 VCS 저장소의 URL"

#: devel/gettext.rst:237
msgid "Choose :guilabel:`gettext PO file`"
msgstr ":guilabel:`gettext PO 파일` 선택"

#: devel/gettext.rst:239
msgid "New language"
msgstr "새 언어"

#: devel/gettext.rst:239
