msgid "Weblate 5.10.1"
msgstr "Weblate 5.10.1"

#: changes.rst:1147
msgid "*Released on February 21st 2025.*"
msgstr "*2025년 2월 21일 출시.*"

#: changes.rst:1151
msgid ""
":ref:`check-multiple-failures` better shows failing checks including links "
