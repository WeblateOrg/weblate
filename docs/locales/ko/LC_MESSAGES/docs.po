msgid "Weblate 4.13"
msgstr "Weblate 4.13"

#: changes/v4.rst:351
msgid "*Released on June 15th 2022.*"
msgstr "*2022년 6월 15일 출시.*"

#: changes/v4.rst:353
msgid "Changed behavior of updating language names."
msgstr "언어 이름 업데이트 동작이 변경되었습니다."

#: changes/v4.rst:354
