msgstr "相符的翻譯鍵"

#: devel/translations.rst:131
msgid "Suffix identification"
msgstr "後綴標識"

#: devel/translations.rst:131
msgid "``monthShort``, ``monthMin``, ``month``"
msgstr "``monthShort``、``monthMin``、``month``"

#: devel/translations.rst:133
msgid "Inline identification"
msgstr "單行標識"

#: devel/translations.rst:133
